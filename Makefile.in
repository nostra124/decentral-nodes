# Makefile template for the combined bitcoin stack (FEAT-191 autoconf
# umbrella). This repo ships MULTIPLE dispatchers from one rpk package:
#   bin/bitcoin  + libexec/bitcoin/*   (BIP plugins, wallet surface)
#   bin/lightning + libexec/lightning/* (Lightning / clightning frontend)
# merged from nostra124/lightning. A future bin/fulcrum slots in the
# same way (FEAT-055..060).
#
# Substituted at `./configure` time:
#   @PREFIX@        install prefix (default $HOME/.local non-root,
#                   /usr/local root)
#   @BINDIR@        $PREFIX/bin
#   @LIBEXECDIR@    $PREFIX/libexec
#   @SYSCONFDIR@    $PREFIX/etc
#   @DATADIR@       $PREFIX/share
#   @MANDIR@        $PREFIX/share/man
#   @PACKAGE@       the rpk package identity (bitcoin) — names the stow tree

SHELL = /bin/bash

PACKAGE   = @PACKAGE@
PREFIX    = @PREFIX@
BINDIR    = @BINDIR@
LIBEXECDIR = @LIBEXECDIR@
SYSCONFDIR = @SYSCONFDIR@
DATADIR   = @DATADIR@
MANDIR    = @MANDIR@

# Stow stages a $PREFIX-relative tree under $(BUILD_DIR), then
# `stow -t $(PREFIX)` symlinks it into place. The configure dir vars are
# absolute ($PREFIX/bin, …), so strip the prefix here: the stow source
# must mirror $PREFIX *relative* (build/bitcoin/bin), not $PREFIX/$PREFIX
# (build/bitcoin/usr/local/bin) — the latter is the old double-prefix
# packaging bug that left files at $PREFIX$PREFIX/… and never on PATH
# (BUG-038). Dirs configured outside $PREFIX keep their absolute path and
# are not stow-relocatable; that was never supported.
REL_BINDIR     = $(patsubst $(PREFIX)/%,%,$(BINDIR))
REL_LIBEXECDIR = $(patsubst $(PREFIX)/%,%,$(LIBEXECDIR))
REL_SYSCONFDIR = $(patsubst $(PREFIX)/%,%,$(SYSCONFDIR))
REL_DATADIR    = $(patsubst $(PREFIX)/%,%,$(DATADIR))
REL_MANDIR     = $(patsubst $(PREFIX)/%,%,$(MANDIR))

# The commands this one package ships. Each has bin/<cmd>, libexec/<cmd>/,
# share/<cmd>/, share/doc/<cmd>/. Add fulcrum here when it lands.
PACKAGES = bitcoin lightning fulcrum

BUILD_DIR = build/$(PACKAGE)

.PHONY: all install uninstall check check-unit check-vectors \
        check-sit check-pit check-pre-push check-all coverage \
        lint lint-cmd-names test help package clean \
        install-skills-user uninstall-skills-user \
        install-apache-bridge uninstall-apache-bridge

all: install

help:
	@echo "Targets: install, uninstall, check, lint,"
	@echo "         check-unit, check-vectors, check-sit, check-pit,"
	@echo "         check-pre-push, check-all, coverage,"
	@echo "         install-skills-user, uninstall-skills-user, package, clean"

# Stow-based install builds a tree mirroring $PREFIX layout under
# $(BUILD_DIR), then `stow -t $(PREFIX)` symlinks it. Symmetric
# uninstall via `stow -D`. Every command in $(PACKAGES) is staged into
# the one $(BUILD_DIR) tree, then stowed once under the $(PACKAGE) identity.
install:
	@command -v stow >/dev/null || { echo "stow not installed"; exit 1; }
	@mkdir -p $(BUILD_DIR)/$(REL_BINDIR) \
	          $(BUILD_DIR)/$(REL_SYSCONFDIR)/bash_completion.d \
	          $(BUILD_DIR)/$(REL_MANDIR)/man1
	@for p in $(PACKAGES); do \
		mkdir -p $(BUILD_DIR)/$(REL_LIBEXECDIR)/$$p \
		         $(BUILD_DIR)/$(REL_DATADIR)/doc/$$p \
		         $(BUILD_DIR)/$(REL_DATADIR)/$$p; \
	done
	@cp -a bin/* $(BUILD_DIR)/$(REL_BINDIR)/
	@for p in $(PACKAGES); do \
		if [ -d libexec/$$p ]; then \
			cp -a libexec/$$p/* $(BUILD_DIR)/$(REL_LIBEXECDIR)/$$p/; \
		fi; \
		if [ -d share/doc/$$p ]; then \
			cp -a share/doc/$$p/* $(BUILD_DIR)/$(REL_DATADIR)/doc/$$p/; \
		fi; \
		if [ -d share/$$p ]; then \
			cp -a share/$$p/* $(BUILD_DIR)/$(REL_DATADIR)/$$p/; \
		fi; \
	done
	@if [ -d etc/bash_completion.d ]; then \
		cp -a etc/bash_completion.d/* \
		      $(BUILD_DIR)/$(REL_SYSCONFDIR)/bash_completion.d/; \
	fi
	@if [ -d share/man/man1 ]; then \
		cp -a share/man/man1/* $(BUILD_DIR)/$(REL_MANDIR)/man1/; \
	fi
	# FEAT-019 / FEAT-048: agent skills, following the rpk skill convention
	# (https://github.com/nostra124/rpk, docs/PACKAGING.md). Skills are the
	# rpk-native flat files under .rpk/skills/<name>.md (migrated there from
	# skills/<name>/SKILL.md so `rpk skills` discovers them — commit ad723c4;
	# BUG-040). Each single file installs to BOTH
	# share/claude/skills/<name>/SKILL.md and share/raven/skills/<name>/
	# SKILL.md (Claude and Raven consume the same file) and to
	# share/opencode/commands/<name>.md.
	@if ls .rpk/skills/*.md >/dev/null 2>&1; then \
		for skill in .rpk/skills/*.md; do \
			[ -f "$$skill" ] || continue; \
			name=$$(basename "$$skill" .md); \
			mkdir -p $(BUILD_DIR)/$(REL_DATADIR)/claude/skills/$$name; \
			install -m 644 "$$skill" \
			    $(BUILD_DIR)/$(REL_DATADIR)/claude/skills/$$name/SKILL.md; \
			mkdir -p $(BUILD_DIR)/$(REL_DATADIR)/raven/skills/$$name; \
			install -m 644 "$$skill" \
			    $(BUILD_DIR)/$(REL_DATADIR)/raven/skills/$$name/SKILL.md; \
			mkdir -p $(BUILD_DIR)/$(REL_DATADIR)/opencode/commands; \
			install -m 644 "$$skill" \
			    $(BUILD_DIR)/$(REL_DATADIR)/opencode/commands/$$name.md; \
		done; \
	fi
	# VERSION → $DATADIR/<cmd>/version : the runtime version string each
	# binary reads (FEAT-194). The binary's fallback resolves to this file
	# when invoked as the installed entry, and to ./VERSION in a dev tree.
	@if [ -f VERSION ]; then \
		for p in $(PACKAGES); do \
			install -m 644 VERSION $(BUILD_DIR)/$(REL_DATADIR)/$$p/version; \
		done; \
	fi
	@# stow refuses a non-existent target, so ensure $(PREFIX) exists for a
	@# fresh prefix (e.g. the SIT host-side install into a tmp HOME) — BUG-046.
	@mkdir -p $(PREFIX)
	@stow -d build -t $(PREFIX) $(PACKAGE)

uninstall:
	@command -v stow >/dev/null || { echo "stow not installed"; exit 1; }
	@stow -d build -t $(PREFIX) -D $(PACKAGE) || true

# Tests
check: check-unit check-vectors

check-unit:
	@if command -v bats >/dev/null 2>&1; then \
		bats tests/unit/*.bats; \
	else echo "bats not installed; skipping"; fi

check-vectors:
	@# FEAT-025: probe for external commands the .t files invoke. If
	# any are missing, skip cleanly with a clear message instead of
	# letting `prove` produce a wall of `command not found` and a
	# wrong exit code. Skipping with exit 0 is the contract documented
	# in skills/testing.md (a clean signal beats a noisy red).
	@missing=; \
	for cmd in base58 dc create-mnemonic mnemonic-to-seed; do \
		command -v $$cmd >/dev/null 2>&1 || missing="$$missing $$cmd"; \
	done; \
	if [ -n "$$missing" ]; then \
		echo "==> check-vectors: skipping (missing dependencies:$$missing)"; \
		echo "    see issues/feature/025-vendor-vector-test-dependencies.md or issues/feature/done/025-* once shipped"; \
		exit 0; \
	fi; \
	if [ -d tests/vectors ] && command -v prove >/dev/null 2>&1; then \
		d=$$(mktemp -d); \
		ln -s $$(pwd)/bin/bitcoin $$d/bitcoin; \
		for p in libexec/bitcoin/*; do \
			[ -e "$$p" ] && ln -s $$(pwd)/$$p $$d/$$(basename $$p); \
		done; \
		PATH=$$d:$$PATH prove tests/vectors/*.t; \
		rc=$$?; \
		rm -rf $$d; \
		exit $$rc; \
	else echo "prove or tests/vectors/ not present; skipping"; fi

# SIT runs inside podman. The lightning suites run against a clightning +
# bitcoind regtest container (built from the working tree); the bitcoin
# suites self-manage a bitcoind container via tests/sit/helpers.bash.
# Both are soft-skipped when podman is absent (cloud sandbox).
check-sit:
	@if ! command -v podman >/dev/null 2>&1; then \
		echo "podman not installed; soft-skipping SIT"; \
		exit 0; \
	fi
	@echo "==> building lightning-regtest"
	@podman build -t lightning-regtest -f tests/sit/podman/Dockerfile.regtest tests/sit
	@echo "==> building lightning-clightning (with the local working tree)"
	@podman build -t lightning-clightning -f tests/sit/podman/Dockerfile.clightning .
	@echo "==> running lightning bats suites inside the container"
	@# Mount the whole tests/sit tree (not just suites/) so each suite's
	@# `load ../helpers` resolves to /sit/helpers.bash — mounting suites/
	@# alone left the relative include dangling (BUG-038).
	@# Run the suites as the operator `alice` (whose lightningd the entrypoint
	@# brought up) with the regtest network exported — the daemon-lifecycle and
	@# channel/pay suites talk to alice's node directly (BUG-038 SIT harness).
	@# Wrap in `timeout` (if available) so a hung live-flow test fails the
	@# target fast instead of blocking CI indefinitely.
	@to=$$(command -v timeout || command -v gtimeout || true); \
	$${to:+$$to 900} podman run --rm \
		-v $(PWD)/tests/sit:/sit:ro \
		lightning-clightning \
		sudo -u alice -i env LIGHTNING_NETWORK=regtest LIGHTNING_NO_BOOTSTRAP=1 bash -lc 'export PATH=/usr/sbin:/sbin:$$PATH; bats /sit/suites/01_daemon_lifecycle.bats /sit/suites/02_channel_open_close.bats /sit/suites/03_invoice_pay_bolt11.bats /sit/suites/04_offer_pay_bolt12.bats /sit/suites/05_lnurl_flow.bats /sit/suites/06_address_create_pay.bats /sit/suites/07_wallet_account_ledger.bats /sit/suites/08_wallet_push_pull.bats /sit/suites/09_inbound_liquidity_lsps1.bats /sit/suites/10_wellknown_api.bats /sit/suites/11_walkthrough.bats /sit/suites/12_softdep_probe.bats /sit/suites/13_tower.bats /sit/suites/14_fee_forward.bats'
	@echo "==> running bitcoin host-side suites"
	@bats tests/sit/suites/*wallet* tests/sit/suites/*derive* tests/sit/suites/*send* tests/sit/suites/*psbt* tests/sit/suites/*push_pull* 2>/dev/null || true

check-pit:
	@if command -v podman >/dev/null 2>&1; then \
		if [ -d tests/pit ]; then \
			echo "==> PIT: see tests/pit/README.md"; \
		else echo "tests/pit/ not present; skipping"; fi; \
	else echo "podman not installed; soft-skipping PIT"; fi

# Composite gate used by .githooks/pre-push. Always runs unit;
# adds SIT and PIT when podman is available (desktop mode).
# See skills/testing.md for the full matrix.
check-pre-push:
	@.githooks/pre-push

check-all: check check-sit check-pit

# kcov coverage report. Wraps the bats suite in kcov to produce line
# coverage for the dispatchers + libexec plugins of every command.
# HTML lands at $(COVERAGE_DIR)/.
COVERAGE_DIR = $(BUILD_DIR)/coverage
coverage:
	@if ! command -v kcov >/dev/null 2>&1; then \
		echo "kcov not installed; build from source via:"; \
		echo "    git clone https://github.com/SimonKagstrom/kcov"; \
		echo "    cd kcov && mkdir build && cd build && cmake .. && make && sudo make install"; \
		exit 127; \
	fi
	@if ! command -v bats >/dev/null 2>&1; then \
		echo "bats not installed; sudo apt install bats"; exit 127; \
	fi
	@rm -rf $(COVERAGE_DIR)
	@mkdir -p $(COVERAGE_DIR)
	@kcov \
		--include-path=$(PWD)/bin/bitcoin,$(PWD)/bin/lightning,$(PWD)/libexec/bitcoin,$(PWD)/libexec/lightning \
		--exclude-path=$(PWD)/tests \
		$(COVERAGE_DIR) \
		bats tests/unit/*.bats >/dev/null
	@echo "==> coverage report at $(COVERAGE_DIR)/index.html"
	@if command -v jq >/dev/null; then \
		jq -r '.percent_covered' $(COVERAGE_DIR)/bats/coverage.json \
			| awk '{ printf "==> line coverage: %.1f%%\n", $$1 }'; \
	fi

lint: lint-cmd-names
	@if command -v shellcheck >/dev/null 2>&1; then \
		for p in $(PACKAGES); do \
			shellcheck -S warning $$(find libexec/$$p -type f 2>/dev/null) || true; \
		done; \
		shellcheck -S warning bin/* || true; \
	else echo "shellcheck not installed; skipping"; fi

# FEAT-032: catch the BUG-013/014/016 defect family — `command:<name>`
# invocations with no matching definition in the same file.
lint-cmd-names:
	@tools/lint-cmd-names

test: check

# Skills installation (FEAT-192, FEAT-048).
#
# Opt-in symlinks into the user's per-agent dirs, iff each dir
# already exists. Three agents, two layouts (per the rpk skill
# convention, https://github.com/nostra124/rpk):
#   - Claude  : dir  ~/.claude/skills/<name>          -> share/claude/skills/<name>
#   - Raven   : dir  ~/.raven/workspace/skills/<name> -> share/raven/skills/<name>
#   - opencode: file ~/.config/opencode/commands/<name>.md
#                                                     -> share/opencode/commands/<name>.md
# Claude and Raven point at the SKILL.md dir; opencode points at
# the single .md command file. `ln -sf` makes this idempotent.
install-skills-user:
	@for skill in .rpk/skills/*.md; do \
		[ -f "$$skill" ] || continue; \
		name=$$(basename "$$skill" .md); \
		if [ -d "$$HOME/.claude/skills" ]; then \
			ln -sf $(PREFIX)/share/claude/skills/$$name \
			    "$$HOME/.claude/skills/$$name"; \
		fi; \
		if [ -d "$$HOME/.raven/workspace/skills" ]; then \
			ln -sf $(PREFIX)/share/raven/skills/$$name \
			    "$$HOME/.raven/workspace/skills/$$name"; \
		fi; \
		if [ -d "$$HOME/.config/opencode/commands" ]; then \
			ln -sf $(PREFIX)/share/opencode/commands/$$name.md \
			    "$$HOME/.config/opencode/commands/$$name.md"; \
		fi; \
	done

uninstall-skills-user:
	@for skill in .rpk/skills/*.md; do \
		[ -f "$$skill" ] || continue; \
		name=$$(basename "$$skill" .md); \
		find $$HOME/.claude/skills $$HOME/.raven/workspace/skills \
		  -maxdepth 1 -name "$$name" -type l -delete 2>/dev/null || true; \
		find $$HOME/.config/opencode/commands \
		  -maxdepth 1 -name "$$name.md" -type l -delete 2>/dev/null || true; \
	done

# FEAT-196: drop the sudoers fragment that lets Apache (www-data) cross
# into the operator's account for the narrow `lightning api-*` verbs.
# Operator is read from $$LIGHTNING_OPERATOR (default $$USER). This target
# requires root and is explicitly NOT run by `make install`.
LIGHTNING_OPERATOR ?= $(USER)
install-apache-bridge:
	@if [ "$$(id -u)" != "0" ]; then \
		echo "install-apache-bridge: must be run as root"; exit 1; \
	fi
	@sed "s/alice/$(LIGHTNING_OPERATOR)/g" share/lightning/sudoers.d/lightning \
		> /etc/sudoers.d/lightning.tmp
	@visudo -c -f /etc/sudoers.d/lightning.tmp >/dev/null
	@chmod 0440 /etc/sudoers.d/lightning.tmp
	@mv /etc/sudoers.d/lightning.tmp /etc/sudoers.d/lightning
	@echo "install-apache-bridge: dropped /etc/sudoers.d/lightning"

uninstall-apache-bridge:
	@if [ "$$(id -u)" != "0" ]; then \
		echo "uninstall-apache-bridge: must be run as root"; exit 1; \
	fi
	@rm -f /etc/sudoers.d/lightning
	@echo "uninstall-apache-bridge: removed /etc/sudoers.d/lightning"

# Versioning (FEAT-194)
#
# VERSION (project root) is the source of truth read by every dispatcher
# and installed to $DATADIR/<cmd>/version. .rpk/versions is the
# per-release SHA ledger appended below. To bump, see skills/version.md.
package:
	@if [ -z "$(VERSION)" ]; then \
		echo "Usage: make package VERSION=x.y.z"; exit 1; \
	fi
	@grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$$' <<< "$(VERSION)" || { \
		echo "Invalid semver: $(VERSION)"; exit 1; }
	@printf '%s\t%s\n' "$(VERSION)" "$$(git rev-parse HEAD)" \
		>> .rpk/versions
	@echo "$(VERSION)" > VERSION
	@git add VERSION .rpk/versions
	@git commit -m "package $(VERSION)"
	@git tag "v$(VERSION)"

# Per FEAT-191's invariant: clean never touches installed files.
clean:
	@rm -rf build/
