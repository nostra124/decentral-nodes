# Makefile template for per-script repos (FEAT-191 autoconf umbrella).
#
# Substituted at `./configure` time:
#   @PREFIX@        install prefix (default $HOME/.local non-root,
#                   /usr/local root)
#   @BINDIR@        $PREFIX/bin
#   @LIBEXECDIR@    $PREFIX/libexec
#   @SYSCONFDIR@    $PREFIX/etc
#   @DATADIR@       $PREFIX/share
#   @MANDIR@        $PREFIX/share/man
#   @PACKAGE@       the package name (account / cluster / dht / …)

SHELL = /bin/bash

PACKAGE   = @PACKAGE@
PREFIX    = @PREFIX@
BINDIR    = @BINDIR@
LIBEXECDIR = @LIBEXECDIR@
SYSCONFDIR = @SYSCONFDIR@
DATADIR   = @DATADIR@
MANDIR    = @MANDIR@

BUILD_DIR = build/$(PACKAGE)

.PHONY: all install uninstall check check-unit check-vectors \
        check-sit check-pit check-pre-push check-all lint lint-cmd-names \
        test help package clean install-skills-user uninstall-skills-user

all: install

help:
	@echo "Targets: install, uninstall, check, lint,"
	@echo "         check-unit, check-vectors, check-sit, check-pit,"
	@echo "         check-pre-push, check-all,"
	@echo "         install-skills-user, uninstall-skills-user, package, clean"

# Stow-based install builds a tree mirroring $PREFIX layout under
# $(BUILD_DIR), then `stow -t $(PREFIX)` symlinks it. Symmetric
# uninstall via `stow -D`.
install:
	@command -v stow >/dev/null || { echo "stow not installed"; exit 1; }
	@mkdir -p $(BUILD_DIR)$(BINDIR) $(BUILD_DIR)$(LIBEXECDIR)/$(PACKAGE) \
	          $(BUILD_DIR)$(SYSCONFDIR)/bash_completion.d \
	          $(BUILD_DIR)$(MANDIR)/man1 \
	          $(BUILD_DIR)$(DATADIR)/doc/$(PACKAGE) \
	          $(BUILD_DIR)$(DATADIR)/$(PACKAGE)
	@cp -a bin/* $(BUILD_DIR)$(BINDIR)/
	# FEAT-006: install a `bitcoin.sh` symlink alongside the
	# binary so vector tests can `. bitcoin.sh` from PATH.
	# The source tree itself stays clean (no new file under bin/).
	@ln -sf $(PACKAGE) $(BUILD_DIR)$(BINDIR)/$(PACKAGE).sh
	@if [ -d libexec/$(PACKAGE) ]; then \
		cp -a libexec/$(PACKAGE)/* $(BUILD_DIR)$(LIBEXECDIR)/$(PACKAGE)/; \
	fi
	@if [ -d etc/bash_completion.d ]; then \
		cp -a etc/bash_completion.d/* \
		      $(BUILD_DIR)$(SYSCONFDIR)/bash_completion.d/; \
	fi
	@if [ -d share/man/man1 ]; then \
		cp -a share/man/man1/* $(BUILD_DIR)$(MANDIR)/man1/; \
	fi
	@if [ -d share/doc/$(PACKAGE) ]; then \
		cp -a share/doc/$(PACKAGE)/* \
		      $(BUILD_DIR)$(DATADIR)/doc/$(PACKAGE)/; \
	fi
	# share/$(PACKAGE)/* — runtime assets read at runtime by
	# plugins (bip39 wordlists, future descriptors templates, …)
	@if [ -d share/$(PACKAGE) ]; then \
		mkdir -p $(BUILD_DIR)$(DATADIR)/$(PACKAGE); \
		cp -a share/$(PACKAGE)/* \
		      $(BUILD_DIR)$(DATADIR)/$(PACKAGE)/; \
	fi
	# FEAT-019 / FEAT-048: agent skills, following the rpk skill
	# convention (https://github.com/nostra124/rpk, docs/PACKAGING.md).
	# Each skills/$(PACKAGE)-<name>/ ships its SKILL.md to BOTH
	# share/claude/skills/<name>/ and share/raven/skills/<name>/
	# (Claude and Raven consume the same SKILL.md — no Raven-specific
	# file) and its opencode.md to share/opencode/commands/<name>.md.
	# The `install-skills-user` target later symlinks these into the
	# user's per-agent dirs iff those dirs exist.
	@if ls -d skills/$(PACKAGE)-* >/dev/null 2>&1; then \
		for skill in skills/$(PACKAGE)-*; do \
			name=$$(basename $$skill); \
			if [ -f "$$skill/SKILL.md" ]; then \
				mkdir -p $(BUILD_DIR)$(DATADIR)/claude/skills/$$name; \
				install -m 644 "$$skill/SKILL.md" \
				    $(BUILD_DIR)$(DATADIR)/claude/skills/$$name/SKILL.md; \
				mkdir -p $(BUILD_DIR)$(DATADIR)/raven/skills/$$name; \
				install -m 644 "$$skill/SKILL.md" \
				    $(BUILD_DIR)$(DATADIR)/raven/skills/$$name/SKILL.md; \
			fi; \
			if [ -f "$$skill/opencode.md" ]; then \
				mkdir -p $(BUILD_DIR)$(DATADIR)/opencode/commands; \
				install -m 644 "$$skill/opencode.md" \
				    $(BUILD_DIR)$(DATADIR)/opencode/commands/$$name.md; \
			fi; \
		done; \
	fi
	# VERSION → $DATADIR/<pkg>/version : the runtime version
	# string the binary reads (FEAT-194). The binary's two-path
	# fallback resolves to this file when invoked as the installed
	# entry, and to ./VERSION when invoked from a dev tree.
	@if [ -f VERSION ]; then \
		install -m 644 VERSION $(BUILD_DIR)$(DATADIR)/$(PACKAGE)/version; \
	fi
	@stow -d build -t $(PREFIX) $(PACKAGE)

uninstall:
	@command -v stow >/dev/null || { echo "stow not installed"; exit 1; }
	@stow -d build -t $(PREFIX) -D $(PACKAGE) || true

# Tests
check: check-unit check-vectors

check-unit:
	@if command -v bats >/dev/null 2>&1; then \
		bats tests/unit/*.bats; \
	else echo "bats not installed; skipping"; fi

check-vectors:
	@# FEAT-025: probe for external commands the .t files invoke. If
	# any are missing, skip cleanly with a clear message instead of
	# letting `prove` produce a wall of `command not found` and a
	# wrong exit code. Skipping with exit 0 is the contract documented
	# in skills/testing.md (a clean signal beats a noisy red).
	@missing=; \
	for cmd in base58 dc create-mnemonic mnemonic-to-seed; do \
		command -v $$cmd >/dev/null 2>&1 || missing="$$missing $$cmd"; \
	done; \
	if [ -n "$$missing" ]; then \
		echo "==> check-vectors: skipping (missing dependencies:$$missing)"; \
		echo "    see issues/feature/025-vendor-vector-test-dependencies.md or issues/feature/done/025-* once shipped"; \
		exit 0; \
	fi; \
	if [ -d tests/vectors ] && command -v prove >/dev/null 2>&1; then \
		d=$$(mktemp -d); \
		ln -s $$(pwd)/bin/bitcoin $$d/bitcoin.sh; \
		ln -s $$(pwd)/bin/bitcoin $$d/bitcoin; \
		for p in libexec/$(PACKAGE)/*; do \
			[ -e "$$p" ] && ln -s $$(pwd)/$$p $$d/$$(basename $$p); \
		done; \
		PATH=$$d:$$PATH prove tests/vectors/*.t; \
		rc=$$?; \
		rm -rf $$d; \
		exit $$rc; \
	else echo "prove or tests/vectors/ not present; skipping"; fi

check-sit:
	@if command -v podman >/dev/null 2>&1; then \
		bats tests/sit/suites/; \
	else echo "podman not installed; soft-skipping SIT"; fi

check-pit:
	@if command -v podman >/dev/null 2>&1; then \
		if [ -d tests/pit ]; then \
			echo "==> PIT: see tests/pit/README.md"; \
		else echo "tests/pit/ not present; skipping"; fi; \
	else echo "podman not installed; soft-skipping PIT"; fi

# Composite gate used by .githooks/pre-push. Always runs unit;
# adds SIT and PIT when podman is available (desktop mode).
# See skills/testing.md for the full matrix.
check-pre-push:
	@.githooks/pre-push

check-all: check check-sit check-pit

lint: lint-cmd-names
	@if command -v shellcheck >/dev/null 2>&1; then \
		shellcheck -S warning bin/* $$(find libexec/$(PACKAGE) -type f 2>/dev/null); \
	else echo "shellcheck not installed; skipping"; fi

# FEAT-032: catch the BUG-013/014/016 defect family — `command:<name>`
# invocations with no matching definition in the same file.
lint-cmd-names:
	@tools/lint-cmd-names

test: check

# Skills installation (FEAT-192, FEAT-048).
#
# Opt-in symlinks into the user's per-agent dirs, iff each dir
# already exists. Three agents, two layouts (per the rpk skill
# convention, https://github.com/nostra124/rpk):
#   - Claude  : dir  ~/.claude/skills/<name>          -> share/claude/skills/<name>
#   - Raven   : dir  ~/.raven/workspace/skills/<name> -> share/raven/skills/<name>
#   - opencode: file ~/.config/opencode/commands/<name>.md
#                                                     -> share/opencode/commands/<name>.md
# Claude and Raven point at the SKILL.md dir; opencode points at
# the single .md command file. `ln -sf` makes this idempotent.
install-skills-user:
	@for skill in skills/$(PACKAGE)-*; do \
		[ -d "$$skill" ] || continue; \
		name=$$(basename $$skill); \
		if [ -d "$$HOME/.claude/skills" ] && [ -f "$$skill/SKILL.md" ]; then \
			ln -sf $(PREFIX)/share/claude/skills/$$name \
			    "$$HOME/.claude/skills/$$name"; \
		fi; \
		if [ -d "$$HOME/.raven/workspace/skills" ] && [ -f "$$skill/SKILL.md" ]; then \
			ln -sf $(PREFIX)/share/raven/skills/$$name \
			    "$$HOME/.raven/workspace/skills/$$name"; \
		fi; \
		if [ -d "$$HOME/.config/opencode/commands" ] && [ -f "$$skill/opencode.md" ]; then \
			ln -sf $(PREFIX)/share/opencode/commands/$$name.md \
			    "$$HOME/.config/opencode/commands/$$name.md"; \
		fi; \
	done

uninstall-skills-user:
	@for skill in skills/$(PACKAGE)-*; do \
		[ -d "$$skill" ] || continue; \
		name=$$(basename $$skill); \
		find $$HOME/.claude/skills $$HOME/.raven/workspace/skills \
		  -maxdepth 1 -name "$$name" -type l -delete 2>/dev/null || true; \
		find $$HOME/.config/opencode/commands \
		  -maxdepth 1 -name "$$name.md" -type l -delete 2>/dev/null || true; \
	done

# Versioning (FEAT-194)
#
# VERSION (project root) is the source of truth read by bin/bitcoin
# and installed to $DATADIR/<pkg>/version. .rpk/versions is the
# per-release SHA ledger appended below. To bump, see
# skills/version.md.
package:
	@if [ -z "$(VERSION)" ]; then \
		echo "Usage: make package VERSION=x.y.z"; exit 1; \
	fi
	@grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$$' <<< "$(VERSION)" || { \
		echo "Invalid semver: $(VERSION)"; exit 1; }
	@printf '%s\t%s\n' "$(VERSION)" "$$(git rev-parse HEAD)" \
		>> .rpk/versions
	@echo "$(VERSION)" > VERSION
	@git add VERSION .rpk/versions
	@git commit -m "package $(VERSION)"
	@git tag "v$(VERSION)"

# Per FEAT-191's invariant: clean never touches installed files.
clean:
	@rm -rf build/
