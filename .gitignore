# autoconf-generated (overwrites the committed Makefile when present)
Makefile

# Make build tree
build/

# Python bytecode for the FEAT-196 CGI scripts
__pycache__/
*.pyc

# Claude Code local runtime + per-user state (locks, local overrides).
# The shared SessionStart hook + settings are committed explicitly; the
# rest of .claude/ (per-user state) stays ignored.
.claude/*
!.claude/settings.json
!.claude/hooks
.claude/hooks/*
!.claude/hooks/session-start.sh
