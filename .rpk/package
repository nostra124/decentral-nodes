#!/bin/bash

function die() { echo "$@"; exit 100; }

PACKAGE=$(rpk identity)
VERSION=$1

# This one rpk package ships multiple commands. COMMANDS are the `-node`
# dispatcher names (matching bin/<cmd> + libexec/<cmd>/, BUG-058). Runtime
# data lives under a separate hardcoded namespace (share/bitcoin, …) copied
# wholesale below, independent of the command names. decentral-nodes is the
# rpk identity; lightning/fulcrum/monero/… all slot into this one package.
COMMANDS="bitcoin-node lightning-node fulcrum-node monero-node liquid-node stacks-node tor-node ipfs-node storj-node joinmarket-node i2pd-node forgejo-node webmin-node usermin-node"

test -z "$VERSION" && VERSION=$(rpk versions | tail -1)

COMMIT=$(rpk commit "$PACKAGE" "$VERSION")
test -z "$COMMIT" && die "version $VERSION has no commit hash"

TARGET=${2:-$(rpk bundle "$(rpk type)")/$PACKAGE-$VERSION}

BRANCH=$(git branch --show-current)
trap 'git checkout "$BRANCH" --force' EXIT

git config advice.detachedHead false
git checkout "$COMMIT" || die "failed to checkout $COMMIT"

# Generate install paths via configure, then install without the
# Makefile's internal stow (rpk handles stow).
./configure --prefix="$TARGET" || die "configure failed"

mkdir -p "$TARGET/bin" \
         "$TARGET/etc/bash_completion.d" \
         "$TARGET/share/man/man1"

cp -a bin/* "$TARGET/bin/"
# libexec verbs: one dir per command (the -node dirs).
for cmd in $COMMANDS; do
    if [ -d "libexec/$cmd" ]; then
        mkdir -p "$TARGET/libexec/$cmd"
        cp -a "libexec/$cmd/"* "$TARGET/libexec/$cmd/"
    fi
done
# Runtime data + docs: copy every share/ namespace as-is (the hardcoded
# project data namespaces, distinct from the -node command names; BUG-058).
for d in share/*/; do
    name=$(basename "$d")
    [ "$name" = man ] && continue
    cp -a "$d" "$TARGET/share/"
done
if [ -d etc/bash_completion.d ]; then
    cp -a etc/bash_completion.d/* "$TARGET/etc/bash_completion.d/"
fi
if [ -d share/man/man1 ]; then
    cp -a share/man/man1/* "$TARGET/share/man/man1/"
fi
if ls .rpk/skills/*.md >/dev/null 2>&1; then
    # rpk-native skills: one flat .rpk/skills/<name>.md per skill (BUG-040).
    # Claude and Raven consume the same file; opencode gets it as <name>.md.
    for skill in .rpk/skills/*.md; do
        [ -f "$skill" ] || continue
        name=$(basename "$skill" .md)
        mkdir -p "$TARGET/share/claude/skills/$name"
        install -m 644 "$skill" "$TARGET/share/claude/skills/$name/SKILL.md"
        mkdir -p "$TARGET/share/raven/skills/$name"
        install -m 644 "$skill" "$TARGET/share/raven/skills/$name/SKILL.md"
        mkdir -p "$TARGET/share/opencode/commands"
        install -m 644 "$skill" "$TARGET/share/opencode/commands/$name.md"
    done
fi
if [ -f VERSION ]; then
    for cmd in $COMMANDS; do
        install -D -m 644 VERSION "$TARGET/share/$cmd/version"
    done
fi

git checkout "$BRANCH" --force
