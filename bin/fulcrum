#!/usr/bin/env bash

############################################################################
# fulcrum — manage a Fulcrum Electrum server as a peer command to bitcoin.
#
# FEAT-055: this is the second top-level command shipped by the one
# `bitcoin` rpk package. The header below is the sanctioned per-script
# copy of the FEAT-001 dispatcher (CLAUDE.md §4/§5, no shared library):
# the libexec resolver is SELF-keyed, so it auto-resolves
# libexec/fulcrum/<verb> with no further wiring.
############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

# Per FEAT-194: VERSION read at runtime from VERSION at the repo root
# (dev tree) or $PREFIX/share/fulcrum/version (installed). One package,
# one version: this prints the same string as `bitcoin version`.
__d="$(cd "$(dirname "$0")" && pwd)"; __s="$(basename "$0")"
VERSION=$(cat "$__d/../VERSION" 2>/dev/null || cat "$__d/../share/$__s/version" 2>/dev/null || echo '1.0.0')
unset __d __s
SELF=$(basename "$0")

# Resolve $SELF_LIBEXEC (FEAT-001 libexec convention) — checks
# in order: env override, in-checkout sibling, user install,
# system install. Per-script copy (no shared lib per §4).
if [ -z "$SELF_LIBEXEC" ]; then
	for _d in \
		"$(cd "$(dirname "$0")/../libexec" 2>/dev/null && pwd)" \
		"$HOME/.local/libexec" \
		"/usr/local/libexec" \
		"/usr/libexec"; do
		[ -d "$_d/$SELF" ] && SELF_LIBEXEC="$_d" && break
	done
	unset _d
fi

die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $*" >&2
}

info() {
	if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$*\033[0m" >&2; fi
}

warn() {
	echo -e "$SELF: warn - \033[31;1;m$*\033[0m" >&2
}

# Log an error without exiting. See skills/logging.md.
error() {
	echo -e "$SELF: error - \033[31;1;m$*\033[0m" >&2
}

# checks if a certain function exists: eg. has command help
has() {
	local KIND=$1
	local NAME=$2
	type -t "$KIND:$NAME" | grep -q function
}

# We run getopts as early as possible so global flags are caught before
# the command dispatch at the end of the file.
while getopts "c:dqpt" flag; do
	if [ x"$1" = x'-q' ]; then SELF_QUIET=1; fi
	if [ x"$1" = x'-d' ]; then SELF_DEBUG=1; fi
	if [ x"$1" = x'-t' ]; then SELF_TEST=1; fi
	shift 1
done

# Read configuration and set defaults if anything's not set
: "${XDG_CONFIG_HOME:="$HOME/.config"}"
: "${XDG_CACHE_HOME:="$HOME/.cache"}"
: "${XDG_DATA_HOME:="$HOME/.local/var"}"
: "${XDG_SHARE_HOME:="$HOME/.local/share"}"

[ -n "$SELF_VERBOSE" ] && set -vx

_is_libexec() {
	local name="$1"
	[ -n "$SELF_LIBEXEC" ] && [ -x "$SELF_LIBEXEC/$SELF/$name" ]
}

command:help() {
	if [[ $# != 0 ]]; then
		if has command "$1" || _is_libexec "$1"; then
			if has help "$1"; then
				help:"$1"
				return 0
			else
				exec "$SELF_LIBEXEC/$SELF/$1" help
			fi
		else
			echo "'$1' is not a $SELF command"
			echo ""
			echo "please see '$SELF help'"
			exit 1
		fi
	else
		cat >&2 <<ENDHELP
usage: $SELF <options> <command> [<args>]

   options:
   -d                     Enable debug output
   -q                     Enable quiet mode

   $SELF manages a Fulcrum Electrum server that indexes the local
   bitcoind. It is a peer command to 'bitcoin' (one package, two
   commands) — Fulcrum is an independent daemon, not a wallet feature.

generic commands:
   help <command>          show detailed help for a command
   version                 print the version of $SELF
   modules                 list available libexec plugins

server lifecycle (FEAT-056):
   daemon                  install / enable / disable / start / stop /
                           monitor / space the Fulcrum service

configuration (FEAT-057):
   config                  list / get / set / unset / path / init fulcrum.conf
   cert                    generate the self-signed TLS cert+key

admin inspection (FEAT-058):
   info                    server version, synced height, client count
   sync                    sync progress vs the node tip
   stats                   raw server stats JSON
   clients                 list connected clients
   logs [-f]               tail the Fulcrum service journal

admin moderation (FEAT-060):
   peers                   list peers (addpeer / rmpeer to manage)
   ban / unban / banlist   client/IP ban management
   kick <id|ip>            disconnect a client
   loglevel <lvl>          set runtime verbosity (normal|debug|trace)

see '$SELF help <command>' for detailed usage of each command.
ENDHELP
	fi
}

help:version() {
	cat >&2 <<-ENDHELP
	usage: $SELF version

	  Print the $SELF version number. One package, one version — this
	  is the same string as 'bitcoin version'.
	ENDHELP
}

command:version() {
	echo "$VERSION"
}

command:modules() {
	[ -d "$SELF_LIBEXEC/$SELF" ] && (cd "$SELF_LIBEXEC/$SELF" && ls)
}

help:modules() {
	cat >&2 <<-ENDHELP
	usage: $SELF modules

	  List the libexec plugins available under libexec/$SELF/.
	ENDHELP
}

#------------------------------------------------------------------------------
# When sourced rather than executed, define the functions and return
# without dispatching (mirrors bin/bitcoin's source-mode guard).
[[ "${BASH_SOURCE[0]}" != "$0" ]] && return 0

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

#------------------------------------------------------------------------------
# Builtin command, else fall through to a libexec plugin.
if has command "$1"; then
	debug "executing command:$1 ${*:2}"
	command:"$1" "${@:2}"
	exit $?
elif test -x "$SELF_LIBEXEC/$SELF/$1"; then
	verb="$1"; shift
	exec "$SELF_LIBEXEC/$SELF/$verb" "$@"
else
	error "'$1' is not a $SELF command (see '$SELF help')"
	exit 1
fi
