# This file requires extended globs to be parsed
shopt -s extglob

# ---------------------------------------------------------------------------
# FEAT-010: wallet store as a git repository.
#
# A wallet is a per-name git repo at
# $XDG_DATA_HOME/bitcoin/wallets/<name>/ holding the *signing context*
# (config, descriptors, ledger). The seed phrase lives in `secret`, not
# here — `bitcoin wallet new` calls `secret put <name>/seed` with the
# generated BIP-39 mnemonic so the wallet repo can be pushed (FEAT-011)
# without leaking the seed.
# ---------------------------------------------------------------------------

wallet:_root() {
	echo "${XDG_DATA_HOME:-$HOME/.local/var}/bitcoin/wallets"
}

wallet:_path() {
	echo "$(wallet:_root)/$1"
}

wallet:_valid_name() {
	[[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]]
}

# ---------------------------------------------------------------------------
# FEAT-009: BIP-380 descriptor checksum + verify.
#
# Per BIP-380 §Checksum: the descriptor body is expanded into 5-bit
# symbols against INPUT_CHARSET (95 chars, 3 groups of 32 + 31 with
# special-case packing), passed through a polymod with five 40-bit
# generator constants, and the resulting 40-bit checksum is rendered
# as 8 chars from CHECKSUM_CHARSET (the bech32 charset).
# ---------------------------------------------------------------------------

# INPUT_CHARSET — 95 chars. Position in string == symbol value.
declare -gr BIP380_INPUT_CHARSET=$'0123456789()[],\'/*abcdefgh@:$%{}IJKLMNOPQRSTUVWXYZ&+-.;<=>?!^_|~ijklmnopqrstuvwxyzABCDEFGH`#"\\ '

declare -gr BIP380_CHECKSUM_CHARSET="qpzry9x8gf2tvdw0s3jn54khce6mua7l"

descriptor:_polymod() {
	local -a generator=(0xf5dee51989 0xa9fdca3312 0x1bab10e32d 0x3706b1677a 0x644d626ffd)
	local -i chk=1 v top i
	for v; do
		(( top = chk >> 35,
		   chk = (chk & 0x7ffffffff) << 5 ^ v ))
		for i in 0 1 2 3 4; do
			(( ((top >> i) & 1) && (chk ^= generator[i]) )) || true
		done
	done
	echo $chk
}

descriptor:_expand() {
	local s="$1"
	local -ai groups=() symbols=()
	local -i i v idx j
	local c
	for ((i=0; i<${#s}; i++)); do
		c="${s:i:1}"
		idx=-1
		for ((j=0; j<${#BIP380_INPUT_CHARSET}; j++)); do
			if [[ "${BIP380_INPUT_CHARSET:j:1}" == "$c" ]]; then
				idx=$j
				break
			fi
		done
		(( idx < 0 )) && return 1
		v=$idx
		symbols+=( $(( v & 31 )) )
		groups+=( $(( v >> 5 )) )
		if (( ${#groups[@]} == 3 )); then
			symbols+=( $(( groups[0] * 9 + groups[1] * 3 + groups[2] )) )
			groups=()
		fi
	done
	if (( ${#groups[@]} == 1 )); then
		symbols+=( ${groups[0]} )
	elif (( ${#groups[@]} == 2 )); then
		symbols+=( $(( groups[0] * 3 + groups[1] )) )
	fi
	printf '%s\n' "${symbols[@]}"
}

descriptor:_create() {
	local body="$1"
	local -a expanded
	mapfile -t expanded < <(descriptor:_expand "$body") \
		|| { error "descriptor: invalid character in '$body'"; return 1; }
	if (( ${#expanded[@]} == 0 )) && [ -n "$body" ]; then
		error "descriptor: invalid character in '$body'"
		return 1
	fi
	local -i chk
	chk=$(descriptor:_polymod "${expanded[@]}" 0 0 0 0 0 0 0 0)
	(( chk ^= 1 ))
	local -i i val
	local out="$body#"
	for i in 0 1 2 3 4 5 6 7; do
		(( val = (chk >> (5 * (7 - i))) & 31 ))
		out+="${BIP380_CHECKSUM_CHARSET:val:1}"
	done
	printf '%s\n' "$out"
}

descriptor:checksum() {
	local s="${1:-}"
	[ -n "$s" ] || { error "descriptor checksum: argument required"; return 2; }
	# If the input already ends in `#<8 chars>`, strip and re-compute.
	if (( ${#s} > 9 )) && [[ "${s: -9: 1}" == "#" ]]; then
		s="${s:0: ${#s}-9}"
	fi
	descriptor:_create "$s"
}

descriptor:verify() {
	local s="${1:-}"
	[ -n "$s" ] || { error "descriptor verify: argument required"; return 2; }
	if (( ${#s} < 10 )) || [[ "${s: -9: 1}" != "#" ]]; then
		error "descriptor verify: no '#' separator + 8-char checksum suffix"
		return 3
	fi
	local body="${s:0: ${#s}-9}"
	local chksum="${s: -8}"
	local -i i j
	local c
	# Every checksum char must be in BIP380_CHECKSUM_CHARSET.
	for ((i=0; i<8; i++)); do
		c="${chksum:i:1}"
		case "$BIP380_CHECKSUM_CHARSET" in
			*"$c"*) ;;
			*) error "descriptor verify: checksum char '$c' not in bech32 set"; return 4 ;;
		esac
	done
	local -a expanded
	mapfile -t expanded < <(descriptor:_expand "$body") \
		|| { error "descriptor verify: invalid character in body"; return 5; }
	local -ai cksym=()
	for ((i=0; i<8; i++)); do
		c="${chksum:i:1}"
		for ((j=0; j<32; j++)); do
			if [[ "${BIP380_CHECKSUM_CHARSET:j:1}" == "$c" ]]; then
				cksym+=( $j )
				break
			fi
		done
	done
	local -i chk
	chk=$(descriptor:_polymod "${expanded[@]}" "${cksym[@]}")
	if (( chk == 1 )); then
		return 0
	else
		error "descriptor verify: checksum mismatch (got polymod=$chk, expected 1)"
		return 6
	fi
}

descriptor:help() {
	cat <<-ENDHELP
	Usage: $SELF descriptor <subcommand> [args]

	  checksum <s>      append a BIP-380 checksum to the descriptor body;
	                    if <s> already ends in '#<8 chars>', replace it
	  verify <s>        verify a descriptor's checksum; exit 0 on success
	  help              this message

	BIP-380 §Checksum defines an 8-character polymod-based suffix after
	a '#' separator: descriptor body, '#', 8 bech32-charset chars.
	ENDHELP
}

help:descriptor() {
	descriptor:help
	cite 380 "Output script descriptors (general)"
	cite 381 "Non-segwit output script descriptors"
	cite 386 "tr() output script descriptor"
}

command:descriptor() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		checksum) descriptor:checksum "$@" ;;
		verify)   descriptor:verify   "$@" ;;
		help)     descriptor:help ;;
		*)
			error "unknown descriptor subcommand: '$sub'"
			descriptor:help >&2
			return 2
			;;
	esac
}

# ---------------------------------------------------------------------------
# FEAT-012: backend abstraction. A thin verb layer dispatches to one
# of three implementations (mempool.space REST shipped here;
# bitcoind RPC and blockstream.info REST are scaffolded as stubs and
# tracked in a follow-up FEAT once we have something to test them
# against in this sandbox).
#
# Active backend resolution: $BITCOIN_BACKEND env var, then the
# config file at $XDG_CONFIG_HOME/bitcoin/backend, then 'mempool'.
# ---------------------------------------------------------------------------

backend:_config_file() {
	echo "${XDG_CONFIG_HOME:-$HOME/.config}/bitcoin/backend"
}

backend:_active() {
	if [ -n "${BITCOIN_BACKEND:-}" ]; then
		echo "$BITCOIN_BACKEND"
		return
	fi
	local cfg; cfg="$(backend:_config_file)"
	if [ -f "$cfg" ]; then
		cat "$cfg"
	else
		echo mempool
	fi
}

backend:_valid() {
	case "$1" in
		mempool|bitcoind|blockstream) return 0 ;;
		*) return 1 ;;
	esac
}

backend:set() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "backend set: name required (mempool|bitcoind|blockstream)"
		return 2
	fi
	if ! backend:_valid "$name"; then
		error "backend set: unknown backend '$name' (use mempool, bitcoind, or blockstream)"
		return 3
	fi
	local cfg; cfg="$(backend:_config_file)"
	mkdir -p "$(dirname "$cfg")" || { error "backend set: cannot mkdir $(dirname "$cfg")"; return 4; }
	echo "$name" > "$cfg"
	info "backend set to: $name"
}

backend:auto() {
	if command -v bitcoin-cli >/dev/null 2>&1 \
	   && bitcoin-cli getblockcount >/dev/null 2>&1; then
		backend:set bitcoind
	else
		warn "bitcoin-cli not reachable; falling back to mempool.space (chain state is trusted to a third party)"
		backend:set mempool
	fi
}

# --- verbs --------------------------------------------------------------------

backend:chain-height() {
	local b; b="$(backend:_active)"
	backend:"$b":chain-height
}

backend:get-address-utxos() {
	local b; b="$(backend:_active)"
	backend:"$b":get-address-utxos "$@"
}

backend:broadcast() {
	local b; b="$(backend:_active)"
	backend:"$b":broadcast "$@"
}

backend:estimate-fee() {
	local b; b="$(backend:_active)"
	backend:"$b":estimate-fee "$@"
}

# --- mempool.space implementation --------------------------------------------

: "${BITCOIN_MEMPOOL_URL:=https://mempool.space}"

backend:mempool:chain-height() {
	local url="$BITCOIN_MEMPOOL_URL/api/blocks/tip/height"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

backend:mempool:get-address-utxos() {
	local addr="${1:-}"
	if [ -z "$addr" ]; then
		error "backend get-address-utxos: address required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/address/$addr/utxo"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

backend:mempool:broadcast() {
	local hex="${1:-}"
	if [ -z "$hex" ]; then
		error "backend broadcast: tx hex required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/tx"
	local out
	if ! out="$(curl -sfL -X POST --data "$hex" "$url")"; then
		error "mempool: POST $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

# Mempool only publishes a fixed set of fee buckets via
# /api/v1/fees/recommended; the <target-blocks> arg picks which one.
# Anything outside the buckets is clamped to the nearest neighbour
# rather than rejected — callers asking for "5 blocks" get the
# 6-block estimate, not an error.
backend:mempool:estimate-fee() {
	local target="${1:-3}"
	if [[ ! "$target" =~ ^[0-9]+$ ]]; then
		error "backend estimate-fee: target must be a non-negative integer (got '$target')"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/v1/fees/recommended"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	local field
	if   (( target <= 1   )); then field=fastestFee
	elif (( target <= 3   )); then field=halfHourFee
	elif (( target <= 6   )); then field=hourFee
	elif (( target <= 144 )); then field=economyFee
	else                            field=minimumFee
	fi
	local rate
	rate="$(printf '%s' "$out" | jq -r ".$field // empty" 2>/dev/null)"
	if [[ ! "$rate" =~ ^[0-9]+$ ]]; then
		error "mempool: estimate-fee response missing or non-integer field '$field' (got '$rate')"
		return 3
	fi
	printf '%s\n' "$rate"
}

# --- bitcoind / blockstream stubs --------------------------------------------
#
# Scaffolded so `bitcoin backend set bitcoind|blockstream` doesn't
# break the dispatcher; verbs return "not implemented" with a clear
# error. Filling these out is FEAT-NNN follow-up.

backend:bitcoind:chain-height() {
	error "backend bitcoind: not implemented in this release (use mempool)"
	return 99
}
backend:bitcoind:get-address-utxos() { backend:bitcoind:chain-height; }
backend:bitcoind:broadcast()         { backend:bitcoind:chain-height; }
backend:bitcoind:estimate-fee()      { backend:bitcoind:chain-height; }

backend:blockstream:chain-height() {
	error "backend blockstream: not implemented in this release (use mempool)"
	return 99
}
backend:blockstream:get-address-utxos() { backend:blockstream:chain-height; }
backend:blockstream:broadcast()         { backend:blockstream:chain-height; }
backend:blockstream:estimate-fee()      { backend:blockstream:chain-height; }

# --- dispatcher --------------------------------------------------------------

command:backend() {
	local action="${1:-view}"
	shift 2>/dev/null || true
	case "$action" in
		view|"")
			backend:_active ;;
		set)
			backend:set "$@" ;;
		auto)
			backend:auto ;;
		mempool|bitcoind|blockstream)
			# Shorthand: `bitcoin backend mempool` = `backend set mempool`
			backend:set "$action" ;;
		chain-height|get-address-utxos|broadcast|estimate-fee)
			backend:"$action" "$@" ;;
		help)
			backend:help ;;
		*)
			error "unknown backend action: '$action'"
			backend:help >&2
			return 2
			;;
	esac
}

backend:help() {
	cat <<-ENDHELP
	Usage: $SELF backend [<action> [args]]

	  view (default)            print the active backend
	  set <name>                set active backend (mempool|bitcoind|blockstream)
	  auto                      pick bitcoind if reachable, else mempool
	  <name>                    shorthand for 'set <name>'

	  chain-height              current chain tip height (integer)
	  get-address-utxos <addr>  UTXOs at <addr> as backend-native JSON
	  broadcast <hex>           POST a raw tx; print the txid
	  estimate-fee [<blocks>]   sat/vB recommended for confirmation in
	                            <blocks> (default 3). Mempool buckets:
	                            1 (fastest), 3 (half-hour), 6 (hour),
	                            144 (economy), else (minimum).

	Active backend in this shell:
	  BITCOIN_BACKEND env var, then $(backend:_config_file), then 'mempool'.

	Only the mempool.space implementation ships in this release.
	bitcoind and blockstream are scaffolded; calling their verbs
	returns a clear "not implemented" error.
	ENDHELP
}

help:backend() {
	backend:help
}

# ---------------------------------------------------------------------------
# FEAT-008 (partial): psbt decode.
#
# Reads a PSBT from stdin (hex format), validates the BIP-174 magic +
# separator, and walks the wire format emitting one line per
# key-value record:
#
#     section=<n>  type=<hex>  key=<hex>  value=<hex>
#
# Section starts at 0 (global) and increments at each 0x00 separator.
# Per-section interpretation (global vs input[i] vs output[j]) is the
# caller's job; we just walk and report.
#
# encode + sign land in ROADMAP-1.8.0.
# ---------------------------------------------------------------------------

# psbt:_take <n> — read 2*n hex chars at $psbt_pos; advance.
# Returns 1 if not enough bytes left. Writes the hex into $PSBT_LAST_HEX
# (NOT stdout) so callers don't pay the fork-per-byte cost of
# command substitution. State (psbt_pos) survives because we don't
# subshell. Same convention for psbt:_take_varint which writes the
# parsed integer into $PSBT_LAST_VINT.
psbt:_take() {
	local n=$1
	local need=$(( n * 2 ))
	if (( psbt_pos + need > psbt_len )); then
		return 1
	fi
	PSBT_LAST_HEX="${psbt_hex:psbt_pos:need}"
	(( psbt_pos += need ))
}

psbt:_take_varint() {
	psbt:_take 1 || return 1
	local v=$((0x$PSBT_LAST_HEX))
	if (( v < 0xfd )); then
		PSBT_LAST_VINT=$v
	elif (( v == 0xfd )); then
		psbt:_take 1 || return 1; local lo=$PSBT_LAST_HEX
		psbt:_take 1 || return 1; local hi=$PSBT_LAST_HEX
		PSBT_LAST_VINT=$(( (0x$hi << 8) | 0x$lo ))
	elif (( v == 0xfe )); then
		psbt:_take 1 || return 1; local b0=$PSBT_LAST_HEX
		psbt:_take 1 || return 1; local b1=$PSBT_LAST_HEX
		psbt:_take 1 || return 1; local b2=$PSBT_LAST_HEX
		psbt:_take 1 || return 1; local b3=$PSBT_LAST_HEX
		PSBT_LAST_VINT=$(( (0x$b3 << 24) | (0x$b2 << 16) | (0x$b1 << 8) | 0x$b0 ))
	else
		error "psbt: varint > 4 bytes not supported (key/value can't exceed 2^32 bytes)"
		return 2
	fi
}

command:psbt() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		decode) psbt:decode "$@" ;;
		encode) psbt:encode "$@" ;;
		sign)   psbt:sign   "$@" ;;
		help)   psbt:help ;;
		*)
			error "unknown psbt subcommand: '$sub'"
			psbt:help >&2
			return 2
			;;
	esac
}

psbt:help() {
	cat <<-ENDHELP
	Usage: $SELF psbt <subcommand>

	  decode            read a PSBT (hex) from stdin and emit one line
	                    per key-value record:
	                      section=<n> type=<hex> key=<hex> value=<hex>
	  encode            read TSV records (decode's output shape) from
	                    stdin and emit a hex PSBT. Tracks section bumps
	                    and inserts 0x00 terminators between sections;
	                    one final 0x00 closes the last section. Empty
	                    trailing sections aren't representable — the
	                    encoded byte count equals (max section + 2)
	                    terminators.
	  sign <privkey>    read a PSBT (hex) from stdin, sign every v0 P2WPKH
	                    input whose WITNESS_UTXO scriptPubKey matches
	                    HASH160(pubkey of <privkey>), and re-emit the PSBT
	                    with PSBT_IN_PARTIAL_SIG records (BIP-174 type 0x02)
	                    inserted per signed input. <privkey> is a 32-byte
	                    hex secret key. SIGHASH_ALL only; ECDSA via openssl
	                    pkeyutl over secp256k1; signatures are BIP-66 low-S
	                    canonicalised.
	  help              this message
	ENDHELP
}

help:psbt() {
	psbt:help
	cite 174 "Partially Signed Bitcoin Transactions"
}

psbt:decode() {
	# Slurp stdin, normalise to lower-case hex.
	local raw; raw="$(cat | tr -d '[:space:]' | tr A-F a-f)"
	if [ -z "$raw" ]; then
		error "psbt decode: empty input (expected hex-encoded PSBT on stdin)"
		return 2
	fi
	if [[ ! "$raw" =~ ^[0-9a-f]+$ ]]; then
		error "psbt decode: input is not hex"
		return 3
	fi
	if (( ${#raw} % 2 != 0 )); then
		error "psbt decode: hex length is odd (${#raw} chars); truncated input?"
		return 4
	fi

	# Globals used by psbt:_take* helpers in the same shell (no subshells).
	psbt_hex="$raw"
	local -gi psbt_len=${#psbt_hex} psbt_pos=0
	PSBT_LAST_HEX=""
	PSBT_LAST_VINT=0

	psbt:_take 5 || { error "psbt decode: input shorter than 5 bytes (no magic)"; return 5; }
	if [[ "$PSBT_LAST_HEX" != "70736274ff" ]]; then
		error "psbt decode: bad magic '$PSBT_LAST_HEX' (expected '70736274ff' per BIP-174 §Specification)"
		return 6
	fi

	local -i section=0 keylen vallen
	local key type val
	while (( psbt_pos < psbt_len )); do
		if ! psbt:_take_varint; then
			error "psbt decode: truncated keylen varint at byte offset $((psbt_pos/2))"
			return 7
		fi
		keylen=$PSBT_LAST_VINT
		if (( keylen == 0 )); then
			(( section++ ))
			continue
		fi
		if ! psbt:_take "$keylen"; then
			error "psbt decode: truncated key (need $keylen bytes) at offset $((psbt_pos/2))"
			return 8
		fi
		key="$PSBT_LAST_HEX"
		type="${key:0:2}"
		if ! psbt:_take_varint; then
			error "psbt decode: truncated value-length varint at offset $((psbt_pos/2))"
			return 9
		fi
		vallen=$PSBT_LAST_VINT
		if ! psbt:_take "$vallen"; then
			error "psbt decode: truncated value (need $vallen bytes) at offset $((psbt_pos/2))"
			return 10
		fi
		val="$PSBT_LAST_HEX"
		printf 'section=%d\ttype=%s\tkey=%s\tvalue=%s\n' "$section" "$type" "$key" "$val"
	done
}

# psbt:_emit_varint <n> — print the BIP-174 compact-size varint for
# n as lowercase hex (no newline). Errors on n > 2^32.
psbt:_emit_varint() {
	local -i n=$1
	if (( n < 0xfd )); then
		printf '%02x' "$n"
	elif (( n <= 0xffff )); then
		printf 'fd%02x%02x' $((n & 0xff)) $(((n >> 8) & 0xff))
	elif (( n <= 0xffffffff )); then
		printf 'fe%02x%02x%02x%02x' \
			$((n & 0xff)) $(((n >> 8) & 0xff)) \
			$(((n >> 16) & 0xff)) $(((n >> 24) & 0xff))
	else
		error "psbt encode: varint > 2^32 not supported"
		return 1
	fi
}

psbt:encode() {
	local -i cur_section=0
	local out="70736274ff"   # magic + separator
	local line f_sec f_type f_key f_val sec key val
	local -i sec_i

	while IFS=$'\t' read -r f_sec f_type f_key f_val; do
		# Skip blank lines.
		[ -z "$f_sec$f_type$f_key$f_val" ] && continue
		# Each field is "name=value".
		sec="${f_sec#section=}"
		key="${f_key#key=}"
		val="${f_val#value=}"
		if [[ ! "$sec" =~ ^[0-9]+$ ]]; then
			error "psbt encode: malformed section field '$f_sec'"
			return 2
		fi
		sec_i=$sec
		if (( sec_i < cur_section )); then
			error "psbt encode: section field went backwards ($cur_section → $sec_i)"
			return 3
		fi
		# Emit 0x00 terminators to skip ahead to the right section.
		while (( cur_section < sec_i )); do
			out+="00"
			(( cur_section++ ))
		done
		if [[ ! "$key" =~ ^[0-9a-fA-F]*$ ]]; then
			error "psbt encode: non-hex key '$key' at section $sec_i"
			return 4
		fi
		if [[ ! "$val" =~ ^[0-9a-fA-F]*$ ]]; then
			error "psbt encode: non-hex value at section $sec_i (len=${#val})"
			return 5
		fi
		if (( ${#key} % 2 != 0 )) || (( ${#val} % 2 != 0 )); then
			error "psbt encode: odd-length hex at section $sec_i"
			return 6
		fi
		out+="$(psbt:_emit_varint $((${#key} / 2)))"
		out+="${key,,}"
		out+="$(psbt:_emit_varint $((${#val} / 2)))"
		out+="${val,,}"
	done
	# One final 0x00 closes the last section.
	out+="00"
	printf '%s\n' "$out"
}

# ---------------------------------------------------------------------------
# FEAT-008 (partial, 1.13.0): psbt sign.
#
# Reads a PSBT (hex) from stdin and a raw 32-byte private key from
# argv. For every input whose WITNESS_UTXO scriptPubKey is v0 P2WPKH
# of HASH160(pubkey), computes the BIP-143 sighash, ECDSA-signs via
# openssl, BIP-66 low-S canonicalises the DER signature, and inserts
# a PSBT_IN_PARTIAL_SIG record (type 0x02) into the input map. Other
# inputs (wrong scriptPubKey, non-P2WPKH, missing WITNESS_UTXO) are
# passed through unmodified. The re-emitted PSBT is printed as hex.
#
# SIGHASH_ALL only. P2WPKH only. RFC 6979 deterministic-k is NOT
# implemented (openssl uses random k), so signatures vary run-to-run.
# Tests verify the structural invariant (sig + sighash verify against
# the pubkey) rather than pinning a byte sequence.
# ---------------------------------------------------------------------------

# secp256k1 group order n and n/2, used for BIP-66 low-S
# canonicalisation. Decimals because dc reads decimals natively.
declare -gr PSBT_SECP256K1_N='115792089237316195423570985008687907852837564279074904382605163141518161494337'
declare -gr PSBT_SECP256K1_N_HALF='57896044618658097711785492504343953926418782139537452191302581570759080747168'

# Pack a 32-byte private key hex into a minimal-DER ECPrivateKey,
# write it to $1. Caller is responsible for cleanup. We omit the
# optional [1] pubkey field — openssl computes the pubkey on demand.
psbt:_write_privkey_der() {
	local out="$1" key_hex="$2"
	{
		printf '302e020101'         # SEQUENCE(46) / INTEGER 1
		printf '0420'               # OCTET STRING(32)
		printf '%s' "$key_hex"
		printf 'a00706052b8104000a' # [0] OID 1.3.132.0.10 (secp256k1)
	} | xxd -r -p > "$out"
}

# Print the compressed-form pubkey hex (33 bytes / 66 chars) for the
# given 32-byte private key hex. Returns non-zero if openssl rejects
# the key (e.g. zero or out-of-range).
psbt:_privkey_to_pubkey() {
	local key_hex="$1"
	local der; der="$(mktemp)"
	psbt:_write_privkey_der "$der" "$key_hex"
	# openssl pkey -text prints the uncompressed (0x04|X|Y) point.
	# Extract X and Y, then build the compressed form (02|X if Y even,
	# 03|X if Y odd).
	local text point x y_last
	if ! text="$(openssl pkey -inform DER -in "$der" -text -noout 2>/dev/null)"; then
		rm -f "$der"
		return 1
	fi
	rm -f "$der"
	# Extract the pub: block. openssl wraps it across lines:
	#   pub:
	#       04:79:be:66:...:d4:b8
	point="$(printf '%s\n' "$text" \
		| awk '/^pub:/{flag=1; next} /^ASN1 OID/{flag=0} flag {print}' \
		| tr -d ' :\n' )"
	# Strip the leading "04" prefix, take 64 chars X and 64 chars Y.
	if (( ${#point} != 130 )); then
		return 2
	fi
	if [[ "${point:0:2}" != "04" ]]; then
		return 3
	fi
	x="${point:2:64}"
	y_last="${point:128:2}"
	local -i y_last_int=$((16#$y_last))
	local prefix
	if (( y_last_int & 1 )); then prefix="03"; else prefix="02"; fi
	printf '%s%s\n' "$prefix" "$x"
}

# Hash160(stdin-hex). Pipe-friendly: takes hex on stdin, prints hex
# on stdout. Uses openssl (we already depend on >= 3.0).
psbt:_hash160_hex() {
	local hex; read -r hex
	printf '%s' "$hex" \
		| xxd -r -p \
		| openssl dgst -sha256 -binary \
		| openssl dgst -rmd160 -binary \
		| xxd -p -c 0 \
		| tr -d '\n'
	printf '\n'
}

# Double-SHA-256 of input hex. Pipe-friendly like _hash160_hex.
psbt:_sha256d_hex() {
	local hex; read -r hex
	printf '%s' "$hex" \
		| xxd -r -p \
		| openssl dgst -sha256 -binary \
		| openssl dgst -sha256 -binary \
		| xxd -p -c 0 \
		| tr -d '\n'
	printf '\n'
}

# BIP-66 low-S canonicalisation. Input: DER ECDSA signature hex.
# If the s component is > n/2, replace it with n - s and re-encode.
# Re-emits canonical DER signature hex.
#
# DER layout: 30 <total-len> 02 <r-len> <r-bytes> 02 <s-len> <s-bytes>
# All length bytes are single-byte (signatures are well under 128 B).
#
# dc wraps long-integer output across lines with a backslash + newline
# continuation; every dc invocation here is filtered through `tr` to
# strip that so the next dc call doesn't see a stray '\'.
psbt:_low_s_canon() {
	local sig="$1"
	if [[ ! "$sig" =~ ^30[[:xdigit:]]{2}02[[:xdigit:]]{2} ]]; then
		error "psbt sign: malformed DER signature header in '$sig'"
		return 1
	fi
	local r_len_hex="${sig:6:2}"
	local -i r_len=$((16#$r_len_hex))
	local r_start=8
	local s_marker_off=$((r_start + r_len * 2))
	if [[ "${sig:s_marker_off:2}" != "02" ]]; then
		error "psbt sign: expected s INTEGER marker at offset $s_marker_off in '$sig'"
		return 2
	fi
	local s_len_hex="${sig:s_marker_off+2:2}"
	local -i s_len=$((16#$s_len_hex))
	local s_start=$((s_marker_off + 4))
	local s="${sig:s_start:s_len*2}"
	local s_decimal
	s_decimal="$(echo "16i ${s^^} p" | dc | tr -d '\\\n')" || return 3
	local cmp
	cmp="$(echo "$PSBT_SECP256K1_N_HALF $s_decimal - p" | dc | tr -d '\\\n')"
	# If (n/2 - s) is negative, s > n/2 and we must flip to n - s.
	if [[ "$cmp" == -* ]]; then
		local new_s_dec; new_s_dec="$(echo "$PSBT_SECP256K1_N $s_decimal - p" | dc | tr -d '\\\n')"
		local new_s_hex; new_s_hex="$(echo "16o $new_s_dec p" | dc | tr -d '\\\n' | tr 'A-F' 'a-f')"
		# Even-pad. DER signed-int leading-zero rule: prepend 00 if
		# high bit of first byte is set.
		if (( ${#new_s_hex} % 2 == 1 )); then new_s_hex="0$new_s_hex"; fi
		local first_byte=$((16#${new_s_hex:0:2}))
		if (( first_byte & 0x80 )); then new_s_hex="00$new_s_hex"; fi
		local new_s_len_hex; new_s_len_hex="$(printf '%02x' $(( ${#new_s_hex} / 2 )))"
		local prefix="${sig:0:s_marker_off+2}"
		local new_sig="${prefix}${new_s_len_hex}${new_s_hex}"
		local -i new_total=$(( (${#new_sig} - 4) / 2 ))
		local new_total_hex; new_total_hex="$(printf '%02x' "$new_total")"
		new_sig="30${new_total_hex}${new_sig:4}"
		printf '%s' "$new_sig"
	else
		printf '%s' "$sig"
	fi
}

# Sign a 32-byte sighash with a private key. Output: low-S
# canonicalised DER signature hex (no SIGHASH byte appended; caller
# adds that).
psbt:_sign_sighash() {
	local key_hex="$1" sighash_hex="$2"
	local der_key; der_key="$(mktemp)"
	local hash_bin; hash_bin="$(mktemp)"
	local sig_bin;  sig_bin="$(mktemp)"
	psbt:_write_privkey_der "$der_key" "$key_hex"
	printf '%s' "$sighash_hex" | xxd -r -p > "$hash_bin"
	if ! openssl pkeyutl -sign -inkey "$der_key" -keyform DER -in "$hash_bin" -out "$sig_bin" 2>/dev/null; then
		rm -f "$der_key" "$hash_bin" "$sig_bin"
		error "psbt sign: openssl pkeyutl -sign failed for key '${key_hex:0:8}…'"
		return 1
	fi
	local sig_hex; sig_hex="$(xxd -p -c 0 "$sig_bin" | tr -d '\n')"
	rm -f "$der_key" "$hash_bin" "$sig_bin"
	psbt:_low_s_canon "$sig_hex"
}

# Compute the BIP-143 sighash for a v0 segwit input.
# Args:
#   $1 unsigned-tx hex
#   $2 input index (0-based)
#   $3 scriptCode hex (for P2WPKH, this is 1976a914<hash160>88ac)
#   $4 amount LE 8-byte hex
#   $5 sighash type (default 01 = SIGHASH_ALL)
# Output: 32-byte sighash hex.
psbt:_bip143_sighash() {
	local tx="$1" idx="$2" script_code="$3" amount_le="$4" sighash_type="${5:-01}"

	# Parse the unsigned tx via the existing _take helpers. They use
	# the globals psbt_hex / psbt_pos / psbt_len; save and restore so
	# we don't clobber an in-flight decode/sign.
	local saved_hex="${psbt_hex:-}" saved_pos="${psbt_pos:-0}" saved_len="${psbt_len:-0}"
	psbt_hex="$tx"
	local -gi psbt_len=${#psbt_hex} psbt_pos=0
	PSBT_LAST_HEX=""
	PSBT_LAST_VINT=0

	# version (4 B LE)
	psbt:_take 4 || { error "psbt sign: truncated version in unsigned tx"; return 1; }
	local nVersion_le="$PSBT_LAST_HEX"

	# inputs
	psbt:_take_varint || { error "psbt sign: truncated input count"; return 1; }
	local -i n_in=$PSBT_LAST_VINT
	local prevouts="" sequences=""
	local target_outpoint="" target_sequence=""
	local k
	for ((k=0; k<n_in; k++)); do
		psbt:_take 32 || { error "psbt sign: truncated prev_txid at input $k"; return 1; }
		local prev_txid="$PSBT_LAST_HEX"
		psbt:_take 4 || { error "psbt sign: truncated prev_vout at input $k"; return 1; }
		local prev_vout="$PSBT_LAST_HEX"
		prevouts+="$prev_txid$prev_vout"
		psbt:_take_varint || { error "psbt sign: truncated scriptSig length at input $k"; return 1; }
		local -i ss_len=$PSBT_LAST_VINT
		psbt:_take "$ss_len" || { error "psbt sign: truncated scriptSig at input $k"; return 1; }
		psbt:_take 4 || { error "psbt sign: truncated sequence at input $k"; return 1; }
		local seq="$PSBT_LAST_HEX"
		sequences+="$seq"
		if (( k == idx )); then
			target_outpoint="$prev_txid$prev_vout"
			target_sequence="$seq"
		fi
	done

	# outputs
	psbt:_take_varint || { error "psbt sign: truncated output count"; return 1; }
	local -i n_out=$PSBT_LAST_VINT
	local outputs=""
	for ((k=0; k<n_out; k++)); do
		psbt:_take 8 || { error "psbt sign: truncated output value at $k"; return 1; }
		outputs+="$PSBT_LAST_HEX"
		psbt:_take_varint || { error "psbt sign: truncated script length at output $k"; return 1; }
		local -i sp_len=$PSBT_LAST_VINT
		outputs+="$(psbt:_emit_varint "$sp_len")"
		psbt:_take "$sp_len" || { error "psbt sign: truncated scriptPubKey at output $k"; return 1; }
		outputs+="$PSBT_LAST_HEX"
	done

	# locktime
	psbt:_take 4 || { error "psbt sign: truncated locktime"; return 1; }
	local nLocktime_le="$PSBT_LAST_HEX"

	# Restore the global parser state.
	psbt_hex="$saved_hex"; psbt_pos=$saved_pos; psbt_len=$saved_len

	if [ -z "$target_outpoint" ]; then
		error "psbt sign: input index $idx out of range (tx has $n_in inputs)"
		return 1
	fi

	local hashPrevouts; hashPrevouts="$(printf '%s' "$prevouts"  | psbt:_sha256d_hex)"
	local hashSequence; hashSequence="$(printf '%s' "$sequences" | psbt:_sha256d_hex)"
	local hashOutputs;  hashOutputs="$(printf '%s' "$outputs"    | psbt:_sha256d_hex)"

	local sighash_type_le4; sighash_type_le4="$(wallet:_le32 "$((16#$sighash_type))")"

	local preimage=""
	preimage+="$nVersion_le"
	preimage+="$hashPrevouts"
	preimage+="$hashSequence"
	preimage+="$target_outpoint"
	preimage+="$(psbt:_emit_varint $(( ${#script_code} / 2 )))"
	preimage+="$script_code"
	preimage+="$amount_le"
	preimage+="$target_sequence"
	preimage+="$hashOutputs"
	preimage+="$nLocktime_le"
	preimage+="$sighash_type_le4"

	printf '%s' "$preimage" | psbt:_sha256d_hex
}

# Parse a PSBT into structured per-input records. Populates the
# parallel globals PSBT_PARSE_INPUT_RECORDS[i] (record blob without
# the terminator) and PSBT_PARSE_OUTPUT_RECORDS[j]. Also exports
# PSBT_PARSE_GLOBAL_RECORDS and PSBT_PARSE_UNSIGNED_TX.
#
# The "record blob" for a section is the concatenation of every
# keylen+key+vallen+value triple, with NO trailing 0x00 — that byte
# is added back at emit time.
psbt:_parse_structured() {
	psbt_hex="$1"
	local -gi psbt_len=${#psbt_hex} psbt_pos=0
	PSBT_LAST_HEX=""
	PSBT_LAST_VINT=0
	psbt:_take 5 || return 1
	if [[ "$PSBT_LAST_HEX" != "70736274ff" ]]; then
		error "psbt sign: bad magic '$PSBT_LAST_HEX' (expected '70736274ff')"
		return 2
	fi
	# Collect the global section, then per-input, per-output sections.
	# The unsigned-tx record sits in the global section as type 0x00.
	PSBT_PARSE_GLOBAL_RECORDS=""
	PSBT_PARSE_UNSIGNED_TX=""
	PSBT_PARSE_INPUT_RECORDS=()
	PSBT_PARSE_OUTPUT_RECORDS=()

	local -i section=0
	local cur_records=""
	while (( psbt_pos < psbt_len )); do
		psbt:_take_varint || { error "psbt sign: truncated keylen varint"; return 3; }
		local -i keylen=$PSBT_LAST_VINT
		if (( keylen == 0 )); then
			# Stash the just-closed section.
			case $section in
				0) PSBT_PARSE_GLOBAL_RECORDS="$cur_records" ;;
				*) ;;
			esac
			if (( section >= 1 )); then
				# This branch handles any section beyond the global.
				# We'll partition after the fact.
				:
			fi
			(( section++ ))
			cur_records=""
			continue
		fi
		psbt:_take "$keylen" || { error "psbt sign: truncated key"; return 4; }
		local key_hex="$PSBT_LAST_HEX"
		local type_byte="${key_hex:0:2}"
		psbt:_take_varint || { error "psbt sign: truncated vallen"; return 5; }
		local -i vallen=$PSBT_LAST_VINT
		psbt:_take "$vallen" || { error "psbt sign: truncated value"; return 6; }
		local val_hex="$PSBT_LAST_HEX"
		local rec=""
		rec+="$(psbt:_emit_varint "$keylen")"
		rec+="$key_hex"
		rec+="$(psbt:_emit_varint "$vallen")"
		rec+="$val_hex"
		cur_records+="$rec"
		if (( section == 0 )) && [[ "$type_byte" == "00" ]]; then
			PSBT_PARSE_UNSIGNED_TX="$val_hex"
		fi
	done
	# We accumulated everything into cur_records / GLOBAL_RECORDS but
	# never split per-input / per-output. Re-do the walk: this time,
	# count the number of inputs and outputs from the unsigned tx so
	# we know how to partition the post-global sections.
	if [ -z "$PSBT_PARSE_UNSIGNED_TX" ]; then
		error "psbt sign: PSBT has no PSBT_GLOBAL_UNSIGNED_TX record"
		return 7
	fi
	# Quick parse: input count is at offset 4 bytes (8 hex chars).
	local saved_hex="$psbt_hex" saved_len="$psbt_len" saved_pos="$psbt_pos"
	psbt_hex="$PSBT_PARSE_UNSIGNED_TX"
	psbt_len=${#psbt_hex}; psbt_pos=8
	psbt:_take_varint || { error "psbt sign: bad input count in unsigned tx"; return 8; }
	local -i n_in=$PSBT_LAST_VINT
	# Skip past the inputs to reach the output-count varint.
	local k
	for ((k=0; k<n_in; k++)); do
		psbt:_take 36 || return 9  # txid + vout
		psbt:_take_varint || return 9  # scriptSig len
		psbt:_take "$PSBT_LAST_VINT" || return 9
		psbt:_take 4 || return 9  # sequence
	done
	psbt:_take_varint || { error "psbt sign: bad output count in unsigned tx"; return 9; }
	local -i n_out=$PSBT_LAST_VINT
	psbt_hex="$saved_hex"; psbt_len=$saved_len; psbt_pos=$saved_pos

	# Re-walk the PSBT structure to collect per-input / per-output
	# blobs into the parallel arrays.
	psbt_pos=0
	psbt:_take 5 >/dev/null
	section=0
	cur_records=""
	while (( psbt_pos < psbt_len )); do
		psbt:_take_varint || return 10
		local -i keylen=$PSBT_LAST_VINT
		if (( keylen == 0 )); then
			if   (( section == 0 ));              then PSBT_PARSE_GLOBAL_RECORDS="$cur_records"
			elif (( section >= 1 && section <= n_in )); then PSBT_PARSE_INPUT_RECORDS[section-1]="$cur_records"
			elif (( section <= n_in + n_out ));   then PSBT_PARSE_OUTPUT_RECORDS[section-1-n_in]="$cur_records"
			fi
			(( section++ ))
			cur_records=""
			continue
		fi
		psbt:_take "$keylen" || return 11
		local key_hex="$PSBT_LAST_HEX"
		psbt:_take_varint || return 12
		local -i vallen=$PSBT_LAST_VINT
		psbt:_take "$vallen" || return 13
		local val_hex="$PSBT_LAST_HEX"
		cur_records+="$(psbt:_emit_varint "$keylen")$key_hex$(psbt:_emit_varint "$vallen")$val_hex"
	done
	# Pad arrays so every input/output has a (possibly empty) entry.
	while (( ${#PSBT_PARSE_INPUT_RECORDS[@]}  < n_in  )); do PSBT_PARSE_INPUT_RECORDS+=("");  done
	while (( ${#PSBT_PARSE_OUTPUT_RECORDS[@]} < n_out )); do PSBT_PARSE_OUTPUT_RECORDS+=(""); done
	PSBT_PARSE_N_IN=$n_in
	PSBT_PARSE_N_OUT=$n_out
}

# Walk an input's record blob and pull out the value for a given
# type byte (e.g. "01" for PSBT_IN_WITNESS_UTXO). Returns the
# value hex on stdout (empty if not present).
psbt:_input_record_value() {
	local blob="$1" wanted_type="$2"
	local -i pos=0 len=${#blob}
	local saved_hex="${psbt_hex:-}" saved_pos="${psbt_pos:-0}" saved_len="${psbt_len:-0}"
	psbt_hex="$blob"
	local -gi psbt_len=${#blob} psbt_pos=0
	PSBT_LAST_HEX=""
	PSBT_LAST_VINT=0
	local found=""
	while (( psbt_pos < psbt_len )); do
		psbt:_take_varint || break
		local -i keylen=$PSBT_LAST_VINT
		(( keylen == 0 )) && break
		psbt:_take "$keylen" || break
		local key_hex="$PSBT_LAST_HEX"
		local type_byte="${key_hex:0:2}"
		psbt:_take_varint || break
		local -i vallen=$PSBT_LAST_VINT
		psbt:_take "$vallen" || break
		if [[ "$type_byte" == "$wanted_type" ]]; then
			found="$PSBT_LAST_HEX"
			break
		fi
	done
	psbt_hex="$saved_hex"; psbt_pos=$saved_pos; psbt_len=$saved_len
	printf '%s' "$found"
}

psbt:sign() {
	local key_hex="${1:-}"
	if [ -z "$key_hex" ]; then
		error "psbt sign: usage: psbt sign <privkey-hex> (PSBT on stdin)"
		return 2
	fi
	key_hex="${key_hex,,}"
	if [[ ! "$key_hex" =~ ^[0-9a-f]{64}$ ]]; then
		error "psbt sign: <privkey-hex> must be 64 lowercase hex chars (32 bytes)"
		return 3
	fi

	local raw; raw="$(cat | tr -d '[:space:]' | tr A-F a-f)"
	if [ -z "$raw" ]; then
		error "psbt sign: empty stdin (expected hex-encoded PSBT)"
		return 4
	fi
	if [[ ! "$raw" =~ ^[0-9a-f]+$ ]]; then
		error "psbt sign: stdin is not hex"
		return 5
	fi

	local pubkey; pubkey="$(psbt:_privkey_to_pubkey "$key_hex")" || {
		error "psbt sign: could not derive pubkey from private key"
		return 6
	}
	local pubkey_hash; pubkey_hash="$(printf '%s' "$pubkey" | psbt:_hash160_hex)"
	local expected_script="0014${pubkey_hash}"

	# Parse the PSBT into per-section blobs.
	psbt:_parse_structured "$raw" || return 7

	local -i n_in=$PSBT_PARSE_N_IN n_out=$PSBT_PARSE_N_OUT
	local tx="$PSBT_PARSE_UNSIGNED_TX"

	local -i i
	for ((i=0; i<n_in; i++)); do
		local blob="${PSBT_PARSE_INPUT_RECORDS[i]}"
		local wu; wu="$(psbt:_input_record_value "$blob" "01")"
		if [ -z "$wu" ]; then
			# No WITNESS_UTXO record — can't sign without it.
			continue
		fi
		# wu = 8-byte LE value + varint scriptlen + scriptPubKey.
		local amount_le="${wu:0:16}"
		# Decode the varint after the 16-char amount.
		local rest="${wu:16}"
		local -i v0=$((16#${rest:0:2}))
		local script_start=2 script_len_bytes
		if   (( v0 < 0xfd )); then script_len_bytes=$v0
		elif (( v0 == 0xfd )); then
			local lo="${rest:2:2}" hi="${rest:4:2}"
			script_len_bytes=$(( (16#$hi << 8) | 16#$lo ))
			script_start=6
		else
			error "psbt sign: WITNESS_UTXO with very long scriptPubKey unsupported"
			continue
		fi
		local script="${rest:script_start:script_len_bytes*2}"
		if [[ "$script" != "$expected_script" ]]; then
			# Not signable by this key.
			continue
		fi
		# scriptCode for P2WPKH per BIP-143: 1976a914 <20-byte hash> 88ac
		local script_code="1976a914${pubkey_hash}88ac"
		local sighash; sighash="$(psbt:_bip143_sighash "$tx" "$i" "$script_code" "$amount_le" 01)" || return 8
		local sig; sig="$(psbt:_sign_sighash "$key_hex" "$sighash")" || return 9
		# Append SIGHASH_ALL byte.
		sig+="01"
		# Insert PSBT_IN_PARTIAL_SIG record: keylen + (0x02 + pubkey) + vallen + (sig+sighash)
		# key field = 0x02 (type) || compressed pubkey (33 B) = 34 bytes
		local key_field="02${pubkey}"
		local -i key_len=$(( ${#key_field} / 2 ))
		local -i val_len=$(( ${#sig} / 2 ))
		local new_record=""
		new_record+="$(psbt:_emit_varint "$key_len")"
		new_record+="$key_field"
		new_record+="$(psbt:_emit_varint "$val_len")"
		new_record+="$sig"
		PSBT_PARSE_INPUT_RECORDS[i]+="$new_record"
	done

	# Re-emit the PSBT.
	local out="70736274ff"
	out+="$PSBT_PARSE_GLOBAL_RECORDS"
	out+="00"
	for ((i=0; i<n_in; i++)); do
		out+="${PSBT_PARSE_INPUT_RECORDS[i]}"
		out+="00"
	done
	local j
	for ((j=0; j<n_out; j++)); do
		out+="${PSBT_PARSE_OUTPUT_RECORDS[j]}"
		out+="00"
	done
	printf '%s\n' "$out"
}

command:wallet() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		new|ls|rm|help|derive|addresses|label|balance|broadcast|build|remote|push|pull) wallet:"$sub" "$@" ;;
		*)
			error "unknown wallet subcommand: '$sub'"
			wallet:help >&2
			return 2
			;;
	esac
}

help:wallet() {
	wallet:help
	cite 39 "Mnemonic seed phrases"
}

wallet:help() {
	cat <<-ENDHELP
	Usage: $SELF wallet <subcommand> [args]

	  new <name>        create a new wallet at $(wallet:_root)/<name>
	                    generates a BIP-39 mnemonic and stores it via
	                    'secret put <name>/seed'
	  ls                list existing wallets
	  rm [-f] <name>    remove a wallet (-f also removes secret/<name>/seed)
	  derive <name>     derive next BIP-84 receive address; append to ledger
	  addresses <name>  list every derived address (with index + label)
	  label <name> <addr> <text>
	                    set/clear the label on a derived address
	  balance <name>    sum UTXO values for all derived addresses via the
	                    active backend (skills/automerging.md §3b -- mempool)
	  build <name> <addr> <sats> [--fee-rate sat/vB]
	                    greedy-select wallet UTXOs, build an unsigned tx that
	                    pays <sats> to <addr>, wrap as a PSBT, print as hex.
	                    Without --fee-rate, reads 'backend estimate-fee 3';
	                    falls back to 1 sat/vB on backend failure.
	                    P2WPKH/P2WSH outputs only.
	  broadcast <name>  POST raw-tx hex from stdin to the active backend
	  remote add <name> <remote> <url>
	                    set/replace a git remote on the wallet repo
	  push <name> [<remote>]
	                    git push the wallet (default remote: origin)
	  pull <name> [<remote>]
	                    git pull --rebase the wallet (default remote: origin)
	  help              this message

	A wallet is a git repository. The seed phrase is held by 'secret',
	not by this repo, so 'bitcoin wallet push' (FEAT-011) is safe by
	construction.
	ENDHELP
}

# ---------------------------------------------------------------------------
# FEAT-013 helpers
# ---------------------------------------------------------------------------

# Read the next derivation index from the ledger (0-based; line count).
wallet:_next_index() {
	local ledger="$1"
	if [ -s "$ledger" ]; then
		wc -l < "$ledger" | tr -d ' '
	else
		echo 0
	fi
}

# Derive the BIP-84 receive address at <name>'s index <i> via the
# mnemonic in secret. Returns just the bc1q… address on stdout.
wallet:_derive_address() {
	local name="$1" idx="$2"
	if ! command -v secret >/dev/null 2>&1; then
		error "wallet derive: 'secret' not in PATH (cannot read seed)"
		return 5
	fi
	# Resolve libexec for the bip32/bip13/mnemonic-to-seed plugins.
	# When sourced, SELF_LIBEXEC must be set by caller; when dispatched,
	# the parent bin/bitcoin sets it.
	local libexec="${SELF_LIBEXEC:?wallet derive: SELF_LIBEXEC must be set}"
	local pubkey
	pubkey="$(
		secret get "$name/seed" |
		"$libexec/${SELF:-bitcoin}/mnemonic-to-seed" |
		"$libexec/${SELF:-bitcoin}/bip32" create 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip13" base58-decode 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip32" derive "m/84h/0h/0h/0/$idx/N" 2>/dev/null |
		tail -c 33 |
		basenc --base16 -w0 |
		tr A-F a-f
	)"
	if [[ ! "$pubkey" =~ ^0[23][[:xdigit:]]{64}$ ]]; then
		error "wallet derive: pubkey derivation produced unexpected output '$pubkey'"
		return 6
	fi
	p2wpkh "$pubkey"
}

wallet:derive() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet derive: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet derive: no such wallet '$name' at $path"
		return 3
	fi
	local ledger="$path/addresses"
	[ -f "$ledger" ] || : > "$ledger"
	local idx; idx="$(wallet:_next_index "$ledger")"
	local addr; addr="$(wallet:_derive_address "$name" "$idx")" || return $?
	# Append as: <index><tab><address><tab><label>  (label initially empty)
	printf '%d\t%s\t\n' "$idx" "$addr" >> "$ledger"
	(
		cd "$path"
		git add addresses
		# commit.gpgsign=false: wallet-internal commits run on the
		# user's wallet repo, not on this project's repo. We don't
		# assume the user has signing keys set up for their wallet.
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			commit -q -m "wallet derive: $name/$idx -> $addr"
	) || { error "wallet derive: commit failed"; return 7; }
	printf '%s\n' "$addr"
}

wallet:addresses() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet addresses: name required"
		return 2
	fi
	local ledger; ledger="$(wallet:_path "$name")/addresses"
	if [ ! -f "$ledger" ]; then
		error "wallet addresses: no ledger at $ledger"
		return 3
	fi
	cat "$ledger"
}

wallet:label() {
	local name="${1:-}" addr="${2:-}" label="${3:-}"
	if [ -z "$name" ] || [ -z "$addr" ]; then
		error "wallet label: usage: wallet label <name> <address> <label>"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	local ledger="$path/addresses"
	if [ ! -f "$ledger" ]; then
		error "wallet label: no ledger at $ledger"
		return 3
	fi
	if ! grep -q -F "	$addr	" "$ledger"; then
		error "wallet label: address '$addr' not in $name's ledger"
		return 4
	fi
	# Rewrite the line: <idx>\t<addr>\t<label>\n
	local tmp="$ledger.tmp"
	awk -v a="$addr" -v l="$label" -F '\t' 'BEGIN{OFS="\t"} {
		if ($2 == a) print $1, $2, l;
		else        print $0;
	}' "$ledger" > "$tmp" && mv "$tmp" "$ledger"
	(
		cd "$path"
		git add addresses
		# commit.gpgsign=false: wallet-internal commits run on the
		# user's wallet repo, not on this project's repo. We don't
		# assume the user has signing keys set up for their wallet.
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			commit -q -m "wallet label: $name $addr -> '$label'"
	) || { error "wallet label: commit failed"; return 5; }
	info "label set for $addr"
}

# FEAT-014 (partial, 1.8.0): wallet broadcast. Reads a raw hex
# transaction from stdin and forwards to the active backend. The
# <name> argument is currently a docs hint — per-wallet backend
# resolution is deferred until FEAT-012's per-wallet config lands.
wallet:broadcast() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet broadcast: name required (currently a docs hint; per-wallet backend deferred)"
		return 2
	fi
	local hex
	hex="$(cat | tr -d '[:space:]')"
	if [ -z "$hex" ]; then
		error "wallet broadcast: empty stdin (expected raw transaction hex)"
		return 3
	fi
	if [[ ! "$hex" =~ ^[0-9a-fA-F]+$ ]]; then
		error "wallet broadcast: stdin is not hex"
		return 4
	fi
	if (( ${#hex} % 2 != 0 )); then
		error "wallet broadcast: hex length is odd (${#hex} chars); truncated input?"
		return 5
	fi
	# Normalise to lowercase.
	hex="${hex,,}"
	backend:broadcast "$hex"
}

# ---------------------------------------------------------------------------
# FEAT-014 (partial, 1.11.0): wallet build. Walk the addresses ledger,
# query the active backend for UTXOs at each, greedy-select (largest
# first) until input total covers <sats> + estimated fee, serialise a
# BIP-141 unsigned tx, wrap in a single-record PSBT and print as hex.
#
# Signing and end-to-end send remain deferred to ROADMAP-1.12.0+.
# ---------------------------------------------------------------------------

# Reverse a hex string byte-by-byte. Used for little-endian txid + vout
# serialisation in the raw tx body.
wallet:_reverse_hex() {
	local hex="$1"
	local out="" i
	for ((i=${#hex}-2; i>=0; i-=2)); do
		out+="${hex:i:2}"
	done
	printf '%s' "$out"
}

# Encode a non-negative integer as 4-byte little-endian hex.
wallet:_le32() {
	local -i n=$1
	printf '%02x%02x%02x%02x' \
		$((n & 0xff)) \
		$(((n >> 8) & 0xff)) \
		$(((n >> 16) & 0xff)) \
		$(((n >> 24) & 0xff))
}

# Encode a non-negative integer as 8-byte little-endian hex. Bitcoin
# satoshi values fit in 51 bits (21M * 1e8) so 63-bit bash arithmetic
# is sufficient — no need for arbitrary-precision shells here.
wallet:_le64() {
	local -i n=$1
	printf '%02x%02x%02x%02x%02x%02x%02x%02x' \
		$((n & 0xff)) \
		$(((n >> 8) & 0xff)) \
		$(((n >> 16) & 0xff)) \
		$(((n >> 24) & 0xff)) \
		$(((n >> 32) & 0xff)) \
		$(((n >> 40) & 0xff)) \
		$(((n >> 48) & 0xff)) \
		$(((n >> 56) & 0xff))
}

# Convert a v0 segwit bech32 address (bc1q.../tb1q...) to its
# scriptPubKey hex (00 <len> <program>). Returns non-zero on a bad
# checksum, wrong HRP, non-v0 witness version, or wrong program length.
# v1+ (P2TR / bech32m) is intentionally rejected here; signing those
# outputs is FEAT-007, not ROADMAP-1.11.0.
wallet:_address_to_script() {
	local addr="$1"
	if [ -z "$addr" ]; then
		return 1
	fi
	local out
	if ! out="$(command:bech32-decode "$addr" 2>/dev/null)"; then
		# Fall through to bech32m so we can emit a clearer "v1+ not
		# supported" error rather than a cryptic checksum failure.
		if ! out="$(command:bech32-decode -m "$addr" 2>/dev/null)"; then
			return 2
		fi
	fi
	local -a lines
	mapfile -t lines <<< "$out"
	if (( ${#lines[@]} < 3 )); then
		return 3
	fi
	local hrp="${lines[0]}" version="${lines[1]}"
	if [[ ! "$hrp" =~ ^(bc|tb)$ ]]; then
		return 4
	fi
	if [[ ! "$version" =~ ^[0-9]+$ ]]; then
		return 5
	fi
	if (( version != 0 )); then
		return 6
	fi
	local prog_decimals
	if ! prog_decimals="$(
		for ((i=2; i<${#lines[@]}; i++)); do echo "${lines[i]}"; done | convertbits 5 8 0
	)"; then
		return 7
	fi
	local prog="" b
	for b in $prog_decimals; do
		prog+="$(printf '%02x' "$b")"
	done
	local -i prog_len=$(( ${#prog} / 2 ))
	if (( prog_len != 20 && prog_len != 32 )); then
		return 8
	fi
	printf '00%02x%s' "$prog_len" "$prog"
}

wallet:build() {
	local name="" addr="" sats=""
	local -i fee_rate=0 fee_rate_set=0
	while [ $# -gt 0 ]; do
		case "${1:-}" in
			--fee-rate)
				if [ -z "${2:-}" ]; then
					error "wallet build: --fee-rate requires an argument"
					return 2
				fi
				if [[ ! "$2" =~ ^[0-9]+$ ]]; then
					error "wallet build: --fee-rate must be a positive integer (sat/vB), got '$2'"
					return 2
				fi
				fee_rate="$2"
				fee_rate_set=1
				shift 2
				;;
			--) shift; break ;;
			-*)
				error "wallet build: unknown flag '$1'"
				return 2
				;;
			*)
				if [ -z "$name" ]; then name="$1"
				elif [ -z "$addr" ]; then addr="$1"
				elif [ -z "$sats" ]; then sats="$1"
				else
					error "wallet build: too many positional arguments (saw '$1')"
					return 2
				fi
				shift
				;;
		esac
	done
	if [ -z "$name" ] || [ -z "$addr" ] || [ -z "$sats" ]; then
		error "wallet build: usage: wallet build <name> <addr> <sats> [--fee-rate sat/vB]"
		return 2
	fi
	if [[ ! "$sats" =~ ^[1-9][0-9]*$ ]]; then
		error "wallet build: <sats> must be a positive integer, got '$sats'"
		return 3
	fi
	# If --fee-rate wasn't supplied, ask the active backend for a
	# half-hour estimate (FEAT-012 estimate-fee, 1.12.0). On any
	# failure — backend unreachable, non-integer reply, stub backend
	# returning "not implemented" — fall back to 1 sat/vB with a
	# `warn` so the user knows their default is the floor.
	if (( ! fee_rate_set )); then
		local est
		if est="$(backend:estimate-fee 3 2>/dev/null)" && [[ "$est" =~ ^[1-9][0-9]*$ ]]; then
			fee_rate=$est
		else
			warn "wallet build: backend estimate-fee unavailable; falling back to 1 sat/vB"
			fee_rate=1
		fi
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet build: no such wallet '$name' at $path"
		return 4
	fi
	local ledger="$path/addresses"
	if [ ! -s "$ledger" ]; then
		error "wallet build: wallet '$name' has no derived addresses (run 'wallet derive')"
		return 5
	fi

	local out_script
	if ! out_script="$(wallet:_address_to_script "$addr")"; then
		error "wallet build: invalid output address '$addr' (only v0 P2WPKH/P2WSH supported in this release)"
		return 6
	fi

	# Collect UTXOs from every address in the wallet's ledger. The
	# backend returns a JSON array per address; we flatten via jq.
	# Per-UTXO `addr` is tracked so the signer (FEAT-008 psbt sign,
	# 1.13.0) can compute the input's scriptPubKey from the address.
	local -a utxos_txid=() utxos_vout=() utxos_value=() utxos_addr=()
	local _idx addr_ledger _label utxo_json txid vout value
	while IFS=$'\t' read -r _idx addr_ledger _label; do
		[ -z "$addr_ledger" ] && continue
		if ! utxo_json="$(backend:get-address-utxos "$addr_ledger" 2>/dev/null)"; then
			warn "wallet build: backend get-utxos failed for $addr_ledger (continuing)"
			continue
		fi
		while IFS=$'\t' read -r txid vout value; do
			[ -z "$txid" ] && continue
			utxos_txid+=( "$txid" )
			utxos_vout+=( "$vout" )
			utxos_value+=( "$value" )
			utxos_addr+=( "$addr_ledger" )
		done < <(printf '%s' "$utxo_json" | jq -r '.[] | [.txid, .vout, .value] | @tsv' 2>/dev/null)
	done < "$ledger"

	if (( ${#utxos_txid[@]} == 0 )); then
		error "wallet build: no UTXOs available for wallet '$name'"
		return 7
	fi

	# Sort UTXO indexes by value descending (largest-first selection).
	local -a order
	mapfile -t order < <(
		local i
		for ((i=0; i<${#utxos_value[@]}; i++)); do
			printf '%d\t%s\n' "${utxos_value[i]}" "$i"
		done | sort -k1,1 -nr | cut -f2
	)

	# Greedy-select. Fee estimate assumes P2WPKH inputs (~68 vbytes
	# each, post-segwit-discount) and 2 outputs (~31 vbytes each) +
	# 10 vbytes of overhead — conservative so we don't fall short
	# when change is added. This is the educational simple-fee model;
	# RBF / branch-and-bound coin selection are out of scope.
	local -a sel=()
	local -i selected_total=0 n_in=0 fee_estimate=0 needed=$sats ix
	for ix in "${order[@]}"; do
		sel+=( "$ix" )
		(( selected_total += utxos_value[ix] ))
		(( n_in++ ))
		(( fee_estimate = (10 + 68 * n_in + 31 * 2) * fee_rate ))
		(( needed = sats + fee_estimate ))
		(( selected_total >= needed )) && break
	done
	if (( selected_total < needed )); then
		error "wallet build: insufficient balance: have $selected_total sats, need $needed (sats=$sats, fee~$fee_estimate at $fee_rate sat/vB)"
		return 8
	fi

	# Change handling. Dust threshold for P2WPKH is ~294 sats at 3
	# sat/vB; we use 546 (the legacy P2PKH dust limit) as a generous
	# floor — anything smaller gets folded into the fee instead.
	local -i dust=546 change=0 n_out=1
	local change_script=""
	(( change = selected_total - sats - fee_estimate ))
	if (( change > dust )); then
		local change_addr
		if ! change_addr="$(wallet:derive "$name" 2>/dev/null)"; then
			error "wallet build: failed to derive change address for '$name'"
			return 9
		fi
		# wallet derive may emit other lines (info etc. go to stderr,
		# but be defensive); take the last line as the address.
		change_addr="$(printf '%s\n' "$change_addr" | tail -n1)"
		if ! change_script="$(wallet:_address_to_script "$change_addr")"; then
			error "wallet build: failed to compute change scriptPubKey for '$change_addr'"
			return 10
		fi
		n_out=2
	fi

	# --- serialise the BIP-141 unsigned transaction -----------------
	local raw_tx=""
	raw_tx+="02000000"                              # version (4 B LE)
	raw_tx+="$(psbt:_emit_varint "$n_in")"          # input count
	for ix in "${sel[@]}"; do
		txid="${utxos_txid[ix]}"
		vout="${utxos_vout[ix]}"
		raw_tx+="$(wallet:_reverse_hex "$txid")"    # 32-B prev_txid (LE)
		raw_tx+="$(wallet:_le32 "$vout")"           #  4-B prev_vout (LE)
		raw_tx+="00"                                # empty scriptSig
		raw_tx+="feffffff"                          # sequence 0xfffffffe (RBF off, locktime on)
	done
	raw_tx+="$(psbt:_emit_varint "$n_out")"         # output count
	raw_tx+="$(wallet:_le64 "$sats")"               # recipient value
	raw_tx+="$(psbt:_emit_varint $(( ${#out_script} / 2 )))"
	raw_tx+="$out_script"
	if (( n_out == 2 )); then
		raw_tx+="$(wallet:_le64 "$change")"
		raw_tx+="$(psbt:_emit_varint $(( ${#change_script} / 2 )))"
		raw_tx+="$change_script"
	fi
	raw_tx+="00000000"                              # locktime

	# --- wrap as a PSBT ---------------------------------------------
	# Magic + global UNSIGNED_TX record + section terminator, then per
	# input map a PSBT_IN_WITNESS_UTXO record (type 0x01) carrying the
	# prev-output's amount (8 B LE) + varint-prefixed scriptPubKey,
	# followed by an end-of-section 0x00 byte. Output maps are empty.
	# The PSBT_IN_WITNESS_UTXO record was added in 1.13.0 so that
	# `psbt sign` (FEAT-008 partial) has everything BIP-143 sighash
	# needs without re-fetching from the backend.
	local psbt="70736274ff"
	psbt+="01"                                      # global keylen=1
	psbt+="00"                                      # key = PSBT_GLOBAL_UNSIGNED_TX
	psbt+="$(psbt:_emit_varint $(( ${#raw_tx} / 2 )))"
	psbt+="$raw_tx"
	psbt+="00"                                      # close global
	local i utxo_script utxo_record
	for ((i=0; i<n_in; i++)); do
		ix="${sel[i]}"
		# scriptPubKey for the input's source address (same v0
		# P2WPKH/P2WSH we accept on the output side).
		if ! utxo_script="$(wallet:_address_to_script "${utxos_addr[ix]}")"; then
			error "wallet build: failed to encode scriptPubKey for input address '${utxos_addr[ix]}'"
			return 11
		fi
		utxo_record="$(wallet:_le64 "${utxos_value[ix]}")"
		utxo_record+="$(psbt:_emit_varint $(( ${#utxo_script} / 2 )))"
		utxo_record+="$utxo_script"
		psbt+="01"                                  # keylen=1
		psbt+="01"                                  # key = PSBT_IN_WITNESS_UTXO
		psbt+="$(psbt:_emit_varint $(( ${#utxo_record} / 2 )))"
		psbt+="$utxo_record"
		psbt+="00"                                  # close input map
	done
	for ((i=0; i<n_out; i++)); do psbt+="00"; done  # empty output maps

	printf '%s\n' "$psbt"
}

# ---------------------------------------------------------------------------
# FEAT-011 (partial, 1.9.0): wallet remote / push / pull. Thin
# wrappers around git's own remote machinery so a wallet repo can move
# between machines (the cold-storage flow). The original FEAT-011 spec
# routes through `account` to resolve SSH endpoints — that's deferred;
# the URL is taken directly here. The custom merge resolvers
# (addresses-union, psbts-last-writer-wins, descriptors-conflict-as-
# error) are also deferred.
# ---------------------------------------------------------------------------

wallet:remote() {
	local action="${1:-}"
	shift 2>/dev/null || true
	if [ "$action" != "add" ]; then
		error "wallet remote: only 'add' is supported in this release (sub-actions deferred)"
		return 2
	fi
	local name="${1:-}" rname="${2:-}" url="${3:-}"
	if [ -z "$name" ] || [ -z "$rname" ] || [ -z "$url" ]; then
		error "wallet remote add: usage: wallet remote add <wallet> <remote-name> <url>"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path/.git" ]; then
		error "wallet remote add: no such wallet '$name' at $path"
		return 3
	fi
	(
		cd "$path"
		# Replace existing remote with the new URL idempotently.
		if git remote get-url "$rname" >/dev/null 2>&1; then
			git remote set-url "$rname" "$url"
		else
			git remote add "$rname" "$url"
		fi
	) || { error "wallet remote add: git remote configuration failed"; return 4; }
	info "wallet '$name' remote '$rname' -> $url"
}

wallet:push() {
	local name="${1:-}" rname="${2:-origin}"
	if [ -z "$name" ]; then
		error "wallet push: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path/.git" ]; then
		error "wallet push: no such wallet '$name' at $path"
		return 3
	fi
	if ! ( cd "$path" && git remote get-url "$rname" >/dev/null 2>&1 ); then
		error "wallet push: '$name' has no '$rname' remote configured (use 'wallet remote add')"
		return 4
	fi
	(
		cd "$path"
		local branch
		branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || branch=main
		git push -q "$rname" "$branch"
	) || { error "wallet push: git push failed"; return 5; }
	info "wallet '$name' pushed to '$rname'"
}

wallet:pull() {
	local name="${1:-}" rname="${2:-origin}"
	if [ -z "$name" ]; then
		error "wallet pull: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path/.git" ]; then
		error "wallet pull: no such wallet '$name' at $path"
		return 3
	fi
	if ! ( cd "$path" && git remote get-url "$rname" >/dev/null 2>&1 ); then
		error "wallet pull: '$name' has no '$rname' remote configured (use 'wallet remote add')"
		return 4
	fi
	(
		cd "$path"
		local branch
		branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || branch=main
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			pull --rebase -q "$rname" "$branch"
	) || { error "wallet pull: git pull failed"; return 5; }
	info "wallet '$name' pulled from '$rname'"
}

wallet:balance() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet balance: name required"
		return 2
	fi
	local ledger; ledger="$(wallet:_path "$name")/addresses"
	if [ ! -f "$ledger" ]; then
		error "wallet balance: no ledger at $ledger"
		return 3
	fi
	local -i total=0
	local addr utxo_json sum
	while IFS=$'\t' read -r _idx addr _label; do
		[ -z "$addr" ] && continue
		if ! utxo_json="$(backend:get-address-utxos "$addr")"; then
			warn "wallet balance: backend get-utxos failed for $addr (continuing)"
			continue
		fi
		# Sum the .value fields. jq is in .rpk/depends; available on CI.
		sum="$(printf '%s' "$utxo_json" | jq -r '[.[].value] | add // 0' 2>/dev/null)"
		if [[ "$sum" =~ ^[0-9]+$ ]]; then
			(( total += sum ))
		fi
	done < "$ledger"
	echo "$total"
}

wallet:new() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet new: name required"
		return 2
	fi
	if ! wallet:_valid_name "$name"; then
		error "wallet new: invalid name '$name' (must match [A-Za-z0-9][A-Za-z0-9_-]*)"
		return 3
	fi
	local path; path="$(wallet:_path "$name")"
	if [ -e "$path" ]; then
		error "wallet new: '$name' already exists at $path"
		return 4
	fi
	if ! command -v secret >/dev/null 2>&1; then
		error "wallet new: 'secret' not found in PATH (install nostra124/secret)"
		return 5
	fi
	if [ ! -x "$SELF_LIBEXEC/$SELF/bip39" ]; then
		error "wallet new: 'bip39' libexec plugin not found at $SELF_LIBEXEC/$SELF/bip39"
		return 6
	fi

	local mnemonic
	if ! mnemonic="$("$SELF_LIBEXEC/$SELF/bip39" create 256 2>/dev/null)"; then
		error "wallet new: bip39 create failed"
		return 7
	fi
	if [ -z "$mnemonic" ]; then
		error "wallet new: bip39 create produced empty mnemonic"
		return 8
	fi

	if ! printf '%s\n' "$mnemonic" | secret put "$name/seed"; then
		error "wallet new: 'secret put $name/seed' failed"
		return 9
	fi

	mkdir -p "$path" || { error "wallet new: mkdir $path failed"; return 10; }
	(
		cd "$path" || exit 1
		git init -q -b main || git init -q
		cat > config <<-CFG
		# bitcoin wallet '$name' — FEAT-010
		name=$name
		network=testnet
		CFG
		: > descriptors
		git add config descriptors
		# commit.gpgsign=false: wallet-internal commits run on the
		# user's wallet repo, not on this project's repo. We don't
		# assume the user has signing keys set up for their wallet.
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			commit -q -m "wallet new: $name"
	) || { error "wallet new: failed to initialise repo at $path"; return 11; }

	info "wallet '$name' created at $path"
}

wallet:ls() {
	local root; root="$(wallet:_root)"
	if [ ! -d "$root" ]; then
		return 0
	fi
	find "$root" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | sort
}

wallet:rm() {
	local force=0
	while [ $# -gt 0 ]; do
		case "${1:-}" in
			-f|--force) force=1; shift ;;
			--) shift; break ;;
			-*) error "wallet rm: unknown flag '$1'"; return 2 ;;
			*) break ;;
		esac
	done
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet rm: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet rm: no such wallet '$name' at $path"
		return 3
	fi
	rm -rf "$path"
	if (( force )); then
		if command -v secret >/dev/null 2>&1; then
			secret rm "$name/seed" 2>/dev/null \
				|| warn "wallet rm: 'secret rm $name/seed' failed (continuing)"
		else
			warn "wallet rm: 'secret' not in PATH; skipped seed removal"
		fi
	fi
	info "wallet '$name' removed"
}

# BUG-016 (1.7.1): the previous `command:bip49-create` and
# `command:bip84-create` dispatcher entries here called a
# never-defined `command:bip32-create` and had been dead since the
# repo's extraction. Removed; the bash-function wrappers `bip49()`
# / `bip84()` later in this file are the canonical user surface.
# A latent issue with their BIP32_-prefixed env vars (the bip32
# plugin reads unprefixed `*_VERSION_CODE`) is tracked as an open
# audit follow-up; not in scope here.

# bip173 (segregated witness outputs address format) commands
command:bech32() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"
	declare -Ai bech32_charset_reverse
	for i in {0..31}; do
		bech32_charset_reverse[${bech32_charset:i:1}]=i
	done

	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			local OPTION_M=1
			BECH32_CONST=0x2bc830a3
		fi
		shift 1
	done

	local hrp="${1,,}" data="${2,,}"
	if [[ "$1$2" =~ [A-Z] && "$1$2" =~ [a-z] ]]; then
		return 1
	elif (( ${#hrp} + ${#data} + 6 > 90 )); then
		return 2
	elif (( ${#hrp} < 1 || ${#hrp} > 83 )); then
		return 3
	fi

	local -i ord p out_of_range=0
	for ((p=0;p<${#hrp};p++)); do
		printf -v ord "%d" "'${hrp:p:1}"
		if ((ord < 33 || ord > 126)); then
			break
		fi
	done
	if ((out_of_range == 1)); then
		return 4
	elif [[ "$data" =~ [^$bech32_charset] ]]; then
		return 5
	fi

	# Convert the data part to its 5-bit digit representation
	# (each character maps to a value via bech32_charset_reverse).
	local -ai data_digits=()
	for ((p=0; p<${#data}; p++)); do
		data_digits+=( ${bech32_charset_reverse[${data:p:1}]} )
	done

	# Compute the 6-digit checksum and map both data and checksum
	# digits back through bech32_charset for the final output.
	local -ai checksum_digits=( $(bech32-create-checksum "$hrp" "${data_digits[@]}") )
	echo -n "${hrp}1${data}"
	local d
	for d in "${checksum_digits[@]}"; do
		echo -n "${bech32_charset:d:1}"
	done
	echo
}

help:bech32() {
	cat << ENDHELP
Usage: $SELF bech32 [-m] <human-readable-part> <data>

Bech32 is a string format used to encode segwit addresses, but by itself it is
not a binary-to-text encoding, as it needs additional conventions for padding.
Therefore, the bech32 command does not read binary data, but merely creates a 
Bech32 string from a human readable part and a non checked data part.

$ $SELF bech32 this-part-is-readable-by-a-human qpzry
this-part-is-readable-by-a-human1qpzrylhvwcq

The -m option creates a bech32m string:

$ bech32 -m this-part-is-readable-by-a-human qpzry
this-part-is-readable-by-a-human1qpzry2tuzaz
ENDHELP
	cite 173 "Bech32 segwit address format"
	cite 350 "Bech32m for v1+ witness addresses"
}

command:bech32-verify() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"

	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			local OPTION_M=1
		fi
		shift 1
	done
	if [[ "$1" =~ ^(.{1,83})1([$bech32_charset]{6,})$ ]]; then
		if [ -n "${OPTION_M}" ]; then
			command:bech32 -m "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]::-6}" | grep -q "^$1$"
		else
			command:bech32 "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]::-6}" | grep -q "^$1$"
		fi
	else
		return 33
	fi
}

help:bech32-verify() {
	cat << ENDHELP
Usage: $SELF bech32-verify [-m] <human-readable-part> <data>

This command can be used to verify the checksum of a bech32 string.

$ $SELF bech32-verify this-part-is-readable-by-a-human1qpzrylhvwcq && echo good checksum
good checksum

$ $SELF bech32-verify -m this-part-is-readable-by-a-human1qpzry2tuzaz && echo good checksum
good checksum
ENDHELP
	cite 173 "Bech32 segwit address format"
	cite 350 "Bech32m for v1+ witness addresses"
}

bech32-polymod() {
	local -ai generator=(0x3b6a57b2 0x26508e6d 0x1ea119fa 0x3d4233dd 0x2a1462b3)
	local -i chk=1 value
	for value; do
		local -i top i
		(( top = chk >> 25, chk = (chk & 0x1ffffff) << 5 ^ value ))
		for i in {0..4}; do
			(( ((top >> i) & 1) && (chk^=${generator[i]}) )) || true
		done
	done
	echo $chk
}

bech32-hrp-expand() {
	local -i p ord
	for ((p=0; p < ${#1}; ++p)); do
		printf -v ord "%d" "'${1:p:1}"
		echo $(( ord >> 5 ))
	done
	echo 0
	for ((p=0; p < ${#1}; ++p)); do
		printf -v ord "%d" "'${1:p:1}"
		echo $(( ord & 31 ))
	done
}

bech32-create-checksum() {
	local hrp="$1"
	shift
	local -i p mod=$(bech32-polymod $(bech32-hrp-expand "$hrp") "$@" 0 0 0 0 0 0)^${BECH32_CONST:-1}
	for p in {0..5}; do
		echo $(( (mod >> 5 * (5 - p)) & 31 ))
	done
}

bech32-verify-checksum() {
	local hrp="$1"
	shift
	local -i pmod="$(bech32-polymod $(bech32-hrp-expand "$hrp") "$@")"
	(( pmod == ${BECH32_CONST:-1} ))
}

command:bech32-encode() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"
	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			BECH32_CONST=0x2bc830a3
		fi
		shift 1
	done
	
	local hrp=$1 i
	shift
	set - "$@" $(bech32-create-checksum "$hrp" "$@")
	echo -n "${hrp}1"
	for i; do echo -n "${bech32_charset:i:1}"; done
	echo
}

help:bech32-encode() {
	cat << ENDHELP
usage: $SELF bech32-encode [-m] human-readable-part text

Encodes the text together with the human-readable-part to a bech32 string.
ENDHELP
	cite 173 "Bech32 segwit address format"
}

command:bech32-decode() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"
	declare -Ai bech32_charset_reverse
	for i in {0..31}; do
		bech32_charset_reverse[${bech32_charset:i:1}]=i
	done

	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			BECH32_CONST=0x2bc830a3
		fi
		shift 1
	done

	local bechString=$1
	local -i p has_lower=0 has_upper=0 ord
	for ((p=0;p<${#bechString};++p)); do
		printf -v ord "%d" "'${bechString:p:1}"
		if   ((ord <  33 || ord >  126)); then
			return 1
		elif ((ord >= 97 && ord <= 122)); then
			has_lower=1
		elif ((ord >= 65 && ord <= 90)); then
			has_upper=1
		fi
	done
	if ((has_upper && has_lower)); then
		return 2 # mixed case
	elif bechString="${bechString,,}"; ((${#bechString} > 90)); then
		return 3 # string is too long
	elif [[ ! "$bechString" =~ 1 ]]; then
		return 4 # no separator
	elif local hrp="${bechString%1*}"; test -z $hrp; then 
		return 5 # no human readable part
	elif local data="${bechString##*1}"; ((${#data} < 6)); then
		return 6 # data is too short
	else
		for ((p=0;p<${#data};++p)); do
			echo "${bech32_charset_reverse[${data:p:1}]}"
		done | {
			mapfile -t
			if bech32-verify-checksum "$hrp" "${MAPFILE[@]}"; then
				echo $hrp
				for p in "${MAPFILE[@]::${#MAPFILE[@]}-6}"; do
					echo $p
				done
			else
				return 8
			fi
		}
	fi
}

# bip-0173/bip-0350 code starts here {{{

# hash160(stdin) — SHA-256 then RIPEMD-160 of stdin bytes; emits the
# 20-byte hash. Delegates to the bip32 libexec plugin so we don't
# duplicate the implementation (per CLAUDE.md §4 no-shared-lib: the
# plugin owns hash160; sourceable mode wraps it).
hash160() {
	if [ -n "${SELF_LIBEXEC:-}" ] && [ -x "$SELF_LIBEXEC/${SELF:-bitcoin}/bip32" ]; then
		"$SELF_LIBEXEC/${SELF:-bitcoin}/bip32" hash160
	elif command -v bip32 >/dev/null 2>&1; then
		bip32 hash160
	else
		echo "hash160: bip32 plugin not on PATH and SELF_LIBEXEC not set" >&2
		return 1
	fi
}

p2wpkh() { segwitAddress -p "$1"; }

# shellcheck disable=SC1064,SC1072,SC1073  # function() <compound-command> is legal bash; shellcheck's parser doesn't recognise the if/elif/else form here.
segwitAddress()
  if
    local OPTIND OPTARG o
    getopts hp:tv: o
  then
    shift $((OPTIND - 1))
    case "$o" in
      h) cat <<-END_USAGE
	${FUNCNAME[0]} -h
	${FUNCNAME[0]} [-t] [-v witness-version] WITNESS_PROGRAM
	${FUNCNAME[0]} [-t] -p compressed-point
	END_USAGE
        ;;
      p)
        if [[ "$OPTARG" =~ ^0[23][[:xdigit:]]{64}$ ]]
        then ${FUNCNAME[0]} "$@" "$(
          basenc --base16 -d <<<"${OPTARG^^[a-f]}" |
          hash160 |
          basenc --base16 -w0
        )"
        else echo "-p option expects a compressed point as argument" >&2
          return 1
        fi
        ;;
      t) HRP=tb ${FUNCNAME[0]} "$@" ;;
      v) WITNESS_VERSION=$OPTARG ${FUNCNAME[0]} "$@" ;;
    esac
  elif
    local hrp="${HRP:-bc}"
    [[ ! "$hrp"     =~ ^(bc|tb)$ ]]
  then return 1
  elif
    local witness_program="$1"
    [[ ! "$witness_program" =~ ^([[:xdigit:]]{2})+$ ]]
  then return 2
  elif
    local -i version=WITNESS_VERSION
    ((version < 0))
  then return 3
  elif ((version == 0))
  then
    if [[ "$witness_program" =~ ^(.{40}|.{64})$ ]] # 20 or 32 bytes
    then
      # P2WPKH or P2WSH
      command:bech32-encode "$hrp" $(
        echo $version;
        echo -n "$witness_program" |
        while read -n 2; do echo 0x$REPLY; done |
        convertbits 8 5
      )
    else
       1>&2 echo For version 0, the witness program must be either 20 or 32 bytes long.
       return 4
    fi
  elif ((version <= 16))
  then
    command:bech32-encode -m "$hrp" $(
      echo $version
      echo -n "$witness_program" |
      while read -n 2; do echo 0x$REPLY; done |
      convertbits 8 5
     )
  else return 255
  fi

segwit_verify()
  if bech32 -v "$1"
  then return 1
  else
    local hrp
    local -i witness_version
    local -ai bytes
    bech32_decode "$1" |
    {
      read hrp
      [[ "$hrp" =~ ^(bc|tb)$ ]] || return 2
      read witness_version
      (( witness_version < 0 || witness_version > 16)) && return 3
      
      bytes=($(convertbits 5 8 0)) || return 4
      if
        ((
          ${#bytes[@]} == 0 ||
          ${#bytes[@]} <  2 ||
          ${#bytes[@]} > 40
        ))
      then return 7
      elif ((
         witness_version == 0 &&
         ${#bytes[@]} != 20 &&
         ${#bytes[@]} != 32
      ))
      then return 8
      fi
    }
  fi

convertbits() {
  local -i inbits=$1 outbits=$2 pad=${3:-1} val=0 bits=0 i
  local -i maxv=$(( (1 << outbits) - 1 ))
  while read 
  do
    ((
      val=(val<<inbits)|REPLY,
      bits+=inbits
    ))
    while ((bits >= outbits))
    do
      (( bits-=outbits ))
      echo $(( (val >> bits) & maxv ))
    done
  done
  if ((pad > 0))
  then
    if ((bits))
    then echo $(( (val << (outbits - bits)) & maxv ))
    fi
  elif (( ( (val << (outbits - bits) ) & maxv ) || bits >= inbits))
  then return 1
  fi
}

segwit_decode()
  if
    test-addr() {
      bech32_decode "$addr" ||
      bech32_decode -m "$addr" 
    }
    local addr="$1"
    ! test-addr >/dev/null
  then return 1
  else
    test-addr |
    {
      local hrp
      read hrp
      if [[ ! "$hrp" =~ ^(bc|tb)$ ]]
      then return 2
      fi
      local -i version
      read version
      if ((version > 0)) && bech32_decode "$addr" >/dev/null
      then return 3
      elif ((version == 0)) && bech32_decode -m "$addr" >/dev/null
      then return 4
      elif ((version > 16))
      then return 5
      fi
      mapfile -t
      local p
      local -a bytes
      bytes=($(
        for p in ${MAPFILE[@]}
        do echo $p
        done |
        convertbits 5 8 0
      )) || return 6
      if
        ((
          ${#bytes[@]} == 0 ||
          ${#bytes[@]} <  2 ||
          ${#bytes[@]} > 40
        ))
      then return 7
      elif ((
         version == 0 &&
         ${#bytes[@]} != 20 &&
         ${#bytes[@]} != 32
      ))
      then return 8
      else
        echo $hrp
        echo $version
        printf "%02x" "${bytes[@]}"
        echo
      fi
    }
  fi

# bip-0173 code stops here }}}

# bip-0032 code starts here {{{

# bip-0032 code stops here }}}

bip49() {
  BIP32_MAINNET_PUBLIC_VERSION_CODE=0x049d7cb2 \
  BIP32_MAINNET_PRIVATE_VERSION_CODE=0x049d7878 \
  BIP32_TESTNET_PUBLIC_VERSION_CODE=0x044a5262 \
  BIP32_TESTNET_PRIVATE_VERSION_CODE=0x044a4e28 \
  bip32 "$@"
}

bip84() {
  BIP32_MAINNET_PUBLIC_VERSION_CODE=0x04b24746 \
  BIP32_MAINNET_PRIVATE_VERSION_CODE=0x04b2430c \
  BIP32_TESTNET_PUBLIC_VERSION_CODE=0x045f1cf6 \
  BIP32_TESTNET_PRIVATE_VERSION_CODE=0x045f18bc \
  bip32 "$@"
}

alias xkey=bip32
alias ykey=bip49
alias zkey=bip84

bip85()
  case "$1" in
    wif)
      shift
      $FUNCNAME 2 "$@" |
      wif
      ;;
    xprv)
      $FUNCNAME 32 ${2:-0} |
      basenc --base16 -w64 |
      {
        read left
        read right
        printf '%08X%02X%08X%08X%s00%s' $BIP32_MAINNET_PRIVATE_VERSION_CODE 0 0 0 $left $right
      } |
      basenc --base16 -d |
      bip32
      ;;
    mnemo*)
      local -i words=${2:-12} index=${3:-0} lang ent=words*32/3
      {
        case "$LANG" in
          ja?(_*))  lang=1;;
          ko?(_*))  lang=2;;
          es?(_*))  lang=3;;
          zh_CN)    lang=4;;
          zh_TW)    lang=5;;
          fr?(_*))  lang=6;;
          it?(_*))  lang=7;;
          cz?(_*))  lang=8;;
          *)        lang=0;;
        esac
        # CS = ENT / 32
        # MS = (ENT + CS) / 11
        $FUNCNAME 39 $lang $words $index
      } |
        head -c $((ent/8)) |
        basenc --base16 -w$((2*(ent/8))) |
        {
          read
          create-mnemonic "$REPLY"
        }
      ;;
    hex)
      shift
      local -i num_bytes=${1:-16} index=${2:-0}
      if ((num_bytes < 16 || num_bytes > 64))
      then echo "number of bytes ($num_bytes) out of range" >&2
        return 46
      else 
        $FUNCNAME 128169 $num_bytes $index |
        head -c $num_bytes |
        basenc --base16 -w0
      fi
      ;;
    *)
      local path="m/83696968h/${1:-0}h/${2:-0}h"
      shift; shift;
      for i in "$@"
      do path="$path/${i}h"
      done
      {
        if test -t 0 
        then 
          read -p "extended master key: "
          $SELF bip13 base58-decode <<<"$REPLY"
        else cat
        fi
      } |
      bip32 "$path" |
      tail -c 32 |
      openssl dgst -sha512 -hmac "bip-entropy-from-k" -binary |
      escape-output-if-needed
      ;;
  esac

p2pkh-address() {
  {
    printf %b "${P2PKH_PREFIX:-\x00}"
    cat
  } | $SELF bip13 base58-encode
}
 
bitcoinAddress()
  if
    local OPTIND o
    getopts ht o
  then shift $((OPTIND - 1))
    case "$o" in
      h) cat <<-END_USAGE_bitcoinAddress
	${FUNCNAME[0]} -h
	${FUNCNAME[0]} PUBLIC_POINT
	${FUNCNAME[0]} WIF_PRIVATE_KEY
	${FUNCNAME[0]} PUBLIC_EXTENDED_KEY
	END_USAGE_bitcoinAddress
        ;;
      t) P2PKH_PREFIX="\x6F" ${FUNCNAME[0]} "$@" ;;
    esac
  elif [[ "$1" =~ ^0([23]([[:xdigit:]]{2}){32}|4([[:xdigit:]]{2}){64})$ ]]
  then basenc --base16 -d <<<"${1^^[a-f]}" |hash160 | p2pkh-address 
  elif
    $SELF bip13 base58-verify <<<"$1" && 
    [[ "$($SELF bip13 base58-decode <<<"$1" |
    basenc --base16 -w76
    )" =~ ^(80|ef)([[:xdigit:]]{64})(01)?([[:xdigit:]]{8})$ ]]
  then
    {
      echo "$secp256k1 16doi lgx ${BASH_REMATCH[2]^^}l;xlfxl<*+"
      if test -n "${BASH_REMATCH[3]}"
      then echo lCx
      else echo lUx
      fi
      echo P
    } |
    dc |
    basenc --base16 -w130 |
    {
      read
      if [[ "${BASH_REMATCH[1]}" = 80 ]]
      then ${FUNCNAME[0]} "$REPLY"
      else ${FUNCNAME[0]} -t "$REPLY"
      fi
    }
  elif [[ "$1" =~ ^[xtyzv]pub ]] && $SELF bip13 base58-verify <<<"$1"
  then
    $SELF bip13 base58-decode <<<"$1" |
    head -c -4 |
    tail -c 33 |
    basenc --base16 -w0 |
    {
      read
      case "${1::1}" in
        x) ${FUNCNAME[0]} "$REPLY" ;;
        t) ${FUNCNAME[0]} -t "$REPLY" ;;
        y) 
          {
            printf %b "\x05"
            {
              printf %b%b "\x00\x14"
              echo "${REPLY^^[a-f]}" | basenc --base16 -d |
              hash160
            } | 
            hash160
          } | $SELF bip13 base58-encode
          ;;
        z) segwitAddress -p "$REPLY" ;;
        v) segwitAddress -t -p "$REPLY" ;;
        *)
          echo "${1::4} addresses NYI" >&2
          return 2
          ;;
      esac
    }
  else return 1
  fi


#------------------------------------------------------------------------------
# FEAT-006: when this file is sourced (e.g. `. bitcoin.sh`) rather than
# executed, define all the functions above and return without running
# any command. The same file serves both modes.
[[ "${BASH_SOURCE[0]}" != "$0" ]] && return 0

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

#------------------------------------------------------------------------------
# If this is a builtin command, execute it, otherwise fall through
if has command $1; then
	debug "executing command:$1 ${@:2}"
	command:$1 "${@:2}" # array slice skipping first element
	exit $?
elif test -x "$SELF_LIBEXEC/$SELF/$1"; then
	exec "$SELF_LIBEXEC/$SELF/$1" "${@:2}" # array slice skipping first element
else
	command:help
	exit $?
fi
