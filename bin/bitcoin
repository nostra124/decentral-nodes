# This file requires extended globs to be parsed
shopt -s extglob

# ---------------------------------------------------------------------------
# FEAT-010: wallet store as a git repository.
#
# A wallet is a per-name git repo at
# $XDG_DATA_HOME/bitcoin/wallets/<name>/ holding the *signing context*
# (config, descriptors, ledger). The seed phrase lives in `secret`, not
# here — `bitcoin wallet new` calls `secret put <name>/seed` with the
# generated BIP-39 mnemonic so the wallet repo can be pushed (FEAT-011)
# without leaking the seed.
# ---------------------------------------------------------------------------

wallet:_root() {
	echo "${XDG_DATA_HOME:-$HOME/.local/var}/bitcoin/wallets"
}

wallet:_path() {
	echo "$(wallet:_root)/$1"
}

wallet:_valid_name() {
	[[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]]
}

# ---------------------------------------------------------------------------
# FEAT-009: BIP-380 descriptor checksum + verify.
#
# Per BIP-380 §Checksum: the descriptor body is expanded into 5-bit
# symbols against INPUT_CHARSET (95 chars, 3 groups of 32 + 31 with
# special-case packing), passed through a polymod with five 40-bit
# generator constants, and the resulting 40-bit checksum is rendered
# as 8 chars from CHECKSUM_CHARSET (the bech32 charset).
# ---------------------------------------------------------------------------

# INPUT_CHARSET — 95 chars. Position in string == symbol value.
declare -gr BIP380_INPUT_CHARSET=$'0123456789()[],\'/*abcdefgh@:$%{}IJKLMNOPQRSTUVWXYZ&+-.;<=>?!^_|~ijklmnopqrstuvwxyzABCDEFGH`#"\\ '

declare -gr BIP380_CHECKSUM_CHARSET="qpzry9x8gf2tvdw0s3jn54khce6mua7l"

descriptor:_polymod() {
	local -a generator=(0xf5dee51989 0xa9fdca3312 0x1bab10e32d 0x3706b1677a 0x644d626ffd)
	local -i chk=1 v top i
	for v; do
		(( top = chk >> 35,
		   chk = (chk & 0x7ffffffff) << 5 ^ v ))
		for i in 0 1 2 3 4; do
			(( ((top >> i) & 1) && (chk ^= generator[i]) )) || true
		done
	done
	echo $chk
}

descriptor:_expand() {
	local s="$1"
	local -ai groups=() symbols=()
	local -i i v idx j
	local c
	for ((i=0; i<${#s}; i++)); do
		c="${s:i:1}"
		idx=-1
		for ((j=0; j<${#BIP380_INPUT_CHARSET}; j++)); do
			if [[ "${BIP380_INPUT_CHARSET:j:1}" == "$c" ]]; then
				idx=$j
				break
			fi
		done
		(( idx < 0 )) && return 1
		v=$idx
		symbols+=( $(( v & 31 )) )
		groups+=( $(( v >> 5 )) )
		if (( ${#groups[@]} == 3 )); then
			symbols+=( $(( groups[0] * 9 + groups[1] * 3 + groups[2] )) )
			groups=()
		fi
	done
	if (( ${#groups[@]} == 1 )); then
		symbols+=( ${groups[0]} )
	elif (( ${#groups[@]} == 2 )); then
		symbols+=( $(( groups[0] * 3 + groups[1] )) )
	fi
	printf '%s\n' "${symbols[@]}"
}

descriptor:_create() {
	local body="$1"
	local -a expanded
	mapfile -t expanded < <(descriptor:_expand "$body") \
		|| { error "descriptor: invalid character in '$body'"; return 1; }
	if (( ${#expanded[@]} == 0 )) && [ -n "$body" ]; then
		error "descriptor: invalid character in '$body'"
		return 1
	fi
	local -i chk
	chk=$(descriptor:_polymod "${expanded[@]}" 0 0 0 0 0 0 0 0)
	(( chk ^= 1 ))
	local -i i val
	local out="$body#"
	for i in 0 1 2 3 4 5 6 7; do
		(( val = (chk >> (5 * (7 - i))) & 31 ))
		out+="${BIP380_CHECKSUM_CHARSET:val:1}"
	done
	printf '%s\n' "$out"
}

descriptor:checksum() {
	local s="${1:-}"
	[ -n "$s" ] || { error "descriptor checksum: argument required"; return 2; }
	# If the input already ends in `#<8 chars>`, strip and re-compute.
	if (( ${#s} > 9 )) && [[ "${s: -9: 1}" == "#" ]]; then
		s="${s:0: ${#s}-9}"
	fi
	descriptor:_create "$s"
}

descriptor:verify() {
	local s="${1:-}"
	[ -n "$s" ] || { error "descriptor verify: argument required"; return 2; }
	if (( ${#s} < 10 )) || [[ "${s: -9: 1}" != "#" ]]; then
		error "descriptor verify: no '#' separator + 8-char checksum suffix"
		return 3
	fi
	local body="${s:0: ${#s}-9}"
	local chksum="${s: -8}"
	local -i i j
	local c
	# Every checksum char must be in BIP380_CHECKSUM_CHARSET.
	for ((i=0; i<8; i++)); do
		c="${chksum:i:1}"
		case "$BIP380_CHECKSUM_CHARSET" in
			*"$c"*) ;;
			*) error "descriptor verify: checksum char '$c' not in bech32 set"; return 4 ;;
		esac
	done
	local -a expanded
	mapfile -t expanded < <(descriptor:_expand "$body") \
		|| { error "descriptor verify: invalid character in body"; return 5; }
	local -ai cksym=()
	for ((i=0; i<8; i++)); do
		c="${chksum:i:1}"
		for ((j=0; j<32; j++)); do
			if [[ "${BIP380_CHECKSUM_CHARSET:j:1}" == "$c" ]]; then
				cksym+=( $j )
				break
			fi
		done
	done
	local -i chk
	chk=$(descriptor:_polymod "${expanded[@]}" "${cksym[@]}")
	if (( chk == 1 )); then
		return 0
	else
		error "descriptor verify: checksum mismatch (got polymod=$chk, expected 1)"
		return 6
	fi
}

descriptor:help() {
	cat <<-ENDHELP
	Usage: $SELF descriptor <subcommand> [args]

	  checksum <s>      append a BIP-380 checksum to the descriptor body;
	                    if <s> already ends in '#<8 chars>', replace it
	  verify <s>        verify a descriptor's checksum; exit 0 on success
	  help              this message

	BIP-380 §Checksum defines an 8-character polymod-based suffix after
	a '#' separator: descriptor body, '#', 8 bech32-charset chars.
	ENDHELP
}

help:descriptor() {
	descriptor:help
	cite 380 "Output script descriptors (general)"
	cite 381 "Non-segwit output script descriptors"
	cite 386 "tr() output script descriptor"
}

command:descriptor() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		checksum) descriptor:checksum "$@" ;;
		verify)   descriptor:verify   "$@" ;;
		help)     descriptor:help ;;
		*)
			error "unknown descriptor subcommand: '$sub'"
			descriptor:help >&2
			return 2
			;;
	esac
}

# ---------------------------------------------------------------------------
# FEAT-012: backend abstraction. A thin verb layer dispatches to one
# of three implementations (mempool.space REST shipped here;
# bitcoind RPC and blockstream.info REST are scaffolded as stubs and
# tracked in a follow-up FEAT once we have something to test them
# against in this sandbox).
#
# Active backend resolution: $BITCOIN_BACKEND env var, then the
# config file at $XDG_CONFIG_HOME/bitcoin/backend, then 'mempool'.
# ---------------------------------------------------------------------------

backend:_config_file() {
	echo "${XDG_CONFIG_HOME:-$HOME/.config}/bitcoin/backend"
}

backend:_active() {
	if [ -n "${BITCOIN_BACKEND:-}" ]; then
		echo "$BITCOIN_BACKEND"
		return
	fi
	local cfg; cfg="$(backend:_config_file)"
	if [ -f "$cfg" ]; then
		cat "$cfg"
	else
		echo mempool
	fi
}

backend:_valid() {
	case "$1" in
		mempool|bitcoind|blockstream) return 0 ;;
		*) return 1 ;;
	esac
}

backend:set() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "backend set: name required (mempool|bitcoind|blockstream)"
		return 2
	fi
	if ! backend:_valid "$name"; then
		error "backend set: unknown backend '$name' (use mempool, bitcoind, or blockstream)"
		return 3
	fi
	local cfg; cfg="$(backend:_config_file)"
	mkdir -p "$(dirname "$cfg")" || { error "backend set: cannot mkdir $(dirname "$cfg")"; return 4; }
	echo "$name" > "$cfg"
	info "backend set to: $name"
}

backend:auto() {
	if command -v bitcoin-cli >/dev/null 2>&1 \
	   && bitcoin-cli getblockcount >/dev/null 2>&1; then
		backend:set bitcoind
	else
		warn "bitcoin-cli not reachable; falling back to mempool.space (chain state is trusted to a third party)"
		backend:set mempool
	fi
}

# --- verbs --------------------------------------------------------------------

backend:chain-height() {
	local b; b="$(backend:_active)"
	backend:"$b":chain-height
}

backend:get-address-utxos() {
	local b; b="$(backend:_active)"
	backend:"$b":get-address-utxos "$@"
}

backend:broadcast() {
	local b; b="$(backend:_active)"
	backend:"$b":broadcast "$@"
}

# --- mempool.space implementation --------------------------------------------

: "${BITCOIN_MEMPOOL_URL:=https://mempool.space}"

backend:mempool:chain-height() {
	local url="$BITCOIN_MEMPOOL_URL/api/blocks/tip/height"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

backend:mempool:get-address-utxos() {
	local addr="${1:-}"
	if [ -z "$addr" ]; then
		error "backend get-address-utxos: address required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/address/$addr/utxo"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

backend:mempool:broadcast() {
	local hex="${1:-}"
	if [ -z "$hex" ]; then
		error "backend broadcast: tx hex required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/tx"
	local out
	if ! out="$(curl -sfL -X POST --data "$hex" "$url")"; then
		error "mempool: POST $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

# --- bitcoind / blockstream stubs --------------------------------------------
#
# Scaffolded so `bitcoin backend set bitcoind|blockstream` doesn't
# break the dispatcher; verbs return "not implemented" with a clear
# error. Filling these out is FEAT-NNN follow-up.

backend:bitcoind:chain-height() {
	error "backend bitcoind: not implemented in this release (use mempool)"
	return 99
}
backend:bitcoind:get-address-utxos() { backend:bitcoind:chain-height; }
backend:bitcoind:broadcast()         { backend:bitcoind:chain-height; }

backend:blockstream:chain-height() {
	error "backend blockstream: not implemented in this release (use mempool)"
	return 99
}
backend:blockstream:get-address-utxos() { backend:blockstream:chain-height; }
backend:blockstream:broadcast()         { backend:blockstream:chain-height; }

# --- dispatcher --------------------------------------------------------------

command:backend() {
	local action="${1:-view}"
	shift 2>/dev/null || true
	case "$action" in
		view|"")
			backend:_active ;;
		set)
			backend:set "$@" ;;
		auto)
			backend:auto ;;
		mempool|bitcoind|blockstream)
			# Shorthand: `bitcoin backend mempool` = `backend set mempool`
			backend:set "$action" ;;
		chain-height|get-address-utxos|broadcast)
			backend:"$action" "$@" ;;
		help)
			backend:help ;;
		*)
			error "unknown backend action: '$action'"
			backend:help >&2
			return 2
			;;
	esac
}

backend:help() {
	cat <<-ENDHELP
	Usage: $SELF backend [<action> [args]]

	  view (default)            print the active backend
	  set <name>                set active backend (mempool|bitcoind|blockstream)
	  auto                      pick bitcoind if reachable, else mempool
	  <name>                    shorthand for 'set <name>'

	  chain-height              current chain tip height (integer)
	  get-address-utxos <addr>  UTXOs at <addr> as backend-native JSON
	  broadcast <hex>           POST a raw tx; print the txid

	Active backend in this shell:
	  BITCOIN_BACKEND env var, then $(backend:_config_file), then 'mempool'.

	Only the mempool.space implementation ships in this release.
	bitcoind and blockstream are scaffolded; calling their verbs
	returns a clear "not implemented" error.
	ENDHELP
}

help:backend() {
	backend:help
}

command:wallet() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		new|ls|rm|help) wallet:"$sub" "$@" ;;
		*)
			error "unknown wallet subcommand: '$sub'"
			wallet:help >&2
			return 2
			;;
	esac
}

help:wallet() {
	wallet:help
	cite 39 "Mnemonic seed phrases"
}

wallet:help() {
	cat <<-ENDHELP
	Usage: $SELF wallet <subcommand> [args]

	  new <name>        create a new wallet at $(wallet:_root)/<name>
	                    generates a BIP-39 mnemonic and stores it via
	                    'secret put <name>/seed'
	  ls                list existing wallets
	  rm [-f] <name>    remove a wallet (-f also removes secret/<name>/seed)
	  help              this message

	A wallet is a git repository. The seed phrase is held by 'secret',
	not by this repo, so 'bitcoin wallet push' (FEAT-011) is safe by
	construction.
	ENDHELP
}

wallet:new() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet new: name required"
		return 2
	fi
	if ! wallet:_valid_name "$name"; then
		error "wallet new: invalid name '$name' (must match [A-Za-z0-9][A-Za-z0-9_-]*)"
		return 3
	fi
	local path; path="$(wallet:_path "$name")"
	if [ -e "$path" ]; then
		error "wallet new: '$name' already exists at $path"
		return 4
	fi
	if ! command -v secret >/dev/null 2>&1; then
		error "wallet new: 'secret' not found in PATH (install nostra124/secret)"
		return 5
	fi
	if [ ! -x "$SELF_LIBEXEC/$SELF/bip39" ]; then
		error "wallet new: 'bip39' libexec plugin not found at $SELF_LIBEXEC/$SELF/bip39"
		return 6
	fi

	local mnemonic
	if ! mnemonic="$("$SELF_LIBEXEC/$SELF/bip39" create 256 2>/dev/null)"; then
		error "wallet new: bip39 create failed"
		return 7
	fi
	if [ -z "$mnemonic" ]; then
		error "wallet new: bip39 create produced empty mnemonic"
		return 8
	fi

	if ! printf '%s\n' "$mnemonic" | secret put "$name/seed"; then
		error "wallet new: 'secret put $name/seed' failed"
		return 9
	fi

	mkdir -p "$path" || { error "wallet new: mkdir $path failed"; return 10; }
	(
		cd "$path" || exit 1
		git init -q -b main || git init -q
		cat > config <<-CFG
		# bitcoin wallet '$name' — FEAT-010
		name=$name
		network=testnet
		CFG
		: > descriptors
		git add config descriptors
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			commit -q -m "wallet new: $name"
	) || { error "wallet new: failed to initialise repo at $path"; return 11; }

	info "wallet '$name' created at $path"
}

wallet:ls() {
	local root; root="$(wallet:_root)"
	if [ ! -d "$root" ]; then
		return 0
	fi
	find "$root" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | sort
}

wallet:rm() {
	local force=0
	while [ $# -gt 0 ]; do
		case "${1:-}" in
			-f|--force) force=1; shift ;;
			--) shift; break ;;
			-*) error "wallet rm: unknown flag '$1'"; return 2 ;;
			*) break ;;
		esac
	done
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet rm: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet rm: no such wallet '$name' at $path"
		return 3
	fi
	rm -rf "$path"
	if (( force )); then
		if command -v secret >/dev/null 2>&1; then
			secret rm "$name/seed" 2>/dev/null \
				|| warn "wallet rm: 'secret rm $name/seed' failed (continuing)"
		else
			warn "wallet rm: 'secret' not in PATH; skipped seed removal"
		fi
	fi
	info "wallet '$name' removed"
}

command:bip49-create() {
  BIP32_MAINNET_PUBLIC_VERSION_CODE=0x049d7cb2 \
  BIP32_MAINNET_PRIVATE_VERSION_CODE=0x049d7878 \
  BIP32_TESTNET_PUBLIC_VERSION_CODE=0x044a5262 \
  BIP32_TESTNET_PRIVATE_VERSION_CODE=0x044a4e28 \
  command:bip32-create "$@"
}

command:bip84-create() {
  BIP32_MAINNET_PUBLIC_VERSION_CODE=0x04b24746 \
  BIP32_MAINNET_PRIVATE_VERSION_CODE=0x04b2430c \
  BIP32_TESTNET_PUBLIC_VERSION_CODE=0x045f1cf6 \
  BIP32_TESTNET_PRIVATE_VERSION_CODE=0x045f18bc \
  command:bip32-create "$@"
}

# bip173 (segregated witness outputs address format) commands
command:bech32() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"
	declare -Ai bech32_charset_reverse
	for i in {0..31}; do
		bech32_charset_reverse[${bech32_charset:i:1}]=i
	done

	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			local OPTION_M=1
			BECH32_CONST=0x2bc830a3
		fi
		shift 1
	done

	local hrp="${1,,}" data="${2,,}"
	if [[ "$1$2" =~ [A-Z] && "$1$2" =~ [a-z] ]]; then
		return 1
	elif (( ${#hrp} + ${#data} + 6 > 90 )); then
		return 2
	elif (( ${#hrp} < 1 || ${#hrp} > 83 )); then
		return 3
	fi

	local -i ord p out_of_range=0
	for ((p=0;p<${#hrp};p++)); do
		printf -v ord "%d" "'${hrp:p:1}"
		if ((ord < 33 || ord > 126)); then
			break
		fi
	done
	if ((out_of_range == 1)); then
		return 4
	elif [[ "$data" =~ [^$bech32_charset] ]]; then
		return 5
	fi

	# Convert the data part to its 5-bit digit representation
	# (each character maps to a value via bech32_charset_reverse).
	local -ai data_digits=()
	for ((p=0; p<${#data}; p++)); do
		data_digits+=( ${bech32_charset_reverse[${data:p:1}]} )
	done

	# Compute the 6-digit checksum and map both data and checksum
	# digits back through bech32_charset for the final output.
	local -ai checksum_digits=( $(bech32-create-checksum "$hrp" "${data_digits[@]}") )
	echo -n "${hrp}1${data}"
	local d
	for d in "${checksum_digits[@]}"; do
		echo -n "${bech32_charset:d:1}"
	done
	echo
}

help:bech32() {
	cat << ENDHELP
Usage: $SELF bech32 [-m] <human-readable-part> <data>

Bech32 is a string format used to encode segwit addresses, but by itself it is
not a binary-to-text encoding, as it needs additional conventions for padding.
Therefore, the bech32 command does not read binary data, but merely creates a 
Bech32 string from a human readable part and a non checked data part.

$ $SELF bech32 this-part-is-readable-by-a-human qpzry
this-part-is-readable-by-a-human1qpzrylhvwcq

The -m option creates a bech32m string:

$ bech32 -m this-part-is-readable-by-a-human qpzry
this-part-is-readable-by-a-human1qpzry2tuzaz
ENDHELP
	cite 173 "Bech32 segwit address format"
	cite 350 "Bech32m for v1+ witness addresses"
}

command:bech32-verify() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"

	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			local OPTION_M=1
		fi
		shift 1
	done
	if [[ "$1" =~ ^(.{1,83})1([$bech32_charset]{6,})$ ]]; then
		if [ -n "${OPTION_M}" ]; then
			command:bech32 -m "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]::-6}" | grep -q "^$1$"
		else
			command:bech32 "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]::-6}" | grep -q "^$1$"
		fi
	else
		return 33
	fi
}

help:bech32-verify() {
	cat << ENDHELP
Usage: $SELF bech32-verify [-m] <human-readable-part> <data>

This command can be used to verify the checksum of a bech32 string.

$ $SELF bech32-verify this-part-is-readable-by-a-human1qpzrylhvwcq && echo good checksum
good checksum

$ $SELF bech32-verify -m this-part-is-readable-by-a-human1qpzry2tuzaz && echo good checksum
good checksum
ENDHELP
	cite 173 "Bech32 segwit address format"
	cite 350 "Bech32m for v1+ witness addresses"
}

bech32-polymod() {
	local -ai generator=(0x3b6a57b2 0x26508e6d 0x1ea119fa 0x3d4233dd 0x2a1462b3)
	local -i chk=1 value
	for value; do
		local -i top i
		(( top = chk >> 25, chk = (chk & 0x1ffffff) << 5 ^ value ))
		for i in {0..4}; do
			(( ((top >> i) & 1) && (chk^=${generator[i]}) )) || true
		done
	done
	echo $chk
}

bech32-hrp-expand() {
	local -i p ord
	for ((p=0; p < ${#1}; ++p)); do
		printf -v ord "%d" "'${1:p:1}"
		echo $(( ord >> 5 ))
	done
	echo 0
	for ((p=0; p < ${#1}; ++p)); do
		printf -v ord "%d" "'${1:p:1}"
		echo $(( ord & 31 ))
	done
}

bech32-create-checksum() {
	local hrp="$1"
	shift
	local -i p mod=$(bech32-polymod $(bech32-hrp-expand "$hrp") "$@" 0 0 0 0 0 0)^${BECH32_CONST:-1}
	for p in {0..5}; do
		echo $(( (mod >> 5 * (5 - p)) & 31 ))
	done
}

bech32-verify-checksum() {
	local hrp="$1"
	shift
	local -i pmod="$(bech32-polymod $(bech32-hrp-expand "$hrp") "$@")"
	(( pmod == ${BECH32_CONST:-1} ))
}

command:bech32-encode() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"
	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			BECH32_CONST=0x2bc830a3
		fi
		shift 1
	done
	
	local hrp=$1 i
	shift
	set - "$@" $(bech32-create-checksum "$hrp" "$@")
	echo -n "${hrp}1"
	for i; do echo -n "${bech32_charset:i:1}"; done
	echo
}

help:bech32-encode() {
	cat << ENDHELP
usage: $SELF bech32-encode [-m] human-readable-part text

Encodes the text together with the human-readable-part to a bech32 string.
ENDHELP
	cite 173 "Bech32 segwit address format"
}

command:bech32-decode() {
	declare -r bech32_charset="qpzry9x8gf2tvdw0s3jn54khce6mua7l"
	declare -Ai bech32_charset_reverse
	for i in {0..31}; do
		bech32_charset_reverse[${bech32_charset:i:1}]=i
	done

	while getopts "c:m" flag; do
		if [ x"$1" = x'-m' ]; then
			BECH32_CONST=0x2bc830a3
		fi
		shift 1
	done

	local bechString=$1
	local -i p has_lower=0 has_upper=0 ord
	for ((p=0;p<${#bechString};++p)); do
		printf -v ord "%d" "'${bechString:p:1}"
		if   ((ord <  33 || ord >  126)); then
			return 1
		elif ((ord >= 97 && ord <= 122)); then
			has_lower=1
		elif ((ord >= 65 && ord <= 90)); then
			has_upper=1
		fi
	done
	if ((has_upper && has_lower)); then
		return 2 # mixed case
	elif bechString="${bechString,,}"; ((${#bechString} > 90)); then
		return 3 # string is too long
	elif [[ ! "$bechString" =~ 1 ]]; then
		return 4 # no separator
	elif local hrp="${bechString%1*}"; test -z $hrp; then 
		return 5 # no human readable part
	elif local data="${bechString##*1}"; ((${#data} < 6)); then
		return 6 # data is too short
	else
		for ((p=0;p<${#data};++p)); do
			echo "${bech32_charset_reverse[${data:p:1}]}"
		done | {
			mapfile -t
			if bech32-verify-checksum "$hrp" "${MAPFILE[@]}"; then
				echo $hrp
				for p in "${MAPFILE[@]::${#MAPFILE[@]}-6}"; do
					echo $p
				done
			else
				return 8
			fi
		}
	fi
}

# bip-0173/bip-0350 code starts here {{{

p2wpkh() { segwitAddress -p "$1"; }

# shellcheck disable=SC1064,SC1072,SC1073  # function() <compound-command> is legal bash; shellcheck's parser doesn't recognise the if/elif/else form here.
segwitAddress()
  if
    local OPTIND OPTARG o
    getopts hp:tv: o
  then
    shift $((OPTIND - 1))
    case "$o" in
      h) cat <<-END_USAGE
	${FUNCNAME[0]} -h
	${FUNCNAME[0]} [-t] [-v witness-version] WITNESS_PROGRAM
	${FUNCNAME[0]} [-t] -p compressed-point
	END_USAGE
        ;;
      p)
        if [[ "$OPTARG" =~ ^0[23][[:xdigit:]]{64}$ ]]
        then ${FUNCNAME[0]} "$@" "$(
          basenc --base16 -d <<<"${OPTARG^^[a-f]}" |
          hash160 |
          basenc --base16 -w0
        )"
        else echo "-p option expects a compressed point as argument" >&2
          return 1
        fi
        ;;
      t) HRP=tb ${FUNCNAME[0]} "$@" ;;
      v) WITNESS_VERSION=$OPTARG ${FUNCNAME[0]} "$@" ;;
    esac
  elif
    local hrp="${HRP:-bc}"
    [[ ! "$hrp"     =~ ^(bc|tb)$ ]]
  then return 1
  elif
    local witness_program="$1"
    [[ ! "$witness_program" =~ ^([[:xdigit:]]{2})+$ ]]
  then return 2
  elif
    local -i version=WITNESS_VERSION
    ((version < 0))
  then return 3
  elif ((version == 0))
  then
    if [[ "$witness_program" =~ ^(.{40}|.{64})$ ]] # 20 or 32 bytes
    then
      # P2WPKH or P2WSH
      command:bech32-encode "$hrp" $(
        echo $version;
        echo -n "$witness_program" |
        while read -n 2; do echo 0x$REPLY; done |
        convertbits 8 5
      )
    else
       1>&2 echo For version 0, the witness program must be either 20 or 32 bytes long.
       return 4
    fi
  elif ((version <= 16))
  then
    command:bech32-encode -m "$hrp" $(
      echo $version
      echo -n "$witness_program" |
      while read -n 2; do echo 0x$REPLY; done |
      convertbits 8 5
     )
  else return 255
  fi

segwit_verify()
  if bech32 -v "$1"
  then return 1
  else
    local hrp
    local -i witness_version
    local -ai bytes
    bech32_decode "$1" |
    {
      read hrp
      [[ "$hrp" =~ ^(bc|tb)$ ]] || return 2
      read witness_version
      (( witness_version < 0 || witness_version > 16)) && return 3
      
      bytes=($(convertbits 5 8 0)) || return 4
      if
        ((
          ${#bytes[@]} == 0 ||
          ${#bytes[@]} <  2 ||
          ${#bytes[@]} > 40
        ))
      then return 7
      elif ((
         witness_version == 0 &&
         ${#bytes[@]} != 20 &&
         ${#bytes[@]} != 32
      ))
      then return 8
      fi
    }
  fi

convertbits() {
  local -i inbits=$1 outbits=$2 pad=${3:-1} val=0 bits=0 i
  local -i maxv=$(( (1 << outbits) - 1 ))
  while read 
  do
    ((
      val=(val<<inbits)|REPLY,
      bits+=inbits
    ))
    while ((bits >= outbits))
    do
      (( bits-=outbits ))
      echo $(( (val >> bits) & maxv ))
    done
  done
  if ((pad > 0))
  then
    if ((bits))
    then echo $(( (val << (outbits - bits)) & maxv ))
    fi
  elif (( ( (val << (outbits - bits) ) & maxv ) || bits >= inbits))
  then return 1
  fi
}

segwit_decode()
  if
    test-addr() {
      bech32_decode "$addr" ||
      bech32_decode -m "$addr" 
    }
    local addr="$1"
    ! test-addr >/dev/null
  then return 1
  else
    test-addr |
    {
      local hrp
      read hrp
      if [[ ! "$hrp" =~ ^(bc|tb)$ ]]
      then return 2
      fi
      local -i version
      read version
      if ((version > 0)) && bech32_decode "$addr" >/dev/null
      then return 3
      elif ((version == 0)) && bech32_decode -m "$addr" >/dev/null
      then return 4
      elif ((version > 16))
      then return 5
      fi
      mapfile -t
      local p
      local -a bytes
      bytes=($(
        for p in ${MAPFILE[@]}
        do echo $p
        done |
        convertbits 5 8 0
      )) || return 6
      if
        ((
          ${#bytes[@]} == 0 ||
          ${#bytes[@]} <  2 ||
          ${#bytes[@]} > 40
        ))
      then return 7
      elif ((
         version == 0 &&
         ${#bytes[@]} != 20 &&
         ${#bytes[@]} != 32
      ))
      then return 8
      else
        echo $hrp
        echo $version
        printf "%02x" "${bytes[@]}"
        echo
      fi
    }
  fi

# bip-0173 code stops here }}}

