# This file requires extended globs to be parsed
shopt -s extglob

# ---------------------------------------------------------------------------
# FEAT-010: wallet store as a git repository.
#
# A wallet is a per-name git repo at
# $XDG_DATA_HOME/bitcoin/wallets/<name>/ holding the *signing context*
# (config, descriptors, ledger). The seed phrase lives in `secret`, not
# here — `bitcoin wallet new` calls `secret put <name>/seed` with the
# generated BIP-39 mnemonic so the wallet repo can be pushed (FEAT-011)
# without leaking the seed.
# ---------------------------------------------------------------------------

wallet:_root() {
	echo "${XDG_DATA_HOME:-$HOME/.local/var}/bitcoin/wallets"
}

wallet:_path() {
	echo "$(wallet:_root)/$1"
}

wallet:_valid_name() {
	[[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]]
}

# ---------------------------------------------------------------------------
# FEAT-035 Stream B (1.23.0): BIP-380 descriptor checksum/verify/derive
# moved to `libexec/bitcoin/bip380`. `command:descriptor` keeps four
# subcommands as a single dispatcher:
#   - wallet  — stays here (reads secret + wallet:_path); not
#               deprecated yet (re-home into `wallet descriptor` in a
#               future PR).
#   - checksum / verify / derive / help — deprecated aliases that
#               warn + exec the new plugin. Removal target: 1.24.0.
# ---------------------------------------------------------------------------

# Base58Check-encode a binary file. Used by descriptor:wallet to
# convert the 78-byte bip32 extended-key serialisation into the
# canonical xpub/xprv string. Duplicated in bip380's helpers per
# CLAUDE.md §5.
descriptor:_base58check_file() {
	local infile="$1"
	local libexec="${SELF_LIBEXEC:?descriptor: SELF_LIBEXEC must be set}"
	local tmp; tmp="$(mktemp)"
	# data || sha256d(data)[:4]
	{
		cat "$infile"
		openssl dgst -sha256 -binary < "$infile" \
			| openssl dgst -sha256 -binary \
			| head -c 4
	} > "$tmp"
	"$libexec/${SELF:-bitcoin}/bip13" base58-encode < "$tmp"
	rm -f "$tmp"
}

descriptor:wallet() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "descriptor wallet: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "descriptor wallet: no such wallet '$name' at $path"
		return 3
	fi
	if ! command -v secret >/dev/null 2>&1; then
		error "descriptor wallet: 'secret' not in PATH (cannot read seed)"
		return 4
	fi
	local libexec="${SELF_LIBEXEC:?descriptor wallet: SELF_LIBEXEC must be set}"

	local raw; raw="$(mktemp)"
	secret get "$name/seed" |
		"$libexec/${SELF:-bitcoin}/bip39" mnemonic-to-seed |
		"$libexec/${SELF:-bitcoin}/bip32" create 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip13" base58-decode 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip32" derive "m/84h/0h/0h/N" 2>/dev/null \
		> "$raw"
	if [ ! -s "$raw" ]; then
		rm -f "$raw"
		error "descriptor wallet: xpub derivation for '$name' produced empty output"
		return 5
	fi
	local xpub; xpub="$(descriptor:_base58check_file "$raw")"
	rm -f "$raw"
	if [ -z "$xpub" ]; then
		error "descriptor wallet: base58check encoding failed for '$name'"
		return 6
	fi
	"$libexec/${SELF:-bitcoin}/bip380" checksum "wpkh($xpub/0/*)"
}

command:descriptor() {
	local sub="${1:-help}"
	case "$sub" in
		wallet)
			shift 2>/dev/null || true
			descriptor:wallet "$@"
			;;
		help)
			# Only the wallet subcommand survives under `descriptor`.
			# checksum / verify / derive moved to bip380 in 1.23.0 and
			# the deprecated aliases were removed in 1.24.0.
			cat >&2 <<-EOF
			Usage: $SELF descriptor wallet <name>

			  wallet <name>     emit a checksummed wpkh(<xpub>/0/*) descriptor for an
			                    existing wallet. Reads the seed via 'secret get' and
			                    derives the m/84h/0h/0h xpub via the same pipeline
			                    'wallet derive' uses.

			'bitcoin descriptor checksum/verify/derive' were removed in
			1.24.0 — use the canonical 'bitcoin bip380 <subcommand>' forms.
			EOF
			;;
		checksum|verify|derive)
			error "'descriptor $sub' was removed in 1.24.0; use 'bitcoin bip380 $sub'"
			return 1
			;;
		*)
			error "unknown descriptor subcommand: '$sub'"
			return 2
			;;
	esac
}

help:descriptor() {
	cite 380 "Output script descriptors (general)"
	cite 381 "Non-segwit output script descriptors"
	cite 386 "tr() output script descriptor"
}

# ---------------------------------------------------------------------------
# FEAT-012: backend abstraction. A thin verb layer dispatches to one
# of three implementations (mempool.space REST shipped here;
# bitcoind RPC and blockstream.info REST are scaffolded as stubs and
# tracked in a follow-up FEAT once we have something to test them
# against in this sandbox).
#
# Active backend resolution: $BITCOIN_BACKEND env var, then the
# config file at $XDG_CONFIG_HOME/bitcoin/backend, then 'mempool'.
# ---------------------------------------------------------------------------

backend:_config_file() {
	echo "${XDG_CONFIG_HOME:-$HOME/.config}/bitcoin/backend"
}

backend:_active() {
	if [ -n "${BITCOIN_BACKEND:-}" ]; then
		echo "$BITCOIN_BACKEND"
		return
	fi
	local cfg; cfg="$(backend:_config_file)"
	if [ -f "$cfg" ]; then
		cat "$cfg"
	else
		echo mempool
	fi
}

backend:_valid() {
	case "$1" in
		mempool|bitcoind|blockstream) return 0 ;;
		*) return 1 ;;
	esac
}

backend:set() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "backend set: name required (mempool|bitcoind|blockstream)"
		return 2
	fi
	if ! backend:_valid "$name"; then
		error "backend set: unknown backend '$name' (use mempool, bitcoind, or blockstream)"
		return 3
	fi
	local cfg; cfg="$(backend:_config_file)"
	mkdir -p "$(dirname "$cfg")" || { error "backend set: cannot mkdir $(dirname "$cfg")"; return 4; }
	echo "$name" > "$cfg"
	info "backend set to: $name"
}

backend:auto() {
	if command -v bitcoin-cli >/dev/null 2>&1 \
	   && bitcoin-cli getblockcount >/dev/null 2>&1; then
		backend:set bitcoind
	else
		warn "bitcoin-cli not reachable; falling back to mempool.space (chain state is trusted to a third party)"
		backend:set mempool
	fi
}

# --- verbs --------------------------------------------------------------------

backend:chain-height() {
	local b; b="$(backend:_active)"
	backend:"$b":chain-height
}

backend:get-address-utxos() {
	local b; b="$(backend:_active)"
	backend:"$b":get-address-utxos "$@"
}

backend:broadcast() {
	local b; b="$(backend:_active)"
	backend:"$b":broadcast "$@"
}

backend:estimate-fee() {
	local b; b="$(backend:_active)"
	backend:"$b":estimate-fee "$@"
}

backend:get-address-txs() {
	local b; b="$(backend:_active)"
	backend:"$b":get-address-txs "$@"
}

# --- mempool.space implementation --------------------------------------------

: "${BITCOIN_MEMPOOL_URL:=https://mempool.space}"

backend:mempool:chain-height() {
	local url="$BITCOIN_MEMPOOL_URL/api/blocks/tip/height"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

backend:mempool:get-address-utxos() {
	local addr="${1:-}"
	if [ -z "$addr" ]; then
		error "backend get-address-utxos: address required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/address/$addr/utxo"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

backend:mempool:broadcast() {
	local hex="${1:-}"
	if [ -z "$hex" ]; then
		error "backend broadcast: tx hex required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/tx"
	local out
	if ! out="$(curl -sfL -X POST --data "$hex" "$url")"; then
		error "mempool: POST $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

# Mempool only publishes a fixed set of fee buckets via
# /api/v1/fees/recommended; the <target-blocks> arg picks which one.
# Anything outside the buckets is clamped to the nearest neighbour
# rather than rejected — callers asking for "5 blocks" get the
# 6-block estimate, not an error.
backend:mempool:estimate-fee() {
	local target="${1:-3}"
	if [[ ! "$target" =~ ^[0-9]+$ ]]; then
		error "backend estimate-fee: target must be a non-negative integer (got '$target')"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/v1/fees/recommended"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	local field
	if   (( target <= 1   )); then field=fastestFee
	elif (( target <= 3   )); then field=halfHourFee
	elif (( target <= 6   )); then field=hourFee
	elif (( target <= 144 )); then field=economyFee
	else                            field=minimumFee
	fi
	local rate
	rate="$(printf '%s' "$out" | jq -r ".$field // empty" 2>/dev/null)"
	if [[ ! "$rate" =~ ^[0-9]+$ ]]; then
		error "mempool: estimate-fee response missing or non-integer field '$field' (got '$rate')"
		return 3
	fi
	printf '%s\n' "$rate"
}

# Return the JSON array of transactions touching <address>. Used by
# `wallet index` (FEAT-018) to build the wallet's on-disk history.
backend:mempool:get-address-txs() {
	local addr="${1:-}"
	if [ -z "$addr" ]; then
		error "backend get-address-txs: address required"
		return 2
	fi
	local url="$BITCOIN_MEMPOOL_URL/api/address/$addr/txs"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "mempool: GET $url failed (curl exit $?)"
		return 1
	fi
	printf '%s\n' "$out"
}

# --- bitcoind / blockstream stubs --------------------------------------------
#
# Scaffolded so `bitcoin backend set bitcoind|blockstream` doesn't
# break the dispatcher; verbs return "not implemented" with a clear
# error. Filling these out is FEAT-NNN follow-up.

backend:bitcoind:chain-height() {
	error "backend bitcoind: not implemented in this release (use mempool)"
	return 99
}
backend:bitcoind:get-address-utxos() { backend:bitcoind:chain-height; }
backend:bitcoind:broadcast()         { backend:bitcoind:chain-height; }
backend:bitcoind:estimate-fee()      { backend:bitcoind:chain-height; }
backend:bitcoind:get-address-txs()   { backend:bitcoind:chain-height; }

backend:blockstream:chain-height() {
	error "backend blockstream: not implemented in this release (use mempool)"
	return 99
}
backend:blockstream:get-address-utxos() { backend:blockstream:chain-height; }
backend:blockstream:broadcast()         { backend:blockstream:chain-height; }
backend:blockstream:estimate-fee()      { backend:blockstream:chain-height; }
backend:blockstream:get-address-txs()   { backend:blockstream:chain-height; }

# --- dispatcher --------------------------------------------------------------

command:backend() {
	local action="${1:-view}"
	shift 2>/dev/null || true
	case "$action" in
		view|"")
			backend:_active ;;
		set)
			backend:set "$@" ;;
		auto)
			backend:auto ;;
		mempool|bitcoind|blockstream)
			# Shorthand: `bitcoin backend mempool` = `backend set mempool`
			backend:set "$action" ;;
		chain-height|get-address-utxos|broadcast|estimate-fee|get-address-txs)
			backend:"$action" "$@" ;;
		help)
			backend:help ;;
		*)
			error "unknown backend action: '$action'"
			backend:help >&2
			return 2
			;;
	esac
}

backend:help() {
	cat <<-ENDHELP
	Usage: $SELF backend [<action> [args]]

	  view (default)            print the active backend
	  set <name>                set active backend (mempool|bitcoind|blockstream)
	  auto                      pick bitcoind if reachable, else mempool
	  <name>                    shorthand for 'set <name>'

	  chain-height              current chain tip height (integer)
	  get-address-utxos <addr>  UTXOs at <addr> as backend-native JSON
	  get-address-txs <addr>    every tx touching <addr> as backend-native
	                            JSON array (FEAT-018 wallet index source)
	  broadcast <hex>           POST a raw tx; print the txid
	  estimate-fee [<blocks>]   sat/vB recommended for confirmation in
	                            <blocks> (default 3). Mempool buckets:
	                            1 (fastest), 3 (half-hour), 6 (hour),
	                            144 (economy), else (minimum).

	Active backend in this shell:
	  BITCOIN_BACKEND env var, then $(backend:_config_file), then 'mempool'.

	Only the mempool.space implementation ships in this release.
	bitcoind and blockstream are scaffolded; calling their verbs
	returns a clear "not implemented" error.
	ENDHELP
}

help:backend() {
	backend:help
}

# ---------------------------------------------------------------------------
# FEAT-035 Stream D (1.23.0): the psbt block — `command:psbt` and the
# entire `psbt:*` private helper family — moved to
# `libexec/bitcoin/bip174` so the canonical user-facing form is
# `bitcoin bip174 <subcommand>` (BIP-faithful naming, per
# docs/command-surface.md). `bitcoin psbt` remains as a deprecated
# alias for one release; removal target 1.24.0.
# ---------------------------------------------------------------------------

# Hash160(stdin-hex). Pipe-friendly: takes hex on stdin, prints hex on
# stdout. Used by the descriptor pkh / sh(wpkh) address paths. Kept
# here (not in bip174) so descriptor doesn't shell out across the
# dispatcher for what is one openssl pipeline. Per CLAUDE.md §5,
# bip174 carries its own copy.
_hash160_hex() {
	local hex; read -r hex
	printf '%s' "$hex" \
		| xxd -r -p \
		| openssl dgst -sha256 -binary \
		| openssl dgst -rmd160 -binary \
		| xxd -p -c 0 \
		| tr -d '\n'
	printf '\n'
}

# Emit a CompactSize varint as hex. Used by wallet:build when
# constructing the unsigned tx + PSBT inline. Same encoding as
# bip174's internal _emit_varint helper; per CLAUDE.md §5 each
# caller is self-contained.
_emit_varint() {
	local -i n=$1
	if (( n < 0xfd )); then
		printf '%02x' "$n"
	elif (( n <= 0xffff )); then
		printf 'fd%02x%02x' $((n & 0xff)) $(((n >> 8) & 0xff))
	elif (( n <= 0xffffffff )); then
		printf 'fe%02x%02x%02x%02x' \
			$((n & 0xff)) $(((n >> 8) & 0xff)) \
			$(((n >> 16) & 0xff)) $(((n >> 24) & 0xff))
	else
		error "tx build: varint > 2^32 not supported"
		return 1
	fi
}

command:psbt() {
	error "'psbt' was removed in 1.24.0; use 'bitcoin bip174'"
	return 1
}

command:wallet() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		new|ls|rm|help|derive|addresses|label|balance|broadcast|build|sign|send|index|tx|history|remote|push|pull) wallet:"$sub" "$@" ;;
		*)
			error "unknown wallet subcommand: '$sub'"
			wallet:help >&2
			return 2
			;;
	esac
}

# FEAT-036 (1.23.0): `bitcoin tx` object verb.
#
# Transaction-as-noun surface. build / sign / broadcast delegate
# to today's wallet:build / wallet:sign / wallet:broadcast (no
# rename in this PR; deprecation of the wallet:* aliases and
# `--utxo` coin-control follow in a separate PR per the
# ROADMAP-1.23.0 PR-sequencing).
#
# decode / finalize / extract pass-through to the canonical
# bip174 plugin (FEAT-035 Stream D) so users get the same
# byte-for-byte BIP-174 surface without remembering which name.
command:tx() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		build)     tx:build "$@" ;;
		sign)      tx:sign  "$@" ;;
		broadcast) tx:broadcast "$@" ;;
		bump)      tx:bump "$@" ;;
		decode)
			local libexec="${SELF_LIBEXEC:?command:tx: SELF_LIBEXEC must be set}"
			exec "$libexec/${SELF:-bitcoin}/bip174" decode "$@"
			;;
		finalize)
			local libexec="${SELF_LIBEXEC:?command:tx: SELF_LIBEXEC must be set}"
			exec "$libexec/${SELF:-bitcoin}/bip174" finalize "$@"
			;;
		extract)
			local libexec="${SELF_LIBEXEC:?command:tx: SELF_LIBEXEC must be set}"
			exec "$libexec/${SELF:-bitcoin}/bip174" extract "$@"
			;;
		help)
			cat <<-ENDHELP
			Usage: $SELF tx <subcommand>

			  build <wallet> <addr> <sats> [--fee-rate sat/vB]
			        Build an unsigned PSBT paying <sats> to <addr>.
			        Greedy largest-first UTXO selection; --fee-rate
			        overrides the backend estimate. (--utxo coin-
			        control flag lands in a follow-up PR.)
			  sign <wallet>
			        Read a PSBT (hex) from stdin, sign every input
			        the wallet's seed can sign, re-emit the PSBT.
			  decode
			        Read a PSBT (hex) from stdin; emit one TSV line
			        per key-value record. Passes through to bip174.
			  finalize
			        Promote PSBT_IN_PARTIAL_SIG to FINAL_SCRIPTWITNESS
			        per BIP-174 §Finalizer. Passes through to bip174.
			  extract
			        Emit the broadcastable BIP-141 segwit raw tx hex
			        from a finalised PSBT. Passes through to bip174.
			  broadcast <wallet>
			        Read raw tx hex from stdin; POST to the active
			        backend; print the txid.
			  bump <wallet> <txid> --rbf|--cpfp [--fee-rate sat/vB]
			        Fee-bump a wallet transaction. --rbf rebuilds the
			        cached tx spending the same inputs at a higher fee
			        (BIP-125). --cpfp spends a wallet-owned output of
			        <txid> into a high-fee child, pinning the parent.
			        Both compose tx build --utxo | tx sign | tx
			        broadcast. Requires the tx to be cached (run
			        'wallet index' first).
			  help
			        this message

			Pipeline: tx build | tx sign | tx finalize | tx extract |
			tx broadcast. The 'bitcoin wallet send' verb is the
			one-shot convenience composition.
			ENDHELP
			;;
		*)
			error "unknown tx subcommand: '$sub' (expected: build, sign, decode, finalize, extract, broadcast, help)"
			return 2
			;;
	esac
}

help:tx() {
	command:tx help
}

# FEAT-043: fee-bumping. Both modes compose the existing
# tx build --utxo | tx sign | bip174 finalize | bip174 extract |
# tx broadcast pipeline, so there's no bespoke PSBT surgery here.
#
#   --rbf   rebuild the cached tx spending the SAME inputs (pinned
#           via --utxo) and paying the SAME external output, but at
#           a higher fee-rate — the change output shrinks to absorb
#           the larger fee (BIP-125 Replace-By-Fee).
#   --cpfp  spend a wallet-owned output of the target tx into a
#           high-fee child paid back to a wallet address, lifting
#           the parent's effective package fee-rate.
tx:bump() {
	local wallet="" txid="" mode="" fee_rate=""
	while (( $# > 0 )); do
		case "$1" in
			--rbf)  mode=rbf;  shift ;;
			--cpfp) mode=cpfp; shift ;;
			--fee-rate)
				if [[ ! "${2:-}" =~ ^[1-9][0-9]*$ ]]; then
					error "tx bump: --fee-rate must be a positive integer (sat/vB), got '${2:-}'"
					return 2
				fi
				fee_rate="$2"; shift 2 ;;
			--*) error "tx bump: unknown flag '$1'"; return 2 ;;
			*)
				if   [ -z "$wallet" ]; then wallet="$1"
				elif [ -z "$txid" ];   then txid="$1"
				else error "tx bump: unexpected positional arg '$1'"; return 2
				fi
				shift ;;
		esac
	done
	if [ -z "$wallet" ] || [ -z "$txid" ]; then
		error "tx bump: usage: tx bump <wallet> <txid> --rbf|--cpfp [--fee-rate sat/vB]"
		return 2
	fi
	if [ -z "$mode" ]; then
		error "tx bump: one of --rbf or --cpfp is required"
		return 2
	fi
	local path; path="$(wallet:_path "$wallet")"
	if [ ! -d "$path" ]; then
		error "tx bump: no such wallet '$wallet' at $path"
		return 3
	fi
	local json="$path/transactions/$txid.json"
	if [ ! -s "$json" ]; then
		error "tx bump: '$txid' not cached (run 'wallet index $wallet' first)"
		return 4
	fi
	if ! command -v jq >/dev/null 2>&1; then
		error "tx bump: jq is required to parse the cached transaction"
		return 5
	fi
	case "$mode" in
		rbf)  tx:_bump_rbf  "$wallet" "$path" "$json" "$txid" "$fee_rate" ;;
		cpfp) tx:_bump_cpfp "$wallet" "$path" "$txid" "$fee_rate" ;;
	esac
}

# Pick the fee-rate for a bump: explicit --fee-rate wins; otherwise
# the active backend's 1-block (fastest) estimate; otherwise a
# sane floor. Echoed on stdout.
tx:_bump_fee_rate() {
	local explicit="$1"
	if [ -n "$explicit" ]; then
		printf '%s\n' "$explicit"
		return 0
	fi
	local est
	if est="$(backend:estimate-fee 1 2>/dev/null)" && [[ "$est" =~ ^[1-9][0-9]*$ ]]; then
		printf '%s\n' "$est"
	else
		warn "tx bump: backend estimate-fee unavailable; defaulting to 5 sat/vB"
		printf '5\n'
	fi
}

# RBF: rebuild paying the same external output from the same inputs
# at a higher fee-rate.
tx:_bump_rbf() {
	local wallet="$1" path="$2" json="$3" txid="$4" explicit_rate="$5"
	# BIP-125 opt-in: at least one input must signal (sequence <
	# 0xfffffffe == 4294967294). A cached tx without sequence data
	# can't be proven replaceable, so we refuse rather than guess.
	local signalled
	signalled="$(jq -r '[.vin[].sequence // 4294967295] | map(select(. < 4294967294)) | length' "$json" 2>/dev/null)"
	if [[ ! "$signalled" =~ ^[0-9]+$ ]] || (( signalled == 0 )); then
		error "tx bump --rbf: '$txid' does not signal BIP-125 replaceability (no input sequence < 0xfffffffe)"
		return 6
	fi
	# Identify the external payment output: the vout whose address is
	# NOT one of the wallet's derived addresses. Exactly one is
	# expected (a standard pay + change tx).
	local ledger="$path/addresses"
	local -a wallet_addrs=()
	if [ -f "$ledger" ]; then
		mapfile -t wallet_addrs < <(awk -F'\t' '{print $2}' "$ledger")
	fi
	# Build a jq filter selecting vouts whose address is not in the set.
	local addr_json
	addr_json="$(printf '%s\n' "${wallet_addrs[@]}" | jq -R . | jq -s .)"
	local payments
	payments="$(jq -c --argjson mine "$addr_json" \
		'[.vout[] | select(.scriptpubkey_address as $a | ($mine | index($a)) | not) | {addr: .scriptpubkey_address, value: .value}]' \
		"$json" 2>/dev/null)"
	local n_pay; n_pay="$(printf '%s' "$payments" | jq -r 'length' 2>/dev/null)"
	if [[ ! "$n_pay" =~ ^[0-9]+$ ]] || (( n_pay != 1 )); then
		error "tx bump --rbf: expected exactly one external output, found ${n_pay:-0} (multi-recipient / consolidation bumps not supported)"
		return 7
	fi
	local pay_addr pay_value
	pay_addr="$(printf '%s' "$payments" | jq -r '.[0].addr')"
	pay_value="$(printf '%s' "$payments" | jq -r '.[0].value')"
	# Inputs: each vin's txid:vout, pinned via --utxo.
	local -a utxo_args=()
	local op
	while IFS= read -r op; do
		[ -n "$op" ] && utxo_args+=( --utxo "$op" )
	done < <(jq -r '.vin[] | "\(.txid):\(.vout)"' "$json" 2>/dev/null)
	if (( ${#utxo_args[@]} == 0 )); then
		error "tx bump --rbf: cached tx has no decodable inputs (vin txid/vout missing)"
		return 8
	fi
	local rate; rate="$(tx:_bump_fee_rate "$explicit_rate")"
	info "tx bump --rbf: rebuilding $txid -> pay $pay_value sat to $pay_addr at $rate sat/vB"
	tx:_bump_pipeline "$wallet" "$pay_addr" "$pay_value" "$rate" "${utxo_args[@]}"
}

# CPFP: spend a wallet-owned output of the target into a high-fee
# child, paid back to one of the wallet's own addresses.
tx:_bump_cpfp() {
	local wallet="$1" path="$2" txid="$3" explicit_rate="$4"
	# Find an unspent wallet output of <txid> via the utxo verb.
	local child_op child_val
	read -r child_op child_val < <(
		utxo:ls "$wallet" 2>/dev/null \
			| awk -F'\t' -v t="$txid" '$1 == t { print $1":"$2, $4; exit }'
	)
	if [ -z "$child_op" ]; then
		error "tx bump --cpfp: no spendable wallet output of '$txid' found (already spent, or the tx paid out entirely — use --rbf)"
		return 9
	fi
	# Self-send target: the wallet's first derived address.
	local self_addr
	self_addr="$(awk -F'\t' 'NR==1{print $2}' "$path/addresses" 2>/dev/null)"
	if [ -z "$self_addr" ]; then
		error "tx bump --cpfp: wallet '$wallet' has no derived address to receive the child output"
		return 10
	fi
	local rate; rate="$(tx:_bump_fee_rate "$explicit_rate")"
	# Pay a dust-ish amount back to ourselves; the high fee-rate over
	# the single pinned input is what does the work. tx build sizes
	# change + fee from the rate.
	local pay=546
	info "tx bump --cpfp: spending $child_op ($child_val sat) into a $rate sat/vB child to $self_addr"
	tx:_bump_pipeline "$wallet" "$self_addr" "$pay" "$rate" --utxo "$child_op"
}

# Shared build|sign|finalize|extract|broadcast pipeline for both
# bump modes. Prints the broadcast txid.
tx:_bump_pipeline() {
	local wallet="$1" addr="$2" sats="$3" rate="$4"; shift 4
	local -a utxo_args=( "$@" )
	local libexec="${SELF_LIBEXEC:?tx bump: SELF_LIBEXEC must be set}"
	local psbt signed final raw
	psbt="$(tx:build "$wallet" "$addr" "$sats" --fee-rate "$rate" "${utxo_args[@]}")" \
		|| { error "tx bump: build failed"; return 11; }
	signed="$(printf '%s\n' "$psbt" | tx:sign "$wallet")" \
		|| { error "tx bump: sign failed"; return 12; }
	final="$(printf '%s\n' "$signed" | "$libexec/${SELF:-bitcoin}/bip174" finalize)" \
		|| { error "tx bump: finalize failed"; return 13; }
	raw="$(printf '%s\n' "$final" | "$libexec/${SELF:-bitcoin}/bip174" extract)" \
		|| { error "tx bump: extract failed"; return 14; }
	printf '%s\n' "$raw" | tx:broadcast "$wallet"
}

# FEAT-037 (1.23.0): `bitcoin utxo` object verb.
#
# UTXO-as-noun surface for coin control. Initial PR ships ls /
# freeze / unfreeze; `utxo select` and the `tx build`
# refuse-frozen integration follow in a separate PR per the
# ROADMAP-1.23.0 PR-sequencing (keeps each diff focused).
command:utxo() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		ls)        utxo:ls       "$@" ;;
		freeze)    utxo:freeze   "$@" ;;
		unfreeze)  utxo:unfreeze "$@" ;;
		select)    utxo:select   "$@" ;;
		help)
			cat <<-ENDHELP
			Usage: $SELF utxo <subcommand>

			  ls <wallet> [--include-frozen]
			        List unspent outputs across every derived address
			        of <wallet> as TSV:
			          txid TAB vout TAB address TAB amount_sat TAB frozen
			        Frozen rows are excluded by default; --include-frozen
			        keeps them in the output marked with a 'Y' in the
			        frozen column.
			  freeze <wallet> <txid:vout> [--reason <text>]
			        Record the outpoint in the wallet's frozen.tsv with
			        an optional reason and a Unix timestamp. Once frozen,
			        a UTXO is hidden from 'utxo ls' (default) and will
			        be refused by 'tx build' (FEAT-036 follow-up).
			  unfreeze <wallet> <txid:vout>
			        Remove the outpoint from the wallet's frozen.tsv.
			        Restores selectability.
			  select <wallet> --target <sats> [--strategy greedy|branch-and-bound]
			        Apply the named UTXO-selection strategy to <wallet>'s
			        candidate UTXOs (skipping frozen ones); emit the
			        chosen outpoints as TSV (txid, vout, value_sat). Pure
			        computation — no transaction is built. Useful for
			        previewing selection or feeding 'tx build --utxo'.
			  help
			        this message

			Frozen state lives in
			  ~/.local/var/bitcoin/wallets/<wallet>/frozen.tsv
			and pushes/pulls with the wallet repo (per FEAT-011's
			git-as-wallet-store model).
			ENDHELP
			;;
		*)
			error "unknown utxo subcommand: '$sub' (expected: ls, freeze, unfreeze, help)"
			return 2
			;;
	esac
}

help:utxo() {
	command:utxo help
}

# Path to the wallet's frozen-UTXO ledger. One file per wallet.
# Format: TSV with 3 columns — outpoint, reason, unix-timestamp.
utxo:_frozen_file() {
	local wallet="$1"
	local path; path="$(wallet:_path "$wallet")"
	printf '%s\n' "$path/frozen.tsv"
}

# Return 0 if <outpoint> is currently frozen in <wallet>.
utxo:_is_frozen() {
	local wallet="$1" outpoint="$2"
	local file; file="$(utxo:_frozen_file "$wallet")"
	[ -f "$file" ] || return 1
	awk -F'\t' -v op="$outpoint" '$1 == op { found=1; exit } END { exit !found }' "$file"
}

# Print the recorded freeze reason for <outpoint> on stdout, or
# nothing if the outpoint isn't frozen / has no reason set. Used
# by tx:build's frozen-UTXO skip warn line.
utxo:_freeze_reason() {
	local wallet="$1" outpoint="$2"
	local file; file="$(utxo:_frozen_file "$wallet")"
	[ -f "$file" ] || return 0
	awk -F'\t' -v op="$outpoint" '$1 == op { print $2; exit }' "$file"
}

utxo:ls() {
	local include_frozen=0
	local wallet=""
	while (( $# > 0 )); do
		case "$1" in
			--include-frozen) include_frozen=1; shift ;;
			--*)              error "utxo ls: unknown flag '$1'"; return 2 ;;
			*)
				if [ -z "$wallet" ]; then wallet="$1"
				else error "utxo ls: unexpected positional arg '$1'"; return 2
				fi
				shift
				;;
		esac
	done
	if [ -z "$wallet" ]; then
		error "utxo ls: usage: utxo ls <wallet> [--include-frozen]"
		return 2
	fi
	local path; path="$(wallet:_path "$wallet")"
	if [ ! -d "$path" ]; then
		error "utxo ls: no such wallet '$wallet' at $path"
		return 3
	fi
	local ledger="$path/addresses"
	if [ ! -f "$ledger" ]; then
		error "utxo ls: no addresses ledger at $ledger"
		return 4
	fi
	local frozen_file; frozen_file="$(utxo:_frozen_file "$wallet")"
	local addr utxo_json
	while IFS=$'\t' read -r _idx addr _label; do
		[ -z "$addr" ] && continue
		if ! utxo_json="$(backend:get-address-utxos "$addr")"; then
			warn "utxo ls: backend get-utxos failed for $addr (continuing)"
			continue
		fi
		# Parse the per-UTXO array. Each entry: { txid, vout, value }.
		# jq is in .rpk/depends and on CI.
		local jq_out
		jq_out="$(
			printf '%s' "$utxo_json" \
				| jq -r --arg addr "$addr" \
					'.[] | [.txid, (.vout|tostring), $addr, (.value|tostring)] | @tsv' \
				2>/dev/null
		)" || continue
		while IFS=$'\t' read -r txid vout addr_out value; do
			[ -z "$txid" ] && continue
			local op="$txid:$vout"
			local frozen=N
			if [ -f "$frozen_file" ] && awk -F'\t' -v o="$op" '$1==o{e=1; exit} END{exit !e}' "$frozen_file"; then
				frozen=Y
				(( !include_frozen )) && continue
			fi
			printf '%s\t%s\t%s\t%s\t%s\n' "$txid" "$vout" "$addr_out" "$value" "$frozen"
		done <<< "$jq_out"
	done < "$ledger"
}

utxo:freeze() {
	local wallet="" outpoint="" reason=""
	while (( $# > 0 )); do
		case "$1" in
			--reason) reason="$2"; shift 2 ;;
			--*)      error "utxo freeze: unknown flag '$1'"; return 2 ;;
			*)
				if   [ -z "$wallet" ];   then wallet="$1"
				elif [ -z "$outpoint" ]; then outpoint="$1"
				else error "utxo freeze: unexpected positional arg '$1'"; return 2
				fi
				shift
				;;
		esac
	done
	if [ -z "$wallet" ] || [ -z "$outpoint" ]; then
		error "utxo freeze: usage: utxo freeze <wallet> <txid:vout> [--reason <text>]"
		return 2
	fi
	if [[ ! "$outpoint" =~ ^[[:xdigit:]]+:[0-9]+$ ]]; then
		error "utxo freeze: <outpoint> must look like '<txid>:<vout>' (got '$outpoint')"
		return 3
	fi
	if [[ "$reason" == *$'\t'* ]] || [[ "$reason" == *$'\n'* ]]; then
		error "utxo freeze: <reason> must not contain tabs or newlines (storage is TSV)"
		return 4
	fi
	local path; path="$(wallet:_path "$wallet")"
	if [ ! -d "$path" ]; then
		error "utxo freeze: no such wallet '$wallet' at $path"
		return 5
	fi
	local file; file="$(utxo:_frozen_file "$wallet")"
	local ts; ts="$(date +%s)"
	# Idempotent: if the outpoint is already frozen, update the reason.
	[ -f "$file" ] || : > "$file"
	local tmp="$file.tmp"
	awk -F'\t' -v o="$outpoint" '$1 != o { print }' "$file" > "$tmp"
	printf '%s\t%s\t%s\n' "$outpoint" "$reason" "$ts" >> "$tmp"
	mv "$tmp" "$file"
	(
		cd "$path"
		git add frozen.tsv
		if ! git diff --cached --quiet 2>/dev/null; then
			git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			    -c commit.gpgsign=false \
				commit -q -m "utxo freeze: $wallet $outpoint${reason:+ (reason: \"$reason\")}"
		fi
	) || { error "utxo freeze: commit failed"; return 6; }
	info "frozen $outpoint in $wallet"
}

utxo:unfreeze() {
	local wallet="${1:-}" outpoint="${2:-}"
	if [ -z "$wallet" ] || [ -z "$outpoint" ]; then
		error "utxo unfreeze: usage: utxo unfreeze <wallet> <txid:vout>"
		return 2
	fi
	if [[ ! "$outpoint" =~ ^[[:xdigit:]]+:[0-9]+$ ]]; then
		error "utxo unfreeze: <outpoint> must look like '<txid>:<vout>' (got '$outpoint')"
		return 3
	fi
	local path; path="$(wallet:_path "$wallet")"
	if [ ! -d "$path" ]; then
		error "utxo unfreeze: no such wallet '$wallet' at $path"
		return 4
	fi
	local file; file="$(utxo:_frozen_file "$wallet")"
	if [ ! -f "$file" ]; then
		info "$wallet has no frozen.tsv; nothing to unfreeze"
		return 0
	fi
	if ! awk -F'\t' -v o="$outpoint" '$1==o{e=1; exit} END{exit !e}' "$file"; then
		info "$outpoint is not frozen in $wallet"
		return 0
	fi
	local tmp="$file.tmp"
	awk -F'\t' -v o="$outpoint" '$1 != o { print }' "$file" > "$tmp"
	mv "$tmp" "$file"
	(
		cd "$path"
		git add frozen.tsv
		if ! git diff --cached --quiet 2>/dev/null; then
			git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			    -c commit.gpgsign=false \
				commit -q -m "utxo unfreeze: $wallet $outpoint"
		fi
	) || { error "utxo unfreeze: commit failed"; return 5; }
	info "unfrozen $outpoint in $wallet"
}

# FEAT-037 AC #5: utxo select — pure-computation selection
# emitter. Pulls the wallet's candidate UTXOs (skipping frozen),
# applies the chosen strategy, and emits the picked outpoints as
# TSV. No transaction built; pair with `tx build --utxo` for the
# actual PSBT.
#
# greedy:           largest-first accumulation until sum >= target.
# branch-and-bound: bitmask enumeration over subsets, picks the
#                   smallest subset that sums *exactly* to target;
#                   falls back to greedy + a warn line when no
#                   exact match exists OR when n > 20 (the bash
#                   bitmask enumeration's practical cap; Bitcoin
#                   Core's DFS-with-pruning is more scalable but
#                   not in scope here).
utxo:select() {
	local wallet="" target="" strategy="greedy"
	while (( $# > 0 )); do
		case "$1" in
			--target)
				if [ -z "${2:-}" ]; then
					error "utxo select: --target requires an argument"
					return 2
				fi
				target="$2"; shift 2 ;;
			--strategy)
				if [ -z "${2:-}" ]; then
					error "utxo select: --strategy requires an argument"
					return 2
				fi
				strategy="$2"; shift 2 ;;
			--*) error "utxo select: unknown flag '$1'"; return 2 ;;
			*)
				if [ -z "$wallet" ]; then wallet="$1"
				else error "utxo select: unexpected positional arg '$1'"; return 2
				fi
				shift ;;
		esac
	done
	if [ -z "$wallet" ]; then
		error "utxo select: usage: utxo select <wallet> --target <sats> [--strategy greedy|branch-and-bound]"
		return 2
	fi
	if [ -z "$target" ]; then
		error "utxo select: --target <sats> required"
		return 2
	fi
	if [[ ! "$target" =~ ^[1-9][0-9]*$ ]]; then
		error "utxo select: --target must be a positive integer (sats), got '$target'"
		return 3
	fi
	case "$strategy" in
		greedy|branch-and-bound|bnb) ;;
		*)
			error "utxo select: --strategy must be 'greedy' or 'branch-and-bound', got '$strategy'"
			return 4 ;;
	esac

	local path; path="$(wallet:_path "$wallet")"
	if [ ! -d "$path" ]; then
		error "utxo select: no such wallet '$wallet' at $path"
		return 5
	fi
	local ledger="$path/addresses"
	if [ ! -s "$ledger" ]; then
		error "utxo select: wallet '$wallet' has no derived addresses"
		return 6
	fi

	# Collect candidate (unfrozen) UTXOs.
	local -a u_txid=() u_vout=() u_value=()
	local _idx addr _label utxo_json txid vout value
	while IFS=$'\t' read -r _idx addr _label; do
		[ -z "$addr" ] && continue
		if ! utxo_json="$(backend:get-address-utxos "$addr" 2>/dev/null)"; then
			warn "utxo select: backend get-utxos failed for $addr (continuing)"
			continue
		fi
		while IFS=$'\t' read -r txid vout value; do
			[ -z "$txid" ] && continue
			local _op="$txid:$vout"
			utxo:_is_frozen "$wallet" "$_op" && continue
			u_txid+=( "$txid" )
			u_vout+=( "$vout" )
			u_value+=( "$value" )
		done < <(printf '%s' "$utxo_json" | jq -r '.[] | [.txid, .vout, .value] | @tsv' 2>/dev/null)
	done < "$ledger"

	local -i n=${#u_txid[@]}
	if (( n == 0 )); then
		error "utxo select: no candidate UTXOs (all spent / all frozen?)"
		return 7
	fi

	# Try branch-and-bound first if requested.
	if [ "$strategy" = "branch-and-bound" ] || [ "$strategy" = "bnb" ]; then
		if (( n > 20 )); then
			warn "utxo select: $n UTXOs exceeds the bitmask cap (20); falling back to greedy"
		else
			local -i best_mask=0 best_count=999 mask sum count i
			for ((mask=1; mask<(1<<n); mask++)); do
				sum=0; count=0
				for ((i=0; i<n; i++)); do
					if (( mask & (1<<i) )); then
						(( sum += u_value[i], count++ ))
					fi
				done
				if (( sum == target )) && (( count < best_count )); then
					best_mask=$mask
					best_count=$count
				fi
			done
			if (( best_count != 999 )); then
				for ((i=0; i<n; i++)); do
					if (( best_mask & (1<<i) )); then
						printf '%s\t%s\t%s\n' "${u_txid[i]}" "${u_vout[i]}" "${u_value[i]}"
					fi
				done
				return 0
			fi
			warn "utxo select: no exact-match subset found; falling back to greedy"
		fi
	fi

	# Greedy: sort by value desc, accumulate until sum >= target.
	local -a sorted_idx
	mapfile -t sorted_idx < <(
		for ((i=0; i<n; i++)); do
			printf '%s\t%s\n' "${u_value[i]}" "$i"
		done | sort -t$'\t' -k1,1 -rn | cut -f2
	)
	local -i total=0
	local idx
	for idx in "${sorted_idx[@]}"; do
		printf '%s\t%s\t%s\n' "${u_txid[idx]}" "${u_vout[idx]}" "${u_value[idx]}"
		(( total += u_value[idx] ))
		(( total >= target )) && return 0
	done
	error "utxo select: insufficient unfrozen UTXOs (sum=$total sat < target=$target sat)"
	return 8
}

# FEAT-038 shorthand. `bitcoin tax label <wallet> <outpoint> --as
# <category>` is byte-identical to `bitcoin wallet label <wallet>
# <outpoint> --tax <category>`. Same backing code; just a more
# discoverable entry point for the tax workflow. report-de
# (FEAT-039) and price (FEAT-040) subcommands land in 1.25.0.
command:tax() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		label)
			# Rewrite `tax label <wallet> <outpoint> --as <cat>` →
			# `wallet label <wallet> <outpoint> --tax <cat>`. Forward
			# any other flags unchanged.
			local -a args=()
			local a
			for a in "$@"; do
				if [ "$a" = "--as" ]; then
					args+=( --tax )
				else
					args+=( "$a" )
				fi
			done
			wallet:label "${args[@]}"
			;;
		help)
			cat <<-ENDHELP
			Usage: $SELF tax <subcommand>

			  label <wallet> <outpoint> --as <category> [--note <text>]
			        Shorthand for 'bitcoin wallet label <wallet> <outpoint>
			        --tax <category> [--note <text>]'. Persists the
			        tax-category tag on a transaction / utxo / address.

			Valid categories (FEAT-038 closed taxonomy):
			  $(wallet:_tax_categories_str)

			Reporting (FEAT-039 report-de, FEAT-040 price oracle) lands
			in 1.25.0. This release ships only the labeling vocabulary.
			ENDHELP
			;;
		*)
			error "unknown tax subcommand: '$sub' (expected: label, help)"
			return 2
			;;
	esac
}

help:tax() {
	command:tax help
}

# FEAT-040: BTC/EUR historical price oracle (local cache).
#
# A deterministic, offline-after-warm price source for the
# 1.25.0 German tax report (FEAT-039). `price fetch` is the only
# verb that touches the network; `price get` / `status` read the
# cache only, so a report run is reproducible and auditable.
#
# Cache: $HOME/.bitcoin/cache/price/btc-eur.tsv — global per
# machine, shared across wallets. Three TSV columns:
# date (ISO 8601 UTC), eur_per_btc, source. Append-only; the
# most recent row per date wins.
: "${BITCOIN_COINGECKO_URL:=https://api.coingecko.com}"

price:_cache_file() {
	printf '%s\n' "${BITCOIN_PRICE_CACHE:-$HOME/.bitcoin/cache/price/btc-eur.tsv}"
}

price:_source_file() {
	printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/bitcoin/price-source"
}

# Active source: BITCOIN_PRICE_SOURCE env, then the config file,
# then the coingecko default.
price:_active_source() {
	if [ -n "${BITCOIN_PRICE_SOURCE:-}" ]; then
		printf '%s\n' "$BITCOIN_PRICE_SOURCE"
		return
	fi
	local cfg; cfg="$(price:_source_file)"
	if [ -s "$cfg" ]; then cat "$cfg"; else echo coingecko; fi
}

# Validate an ISO-8601 date (YYYY-MM-DD) that the system `date`
# accepts. Echoes nothing; returns non-zero on a bad date.
price:_valid_date() {
	[[ "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || return 1
	date -u -d "$1" +%F >/dev/null 2>&1
}

command:price() {
	local sub="${1:-help}"
	shift 2>/dev/null || true
	case "$sub" in
		get)    price:get    "$@" ;;
		fetch)  price:fetch  "$@" ;;
		source) price:source "$@" ;;
		status) price:status "$@" ;;
		help)
			cat <<-ENDHELP
			Usage: $SELF price <subcommand>

			  get <YYYY-MM-DD>      EUR per BTC for the date, read from
			                       the local cache. Errors (pointing at
			                       'price fetch') if the date isn't cached
			                       — reports must be reproducible, so there
			                       are no silent network fetches here.
			  fetch [--from D] [--to D]
			                       Populate the cache from the active
			                       source for the date range (default:
			                       today). Idempotent — only missing dates
			                       are fetched. The ONLY networked verb.
			  source [--set coingecko|kraken|csv://<path>]
			                       View or set the price source. Default
			                       coingecko. The 'price of the day' is the
			                       00:00 UTC snapshot the source reports.
			  status               Cache freshness + coverage.
			  help                 this message

			Cache: $(price:_cache_file)
			(global per machine; shared across wallets; not in any
			wallet's git repo).
			ENDHELP
			;;
		*)
			error "unknown price subcommand: '$sub' (expected: get, fetch, source, status, help)"
			return 2
			;;
	esac
}

help:price() {
	command:price help
}

price:get() {
	local date="${1:-}"
	if [ -z "$date" ]; then
		error "price get: usage: price get <YYYY-MM-DD>"
		return 2
	fi
	if ! price:_valid_date "$date"; then
		error "price get: '$date' is not a valid ISO-8601 date (YYYY-MM-DD)"
		return 3
	fi
	local cache; cache="$(price:_cache_file)"
	if [ ! -s "$cache" ]; then
		warn "price get: cache is empty; run 'bitcoin price fetch --from $date'"
		return 4
	fi
	# Most recent row per date wins (append-only with later revisions).
	local val
	val="$(awk -F'\t' -v d="$date" '$1==d{v=$2} END{if(v!="")print v}' "$cache")"
	if [ -z "$val" ]; then
		warn "price get: no cached price for $date; run 'bitcoin price fetch --from $date --to $date'"
		return 5
	fi
	printf '%s\n' "$val"
}

price:source() {
	if [ "${1:-}" = "--set" ]; then
		local src="${2:-}"
		case "$src" in
			coingecko|kraken) ;;
			csv://*) ;;
			"") error "price source --set: a source is required (coingecko|kraken|csv://<path>)"; return 2 ;;
			*) error "price source --set: unknown source '$src' (use coingecko, kraken, or csv://<path>)"; return 3 ;;
		esac
		local cfg; cfg="$(price:_source_file)"
		mkdir -p "$(dirname "$cfg")" || { error "price source: cannot mkdir $(dirname "$cfg")"; return 4; }
		printf '%s\n' "$src" > "$cfg"
		info "price source set to: $src"
		return 0
	fi
	if [ "${1:-}" = "--help" ]; then
		cat <<-ENDHELP
		price source [--set coingecko|kraken|csv://<path>]

		The 'price of the day' convention: the 00:00 UTC snapshot the
		source reports for the requested date. CoinGecko's historical
		endpoint returns that snapshot directly; kraken / csv rows snap
		to the same 00:00 UTC daily mark for consistency.
		ENDHELP
		return 0
	fi
	# View.
	price:_active_source
}

# Append one cached row if the date isn't already present.
# Returns 0 if a row was written, 1 if it was a cache hit.
price:_cache_put() {
	local date="$1" eur="$2" source="$3" cache="$4"
	if awk -F'\t' -v d="$date" '$1==d{f=1} END{exit !f}' "$cache" 2>/dev/null; then
		return 1   # already cached
	fi
	printf '%s\t%s\t%s\n' "$date" "$eur" "$source" >> "$cache"
	return 0
}

# Fetch one date's EUR/BTC from the coingecko historical endpoint.
# Echoes the integer-or-decimal EUR price; non-zero on failure.
price:_fetch_coingecko() {
	local date="$1"
	# coingecko wants DD-MM-YYYY.
	local url="$BITCOIN_COINGECKO_URL/api/v3/coins/bitcoin/history?date=${date:8:2}-${date:5:2}-${date:0:4}&localization=false"
	local out
	if ! out="$(curl -sfL "$url")"; then
		error "price fetch: coingecko GET $url failed (curl exit $?)"
		return 1
	fi
	local eur
	eur="$(printf '%s' "$out" | jq -r '.market_data.current_price.eur // empty' 2>/dev/null)"
	if [[ ! "$eur" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
		error "price fetch: coingecko response missing market_data.current_price.eur for $date"
		return 2
	fi
	printf '%s\n' "$eur"
}

price:fetch() {
	local from="" to=""
	while (( $# > 0 )); do
		case "$1" in
			--from) from="$2"; shift 2 ;;
			--to)   to="$2";   shift 2 ;;
			--*) error "price fetch: unknown flag '$1'"; return 2 ;;
			*) error "price fetch: unexpected positional arg '$1'"; return 2 ;;
		esac
	done
	[ -z "$from" ] && from="$(date -u +%F)"
	[ -z "$to" ] && to="$from"
	if ! price:_valid_date "$from" || ! price:_valid_date "$to"; then
		error "price fetch: --from / --to must be valid ISO-8601 dates (YYYY-MM-DD)"
		return 3
	fi
	if [[ "$from" > "$to" ]]; then
		error "price fetch: --from ($from) is after --to ($to)"
		return 3
	fi
	if ! command -v jq >/dev/null 2>&1; then
		error "price fetch: jq is required to parse price responses"
		return 4
	fi
	local cache; cache="$(price:_cache_file)"
	mkdir -p "$(dirname "$cache")" || { error "price fetch: cannot mkdir $(dirname "$cache")"; return 5; }
	[ -f "$cache" ] || : > "$cache"
	local source; source="$(price:_active_source)"

	# csv:// source: read the local file, no network. CSV columns:
	# date, eur_per_btc, (ignored). Only rows within [from,to] and
	# not already cached are appended.
	if [[ "$source" == csv://* ]]; then
		local csvpath="${source#csv://}"
		if [ ! -s "$csvpath" ]; then
			error "price fetch: csv source '$csvpath' is missing or empty"
			return 6
		fi
		local -i added=0
		local d eur _rest
		while IFS=, read -r d eur _rest; do
			price:_valid_date "$d" || continue
			[[ "$d" < "$from" || "$d" > "$to" ]] && continue
			if price:_cache_put "$d" "$eur" "csv" "$cache"; then (( added++ )); fi
		done < "$csvpath"
		info "price fetch: added $added row(s) from csv ($csvpath)"
		return 0
	fi

	if [ "$source" = "kraken" ]; then
		error "price fetch: kraken source not implemented in this release (use coingecko or csv://)"
		return 7
	fi

	# coingecko (default): one request per missing date, paced.
	local -i added=0 hit=0
	local d eur
	d="$from"
	while [[ "$d" < "$to" || "$d" == "$to" ]]; do
		if awk -F'\t' -v dd="$d" '$1==dd{f=1} END{exit !f}' "$cache" 2>/dev/null; then
			(( hit++ ))
		else
			if eur="$(price:_fetch_coingecko "$d")"; then
				price:_cache_put "$d" "$eur" "coingecko" "$cache" && (( added++ ))
			else
				warn "price fetch: skipping $d (fetch failed)"
			fi
		fi
		d="$(date -u -d "$d + 1 day" +%F)"
	done
	info "price fetch: added $added row(s); $hit already cached"
}

price:status() {
	local cache; cache="$(price:_cache_file)"
	if [ ! -s "$cache" ]; then
		echo "cache: empty ($cache)"
		return 0
	fi
	local -i rows; rows="$(grep -c . "$cache")"
	local first last
	first="$(awk -F'\t' 'NR==1{print $1}' "$cache")"
	last="$(awk -F'\t' '{d=$1} END{print d}' "$cache")"
	printf 'cache: %s\nrows: %d\ncoverage: %s .. %s\nsource: %s\n' \
		"$cache" "$rows" "$first" "$last" "$(price:_active_source)"
}

# FEAT-035 alias removal (1.24.0): the deprecated standalone
# `bitcoin mnemonic-to-seed` was promised removal in 1.24.0
# (the warn-and-forward shim under libexec/bitcoin/ has been
# deleted). This command:* shim takes priority over the
# dispatcher's libexec-fallback so users see a clear "removed"
# error rather than `bitcoin help` falling through.
command:mnemonic-to-seed() {
	error "'mnemonic-to-seed' was removed in 1.24.0; use 'bitcoin bip39 mnemonic-to-seed'"
	return 1
}

help:wallet() {
	wallet:help
	cite 39 "Mnemonic seed phrases"
}

wallet:help() {
	cat <<-ENDHELP
	Usage: $SELF wallet <subcommand> [args]

	  new <name>        create a new wallet at $(wallet:_root)/<name>
	                    generates a BIP-39 mnemonic and stores it via
	                    'secret put <name>/seed'
	  ls                list existing wallets
	  rm [-f] <name>    remove a wallet (-f also removes secret/<name>/seed)
	  derive <name>     derive next BIP-84 receive address; append to ledger
	  addresses <name>  list every derived address (with index + label)
	  label <kind:tx|utxo|addr> <name> <key> <text>
	                    set/clear a label. Kinds:
	                      tx   <txid>          → labels/tx
	                      utxo <txid>:<vout>   → labels/utxo
	                      addr <addr>          → addresses column
	                    Empty <text> clears the entry. The compat form
	                    'label <name> <addr> <text>' (no kind prefix) is
	                    treated as 'label addr ...' for pre-1.19.0 callers.
	  balance <name>    sum UTXO values for all derived addresses via the
	                    active backend (skills/automerging.md §3b -- mempool)
	  build <name> <addr> <sats> [--fee-rate sat/vB]
	                    greedy-select wallet UTXOs, build an unsigned tx that
	                    pays <sats> to <addr>, wrap as a PSBT, print as hex.
	                    Without --fee-rate, reads 'backend estimate-fee 3';
	                    falls back to 1 sat/vB on backend failure.
	                    P2WPKH/P2WSH outputs only.
	  sign <name>       read a PSBT (hex) from stdin, derive a private key
	                    for every address in the wallet's ledger, pipe the
	                    PSBT through 'psbt sign' for each. Inputs the keys
	                    can't sign pass through unmodified.
	  send <name> <addr> <sats> [--fee-rate sat/vB] [--mainnet]
	                    end-to-end: build | sign | psbt finalize | psbt extract
	                    | broadcast. Prints the txid the backend returned.
	                    --mainnet is required when the wallet's config says
	                    network=mainnet; ignored on other networks.
	  broadcast <name>  POST raw-tx hex from stdin to the active backend
	  index <name>      for every address in the wallet's ledger, fetch
	                    every tx via 'backend get-address-txs' and cache
	                    the raw hex + decoded JSON under
	                    <wallet>/transactions/<txid>.{hex,json}. Updates
	                    the history ledger and commits. Idempotent.
	  tx <name> <txid>  print the cached transactions/<txid>.hex (+.json)
	                    without re-querying the backend.
	  history <name> [--label <pattern>]
	                    list the wallet's history ledger
	                    (txid, height, direction, net sats); with
	                    --label, filter rows whose tx-label matches
	                    <pattern> (case-insensitive substring)
	  remote add <name> <remote> <url>
	                    set/replace a git remote on the wallet repo
	  push <name> [<remote>]
	                    git push the wallet (default remote: origin)
	  pull <name> [<remote>]
	                    git pull --rebase the wallet (default remote: origin)
	  help              this message

	A wallet is a git repository. The seed phrase is held by 'secret',
	not by this repo, so 'bitcoin wallet push' (FEAT-011) is safe by
	construction.
	ENDHELP
}

# ---------------------------------------------------------------------------
# FEAT-013 helpers
# ---------------------------------------------------------------------------

# Read the next derivation index from the ledger (0-based; line count).
wallet:_next_index() {
	local ledger="$1"
	if [ -s "$ledger" ]; then
		wc -l < "$ledger" | tr -d ' '
	else
		echo 0
	fi
}

# Derive the BIP-84 receive address at <name>'s index <i> via the
# mnemonic in secret. Returns just the bc1q… address on stdout.
wallet:_derive_address() {
	local name="$1" idx="$2"
	if ! command -v secret >/dev/null 2>&1; then
		error "wallet derive: 'secret' not in PATH (cannot read seed)"
		return 5
	fi
	# Resolve libexec for the bip32/bip13/bip39 plugins.
	# When sourced, SELF_LIBEXEC must be set by caller; when dispatched,
	# the parent bin/bitcoin sets it.
	local libexec="${SELF_LIBEXEC:?wallet derive: SELF_LIBEXEC must be set}"
	local pubkey
	pubkey="$(
		secret get "$name/seed" |
		"$libexec/${SELF:-bitcoin}/bip39" mnemonic-to-seed |
		"$libexec/${SELF:-bitcoin}/bip32" create 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip13" base58-decode 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip32" derive "m/84h/0h/0h/0/$idx/N" 2>/dev/null |
		tail -c 33 |
		basenc --base16 -w0 |
		tr A-F a-f
	)"
	if [[ ! "$pubkey" =~ ^0[23][[:xdigit:]]{64}$ ]]; then
		error "wallet derive: pubkey derivation produced unexpected output '$pubkey'"
		return 6
	fi
	p2wpkh "$pubkey"
}

wallet:derive() {
	# FEAT-044: --walk [--gap N] turns the single-index derive into a
	# BIP-44 gap-limit scan. Without --walk the behaviour is unchanged
	# (derive the next index, commit, print the address).
	local name="" walk=0
	local -i gap=20
	while (( $# > 0 )); do
		case "$1" in
			--walk) walk=1; shift ;;
			--gap)
				if [[ ! "${2:-}" =~ ^[0-9]+$ ]]; then
					error "wallet derive: --gap requires a non-negative integer (got '${2:-}')"
					return 2
				fi
				gap="$2"; shift 2 ;;
			--*) error "wallet derive: unknown flag '$1'"; return 2 ;;
			*)
				if [ -z "$name" ]; then name="$1"
				else error "wallet derive: unexpected positional arg '$1'"; return 2
				fi
				shift ;;
		esac
	done
	if [ -z "$name" ]; then
		error "wallet derive: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet derive: no such wallet '$name' at $path"
		return 3
	fi
	local ledger="$path/addresses"
	[ -f "$ledger" ] || : > "$ledger"

	# --gap 0 disables the walk (acts like a plain derive).
	if (( walk && gap > 0 )); then
		wallet:_derive_walk "$name" "$path" "$ledger" "$gap"
		return $?
	fi

	local idx; idx="$(wallet:_next_index "$ledger")"
	local addr; addr="$(wallet:_derive_address "$name" "$idx")" || return $?
	# Append as: <index><tab><address><tab><label>  (label initially empty)
	printf '%d\t%s\t\n' "$idx" "$addr" >> "$ledger"
	(
		cd "$path"
		git add addresses
		# commit.gpgsign=false: wallet-internal commits run on the
		# user's wallet repo, not on this project's repo. We don't
		# assume the user has signing keys set up for their wallet.
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			commit -q -m "wallet derive: $name/$idx -> $addr"
	) || { error "wallet derive: commit failed"; return 7; }
	printf '%s\n' "$addr"
}

# FEAT-044 gap-limit scan. Derives forward from the ledger top,
# probes each address's on-chain history via the active backend,
# and appends addresses that have history. Stops after <gap>
# consecutive empties. One git commit for all discovered rows;
# no-op (no commit) if nothing is discovered. Prints a summary
# line on stdout.
#
# mempool.space rate-limits ~1 req/sec, so the walk is
# intentionally sequential (no parallel probing).
wallet:_derive_walk() {
	local name="$1" path="$2" ledger="$3"
	local -i gap="$4"
	local -i idx empties=0 found=0
	idx="$(wallet:_next_index "$ledger")"
	local addr txs
	while (( empties < gap )); do
		if ! addr="$(wallet:_derive_address "$name" "$idx")"; then
			error "wallet derive --walk: derivation failed at index $idx"
			return 4
		fi
		# Probe the backend for any history at this address. A
		# non-empty JSON array (mempool/blockstream shape) means the
		# address has been used.
		if txs="$(backend:get-address-txs "$addr" 2>/dev/null)" \
			&& [ -n "$txs" ] \
			&& [ "$(printf '%s' "$txs" | jq -r 'length' 2>/dev/null)" -gt 0 ] 2>/dev/null; then
			printf '%d\t%s\t\n' "$idx" "$addr" >> "$ledger"
			(( found++, empties = 0 ))
		else
			(( empties++ ))
		fi
		(( idx++ ))
	done
	if (( found > 0 )); then
		(
			cd "$path"
			git add addresses
			git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			    -c commit.gpgsign=false \
				commit -q -m "wallet derive --walk: $name discovered $found new address(es)"
		) || { error "wallet derive --walk: commit failed"; return 7; }
	fi
	# Summary: how many discovered, and where the gap limit stopped us.
	printf 'derived: %d; gap-limit reached at index %d\n' "$found" "$idx"
}

wallet:addresses() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet addresses: name required"
		return 2
	fi
	local ledger; ledger="$(wallet:_path "$name")/addresses"
	if [ ! -f "$ledger" ]; then
		error "wallet addresses: no ledger at $ledger"
		return 3
	fi
	cat "$ledger"
}

wallet:label() {
	# Three signatures are accepted:
	#
	#   FEAT-038 (1.23.0) — flag-based, tax-vocabulary aware:
	#     wallet label <wallet> <outpoint> --tax <category> [--note <text>]
	#     wallet label <wallet> <outpoint> --free-text <text>
	#     wallet label <wallet> --show [<outpoint>]
	#     wallet label <wallet> --validate
	#
	#   1.19.0 form:
	#     wallet label <kind> <name> <key> <text>     (kind = tx|utxo|addr)
	#
	#   pre-1.19.0 compat:
	#     wallet label <name> <addr> <text>
	#
	# Detection precedence: a `--` flag in any position → FEAT-038
	# form; first arg in (tx|utxo|addr) → 1.19.0 form; otherwise
	# → pre-1.19.0 compat. The taxonomy is enforced ONLY in
	# FEAT-038 form (the older positional forms continue to take
	# free-text).
	local arg has_dashdash=0
	for arg in "$@"; do
		[[ "$arg" == --* ]] && has_dashdash=1
	done
	if (( has_dashdash )); then
		wallet:_label_v2 "$@"
		return $?
	fi
	local kind name key text
	case "${1:-}" in
		tx|utxo|addr)
			kind="$1"; name="${2:-}"; key="${3:-}"; text="${4:-}"
			;;
		"")
			error "wallet label: usage: wallet label <wallet> <outpoint> --tax <category>"
			return 2
			;;
		*)
			# Compat: <name> <addr> <text>
			kind=addr; name="${1:-}"; key="${2:-}"; text="${3:-}"
			;;
	esac
	if [ -z "$name" ] || [ -z "$key" ]; then
		error "wallet label: usage: wallet label <kind:tx|utxo|addr> <name> <key> <text>"
		return 2
	fi
	# Reject tabs / newlines in the label text — storage is TSV.
	if [[ "$text" == *$'\t'* ]] || [[ "$text" == *$'\n'* ]]; then
		error "wallet label: <text> must not contain tabs or newlines (storage is TSV)"
		return 3
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet label: no such wallet '$name' at $path"
		return 4
	fi
	case "$kind" in
		addr) wallet:_label_addr "$name" "$path" "$key" "$text" ;;
		tx)   wallet:_label_kv   "$name" "$path" "tx"   "$key" "" "$text" ;;
		utxo)
			if [[ ! "$key" =~ ^[[:xdigit:]]+:[0-9]+$ ]]; then
				error "wallet label utxo: <key> must look like '<txid>:<vout>' (got '$key')"
				return 5
			fi
			wallet:_label_kv   "$name" "$path" "utxo" "$key" "" "$text"
			;;
	esac
}

# FEAT-038 closed taxonomy. Adding a new category here is a
# release-gate event: it changes the schema downstream FEAT-039
# tax-reporting code reads. Keep this list aligned with
# issues/feature/038-tax-label-vocabulary.md §Taxonomy.
declare -ar WALLET_TAX_CATEGORIES=(
	self-transfer income gift-in gift-out purchase sale spend fee
	lending-out lending-in loss-claim channel-open channel-close
)

# Return 0 if $1 is in the closed taxonomy; non-zero otherwise.
wallet:_is_tax_category() {
	local cat="$1" c
	for c in "${WALLET_TAX_CATEGORIES[@]}"; do
		[ "$c" = "$cat" ] && return 0
	done
	return 1
}

# Print the closed taxonomy as a space-separated list. Used in
# error messages so users see the valid set.
wallet:_tax_categories_str() {
	echo "${WALLET_TAX_CATEGORIES[*]}"
}

# Infer the label kind from the shape of <outpoint>:
#   <txid>:<vout>  → utxo
#   <txid>         → tx (64 hex chars exactly)
#   <addr>         → addr
# Echoes the kind on stdout; non-zero on unrecognised shape.
wallet:_infer_label_kind() {
	local outpoint="$1"
	if [[ "$outpoint" =~ ^[[:xdigit:]]+:[0-9]+$ ]]; then
		echo utxo
	elif [[ "$outpoint" =~ ^[[:xdigit:]]{64}$ ]]; then
		echo tx
	elif [ -n "$outpoint" ]; then
		echo addr
	else
		return 1
	fi
}

# FEAT-038 flag-based label dispatcher. Three modes:
#   wallet label <wallet> <outpoint> --tax <cat> [--note <text>]
#   wallet label <wallet> <outpoint> --free-text <text>
#   wallet label <wallet> --show [<outpoint>]
#   wallet label <wallet> --validate
wallet:_label_v2() {
	local wallet="" outpoint="" tax="" note="" free_text="" show=0 validate=0
	local got_outpoint=0
	while (( $# > 0 )); do
		case "$1" in
			--tax)        tax="$2";       shift 2 ;;
			--note)       note="$2";      shift 2 ;;
			--free-text)  free_text="$2"; shift 2 ;;
			--show)       show=1;         shift ;;
			--validate)   validate=1;     shift ;;
			--*)          error "wallet label: unknown flag '$1'"; return 2 ;;
			*)
				if [ -z "$wallet" ]; then
					wallet="$1"
				elif (( !got_outpoint )); then
					outpoint="$1"; got_outpoint=1
				else
					error "wallet label: unexpected positional arg '$1'"
					return 2
				fi
				shift
				;;
		esac
	done
	if [ -z "$wallet" ]; then
		error "wallet label: usage: wallet label <wallet> <outpoint> --tax <category>"
		return 2
	fi
	# Validate the tax category FIRST — it's a schema check that
	# doesn't depend on wallet state, so users get the "valid set"
	# error even on a typo'd wallet name.
	if [ -n "$tax" ] && ! wallet:_is_tax_category "$tax"; then
		error "wallet label: '$tax' is not a tax category (valid: $(wallet:_tax_categories_str))"
		return 6
	fi
	local path; path="$(wallet:_path "$wallet")"
	if [ ! -d "$path" ]; then
		error "wallet label: no such wallet '$wallet' at $path"
		return 4
	fi
	if (( show )); then
		wallet:_label_show "$wallet" "$path" "$outpoint"
		return $?
	fi
	if (( validate )); then
		wallet:_label_validate "$wallet" "$path"
		return $?
	fi
	if [ -z "$outpoint" ]; then
		error "wallet label: <outpoint> required (got --tax/--free-text without one)"
		return 2
	fi
	local kind; kind="$(wallet:_infer_label_kind "$outpoint")" \
		|| { error "wallet label: cannot infer kind from outpoint '$outpoint'"; return 5; }
	if [ -n "$tax" ]; then
		wallet:_label_kv "$wallet" "$path" "$kind" "$outpoint" "$tax" "$note"
		return $?
	fi
	if [ -n "$free_text" ]; then
		if [[ "$free_text" == *$'\t'* ]] || [[ "$free_text" == *$'\n'* ]]; then
			error "wallet label: <text> must not contain tabs or newlines"
			return 3
		fi
		# kind=addr is handled by wallet:_label_addr (no tax col);
		# kind={tx,utxo} go through wallet:_label_kv with empty tax.
		if [ "$kind" = "addr" ]; then
			wallet:_label_addr "$wallet" "$path" "$outpoint" "$free_text"
		else
			wallet:_label_kv "$wallet" "$path" "$kind" "$outpoint" "" "$free_text"
		fi
		return $?
	fi
	error "wallet label: one of --tax / --free-text / --show / --validate required"
	return 2
}

# Helper: rewrite the addresses-ledger label column for <addr>.
# Pre-1.19.0 behaviour; preserved as the addr-kind storage.
wallet:_label_addr() {
	local name="$1" path="$2" addr="$3" text="$4"
	local ledger="$path/addresses"
	if [ ! -f "$ledger" ]; then
		error "wallet label addr: no ledger at $ledger"
		return 3
	fi
	if ! grep -q -F "	$addr	" "$ledger"; then
		error "wallet label addr: address '$addr' not in $name's ledger"
		return 4
	fi
	local tmp="$ledger.tmp"
	awk -v a="$addr" -v l="$text" -F '\t' 'BEGIN{OFS="\t"} {
		if ($2 == a) print $1, $2, l;
		else        print $0;
	}' "$ledger" > "$tmp" && mv "$tmp" "$ledger"
	(
		cd "$path"
		git add addresses
		if ! git diff --cached --quiet 2>/dev/null; then
			git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			    -c commit.gpgsign=false \
				commit -q -m "wallet label: $name $addr -> '$text'"
		fi
	) || { error "wallet label addr: commit failed"; return 5; }
	info "label set for $addr"
}

# Helper: set / clear / append the label for <key> in
# labels/<kind>. Storage is TSV. FEAT-038 (1.23.0) extends the
# format from 2 columns to 3:
#   key TAB tax_category TAB text
# Legacy 2-column rows are read as `tax_category=""`; new writes
# always emit 3 columns. Empty <text> AND empty <tax> removes
# the row.
wallet:_label_kv() {
	local name="$1" path="$2" kind="$3" key="$4" tax="$5" text="$6"
	local store="$path/labels"
	local file="$store/$kind"
	mkdir -p "$store" || { error "wallet label $kind: cannot mkdir $store"; return 3; }
	[ -f "$file" ] || : > "$file"
	# Rewrite: drop any existing row for <key>; on append, choose
	# the 2-column or 3-column form based on whether <tax> is set.
	# Pre-1.23.0 callers passing just <text> stay on the legacy
	# 2-column shape so their assertions and `git diff` output are
	# unchanged. FEAT-038 callers passing --tax always emit 3 cols.
	local tmp="$file.tmp"
	awk -v k="$key" -F '\t' '$1 != k { print }' "$file" > "$tmp"
	if [ -n "$tax" ]; then
		printf '%s\t%s\t%s\n' "$key" "$tax" "$text" >> "$tmp"
	elif [ -n "$text" ]; then
		printf '%s\t%s\n' "$key" "$text" >> "$tmp"
	fi
	mv "$tmp" "$file"
	(
		cd "$path"
		git add "labels/$kind"
		if ! git diff --cached --quiet 2>/dev/null; then
			local action
			if [ -z "$tax" ] && [ -z "$text" ]; then
				action="cleared"
			elif [ -n "$tax" ]; then
				action="--tax $tax${text:+ (note: \"$text\")}"
			else
				action="-> '$text'"
			fi
			git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			    -c commit.gpgsign=false \
				commit -q -m "wallet label $kind: $name $key $action"
		fi
	) || { error "wallet label $kind: commit failed"; return 5; }
	if [ -z "$tax" ] && [ -z "$text" ]; then
		info "label cleared for $kind:$key"
	else
		info "label set for $kind:$key"
	fi
}

# FEAT-038: print current labels. With no outpoint, dumps every
# label across the addr/tx/utxo stores in a uniform 4-column
# format: kind, key, tax_category, text. Empty fields render as "-".
wallet:_label_show() {
	local wallet="$1" path="$2" outpoint="${3:-}"
	local addrs="$path/addresses"
	local tx_file="$path/labels/tx"
	local utxo_file="$path/labels/utxo"
	{
		# addresses ledger: <idx>\t<addr>\t<label>
		if [ -f "$addrs" ]; then
			awk -F'\t' -v op="$outpoint" '
				{ k=$2; lab=$3 }
				op == "" || op == k {
					printf "addr\t%s\t-\t%s\n", k, (lab == "" ? "-" : lab)
				}
			' "$addrs"
		fi
		# labels/tx: <txid>\t<tax>\t<text>  (legacy: <txid>\t<text>)
		if [ -f "$tx_file" ]; then
			awk -F'\t' -v op="$outpoint" '
				NF >= 3 { k=$1; tax=$2; txt=$3 }
				NF == 2 { k=$1; tax=""; txt=$2 }
				op == "" || op == k {
					printf "tx\t%s\t%s\t%s\n", k,
						(tax == "" ? "-" : tax),
						(txt == "" ? "-" : txt)
				}
			' "$tx_file"
		fi
		# labels/utxo: <outpoint>\t<tax>\t<text>  (legacy: 2 col)
		if [ -f "$utxo_file" ]; then
			awk -F'\t' -v op="$outpoint" '
				NF >= 3 { k=$1; tax=$2; txt=$3 }
				NF == 2 { k=$1; tax=""; txt=$2 }
				op == "" || op == k {
					printf "utxo\t%s\t%s\t%s\n", k,
						(tax == "" ? "-" : tax),
						(txt == "" ? "-" : txt)
				}
			' "$utxo_file"
		fi
	}
}

# FEAT-038 release-gate helper: walk every UTXO (from labels/utxo
# rows that exist after `wallet index`) and every tx-output (from
# labels/tx) and report ones without a tax_category. Exits 0 only
# if every row has one — useful as a pre-report gate for FEAT-039.
# Unlabeled UTXOs in `wallet history` (rows that have NO label
# entry at all) are not yet enumerated here; that integration
# comes with FEAT-037 (utxo object verb).
wallet:_label_validate() {
	local wallet="$1" path="$2"
	local tx_file="$path/labels/tx"
	local utxo_file="$path/labels/utxo"
	# A row "has a tax category" iff it has >= 3 fields AND the
	# tax_category column ($2) is non-empty. Legacy 2-col rows
	# (NF == 2) and 3-col rows with empty $2 both fail the check.
	# awk handles NF cleanly where bash `read -r` can't distinguish
	# "empty trailing field" from "no trailing field".
	local report
	report="$(
		for kind_file in "tx:$tx_file" "utxo:$utxo_file"; do
			local kind="${kind_file%%:*}" file="${kind_file#*:}"
			[ -f "$file" ] || continue
			awk -F'\t' -v kind="$kind" '
				NF < 3 || $2 == "" { print kind "\t" $1 "\t(unlabeled)" }
			' "$file"
		done
	)"
	if [ -n "$report" ]; then
		printf '%s\n' "$report"
		local -i n; n=$(printf '%s' "$report" | grep -c .)
		info "$n label rows are missing a tax category"
		return 7
	fi
	info "every label row has a tax category"
	return 0
}

# FEAT-014 (partial, 1.8.0): wallet broadcast. Reads a raw hex
# transaction from stdin and forwards to the active backend. The
# <name> argument is currently a docs hint — per-wallet backend
# resolution is deferred until FEAT-012's per-wallet config lands.
#
# FEAT-036 follow-up (1.23.0): renamed from wallet:broadcast →
# tx:broadcast. wallet:broadcast remains as a deprecated alias
# below; wallet:send was updated to call tx:* directly.
tx:broadcast() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "tx broadcast: name required (currently a docs hint; per-wallet backend deferred)"
		return 2
	fi
	local hex
	hex="$(cat | tr -d '[:space:]')"
	if [ -z "$hex" ]; then
		error "tx broadcast: empty stdin (expected raw transaction hex)"
		return 3
	fi
	if [[ ! "$hex" =~ ^[0-9a-fA-F]+$ ]]; then
		error "tx broadcast: stdin is not hex"
		return 4
	fi
	if (( ${#hex} % 2 != 0 )); then
		error "tx broadcast: hex length is odd (${#hex} chars); truncated input?"
		return 5
	fi
	# Normalise to lowercase.
	hex="${hex,,}"
	backend:broadcast "$hex"
}

# FEAT-036 follow-up (1.23.0): deprecation aliases. wallet:build /
# wallet:sign / wallet:broadcast each emit one warn line citing
# the canonical tx form and forward. Removal target 1.24.0.
# wallet:send was migrated to call tx:* directly so the
# convenience verb stays warn-free.
wallet:build() {
	error "'wallet build' was removed in 1.24.0; use 'bitcoin tx build'"
	return 1
}
wallet:sign() {
	error "'wallet sign' was removed in 1.24.0; use 'bitcoin tx sign'"
	return 1
}
wallet:broadcast() {
	error "'wallet broadcast' was removed in 1.24.0; use 'bitcoin tx broadcast'"
	return 1
}

# ---------------------------------------------------------------------------
# FEAT-014 (partial, 1.11.0): wallet build. Walk the addresses ledger,
# query the active backend for UTXOs at each, greedy-select (largest
# first) until input total covers <sats> + estimated fee, serialise a
# BIP-141 unsigned tx, wrap in a single-record PSBT and print as hex.
#
# Signing and end-to-end send remain deferred to ROADMAP-1.12.0+.
# ---------------------------------------------------------------------------

# Reverse a hex string byte-by-byte. Used for little-endian txid + vout
# serialisation in the raw tx body.
wallet:_reverse_hex() {
	local hex="$1"
	local out="" i
	for ((i=${#hex}-2; i>=0; i-=2)); do
		out+="${hex:i:2}"
	done
	printf '%s' "$out"
}

# Encode a non-negative integer as 4-byte little-endian hex.
wallet:_le32() {
	local -i n=$1
	printf '%02x%02x%02x%02x' \
		$((n & 0xff)) \
		$(((n >> 8) & 0xff)) \
		$(((n >> 16) & 0xff)) \
		$(((n >> 24) & 0xff))
}

# Encode a non-negative integer as 8-byte little-endian hex. Bitcoin
# satoshi values fit in 51 bits (21M * 1e8) so 63-bit bash arithmetic
# is sufficient — no need for arbitrary-precision shells here.
wallet:_le64() {
	local -i n=$1
	printf '%02x%02x%02x%02x%02x%02x%02x%02x' \
		$((n & 0xff)) \
		$(((n >> 8) & 0xff)) \
		$(((n >> 16) & 0xff)) \
		$(((n >> 24) & 0xff)) \
		$(((n >> 32) & 0xff)) \
		$(((n >> 40) & 0xff)) \
		$(((n >> 48) & 0xff)) \
		$(((n >> 56) & 0xff))
}

# Convert a v0 segwit bech32 address (bc1q.../tb1q...) to its
# scriptPubKey hex (00 <len> <program>). Returns non-zero on a bad
# checksum, wrong HRP, non-v0 witness version, or wrong program length.
# v1+ (P2TR / bech32m) is intentionally rejected here; signing those
# outputs is FEAT-007, not ROADMAP-1.11.0.
wallet:_address_to_script() {
	local addr="$1"
	if [ -z "$addr" ]; then
		return 1
	fi
	local out
	local libexec="${SELF_LIBEXEC:?wallet:_address_to_script: SELF_LIBEXEC must be set}"
	# FEAT-035 Stream C2: bech32 decode moved to bip173/bip350.
	if ! out="$("$libexec/${SELF:-bitcoin}/bip173" decode "$addr" 2>/dev/null)"; then
		# Fall through to bech32m so we can emit a clearer "v1+ not
		# supported" error rather than a cryptic checksum failure.
		if ! out="$("$libexec/${SELF:-bitcoin}/bip350" decode "$addr" 2>/dev/null)"; then
			return 2
		fi
	fi
	local -a lines
	mapfile -t lines <<< "$out"
	if (( ${#lines[@]} < 3 )); then
		return 3
	fi
	local hrp="${lines[0]}" version="${lines[1]}"
	if [[ ! "$hrp" =~ ^(bc|tb)$ ]]; then
		return 4
	fi
	if [[ ! "$version" =~ ^[0-9]+$ ]]; then
		return 5
	fi
	if (( version != 0 )); then
		return 6
	fi
	local prog_decimals
	if ! prog_decimals="$(
		for ((i=2; i<${#lines[@]}; i++)); do echo "${lines[i]}"; done | convertbits 5 8 0
	)"; then
		return 7
	fi
	local prog="" b
	for b in $prog_decimals; do
		prog+="$(printf '%02x' "$b")"
	done
	local -i prog_len=$(( ${#prog} / 2 ))
	if (( prog_len != 20 && prog_len != 32 )); then
		return 8
	fi
	printf '00%02x%s' "$prog_len" "$prog"
}

tx:build() {
	local name="" addr="" sats=""
	local -i fee_rate=0 fee_rate_set=0
	# FEAT-036 AC #3: --utxo <txid:vout> repeatable coin-control
	# flag. When at least one is supplied, greedy selection is
	# replaced with explicit picking from the requested set. Empty
	# array → greedy as today.
	local -a requested_utxos=()
	while [ $# -gt 0 ]; do
		case "${1:-}" in
			--fee-rate)
				if [ -z "${2:-}" ]; then
					error "tx build: --fee-rate requires an argument"
					return 2
				fi
				if [[ ! "$2" =~ ^[0-9]+$ ]]; then
					error "tx build: --fee-rate must be a positive integer (sat/vB), got '$2'"
					return 2
				fi
				fee_rate="$2"
				fee_rate_set=1
				shift 2
				;;
			--utxo)
				if [ -z "${2:-}" ]; then
					error "tx build: --utxo requires a <txid:vout> argument"
					return 2
				fi
				if [[ ! "$2" =~ ^[[:xdigit:]]+:[0-9]+$ ]]; then
					error "tx build: --utxo argument must look like '<txid>:<vout>' (got '$2')"
					return 2
				fi
				requested_utxos+=( "$2" )
				shift 2
				;;
			--) shift; break ;;
			-*)
				error "tx build: unknown flag '$1'"
				return 2
				;;
			*)
				if [ -z "$name" ]; then name="$1"
				elif [ -z "$addr" ]; then addr="$1"
				elif [ -z "$sats" ]; then sats="$1"
				else
					error "tx build: too many positional arguments (saw '$1')"
					return 2
				fi
				shift
				;;
		esac
	done
	if [ -z "$name" ] || [ -z "$addr" ] || [ -z "$sats" ]; then
		error "tx build: usage: wallet build <name> <addr> <sats> [--fee-rate sat/vB]"
		return 2
	fi
	if [[ ! "$sats" =~ ^[1-9][0-9]*$ ]]; then
		error "tx build: <sats> must be a positive integer, got '$sats'"
		return 3
	fi
	# If --fee-rate wasn't supplied, ask the active backend for a
	# half-hour estimate (FEAT-012 estimate-fee, 1.12.0). On any
	# failure — backend unreachable, non-integer reply, stub backend
	# returning "not implemented" — fall back to 1 sat/vB with a
	# `warn` so the user knows their default is the floor.
	if (( ! fee_rate_set )); then
		local est
		if est="$(backend:estimate-fee 3 2>/dev/null)" && [[ "$est" =~ ^[1-9][0-9]*$ ]]; then
			fee_rate=$est
		else
			warn "tx build: backend estimate-fee unavailable; falling back to 1 sat/vB"
			fee_rate=1
		fi
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "tx build: no such wallet '$name' at $path"
		return 4
	fi
	local ledger="$path/addresses"
	if [ ! -s "$ledger" ]; then
		error "tx build: wallet '$name' has no derived addresses (run 'wallet derive')"
		return 5
	fi

	local out_script
	if ! out_script="$(wallet:_address_to_script "$addr")"; then
		error "tx build: invalid output address '$addr' (only v0 P2WPKH/P2WSH supported in this release)"
		return 6
	fi

	# Collect UTXOs from every address in the wallet's ledger. The
	# backend returns a JSON array per address; we flatten via jq.
	# Per-UTXO `addr` is tracked so the signer (FEAT-008 psbt sign,
	# 1.13.0) can compute the input's scriptPubKey from the address.
	local -a utxos_txid=() utxos_vout=() utxos_value=() utxos_addr=()
	local _idx addr_ledger _label utxo_json txid vout value
	while IFS=$'\t' read -r _idx addr_ledger _label; do
		[ -z "$addr_ledger" ] && continue
		if ! utxo_json="$(backend:get-address-utxos "$addr_ledger" 2>/dev/null)"; then
			warn "tx build: backend get-utxos failed for $addr_ledger (continuing)"
			continue
		fi
		while IFS=$'\t' read -r txid vout value; do
			[ -z "$txid" ] && continue
			# FEAT-037 integration: skip frozen UTXOs. utxo:_is_frozen
			# looks the outpoint up in <wallet-repo>/frozen.tsv. The
			# warn line names the outpoint + reason so the user sees
			# why their available balance dropped.
			local _op="$txid:$vout"
			if utxo:_is_frozen "$name" "$_op"; then
				local _reason
				_reason="$(utxo:_freeze_reason "$name" "$_op")"
				warn "tx build: skipping frozen UTXO $_op${_reason:+ (reason: \"$_reason\")}"
				continue
			fi
			utxos_txid+=( "$txid" )
			utxos_vout+=( "$vout" )
			utxos_value+=( "$value" )
			utxos_addr+=( "$addr_ledger" )
		done < <(printf '%s' "$utxo_json" | jq -r '.[] | [.txid, .vout, .value] | @tsv' 2>/dev/null)
	done < "$ledger"

	# FEAT-036 AC #3: if the user supplied --utxo flags, restrict
	# the candidate set to only those outpoints. Errors if any
	# requested outpoint isn't actually unspent at any of the
	# wallet's derived addresses.
	if (( ${#requested_utxos[@]} > 0 )); then
		local -a filt_txid=() filt_vout=() filt_value=() filt_addr=()
		local req i found_op
		for req in "${requested_utxos[@]}"; do
			found_op=0
			for (( i=0; i<${#utxos_txid[@]}; i++ )); do
				if [ "${utxos_txid[i]}:${utxos_vout[i]}" = "$req" ]; then
					filt_txid+=(  "${utxos_txid[i]}"  )
					filt_vout+=(  "${utxos_vout[i]}"  )
					filt_value+=( "${utxos_value[i]}" )
					filt_addr+=(  "${utxos_addr[i]}"  )
					found_op=1
					break
				fi
			done
			if (( !found_op )); then
				error "tx build: requested --utxo $req not found among wallet UTXOs (frozen? already spent? not derived?)"
				return 7
			fi
		done
		utxos_txid=( "${filt_txid[@]}" )
		utxos_vout=( "${filt_vout[@]}" )
		utxos_value=( "${filt_value[@]}" )
		utxos_addr=( "${filt_addr[@]}" )
	fi

	if (( ${#utxos_txid[@]} == 0 )); then
		error "tx build: no UTXOs available for wallet '$name'"
		return 7
	fi

	# Sort UTXO indexes by value descending (largest-first selection).
	local -a order
	mapfile -t order < <(
		local i
		for ((i=0; i<${#utxos_value[@]}; i++)); do
			printf '%d\t%s\n' "${utxos_value[i]}" "$i"
		done | sort -k1,1 -nr | cut -f2
	)

	# Greedy-select. Fee estimate assumes P2WPKH inputs (~68 vbytes
	# each, post-segwit-discount) and 2 outputs (~31 vbytes each) +
	# 10 vbytes of overhead — conservative so we don't fall short
	# when change is added. This is the educational simple-fee model;
	# RBF / branch-and-bound coin selection are out of scope.
	local -a sel=()
	local -i selected_total=0 n_in=0 fee_estimate=0 needed=$sats ix
	for ix in "${order[@]}"; do
		sel+=( "$ix" )
		(( selected_total += utxos_value[ix] ))
		(( n_in++ ))
		(( fee_estimate = (10 + 68 * n_in + 31 * 2) * fee_rate ))
		(( needed = sats + fee_estimate ))
		(( selected_total >= needed )) && break
	done
	if (( selected_total < needed )); then
		error "tx build: insufficient balance: have $selected_total sats, need $needed (sats=$sats, fee~$fee_estimate at $fee_rate sat/vB)"
		return 8
	fi

	# Change handling. Dust threshold for P2WPKH is ~294 sats at 3
	# sat/vB; we use 546 (the legacy P2PKH dust limit) as a generous
	# floor — anything smaller gets folded into the fee instead.
	local -i dust=546 change=0 n_out=1
	local change_script=""
	(( change = selected_total - sats - fee_estimate ))
	if (( change > dust )); then
		local change_addr
		if ! change_addr="$(wallet:derive "$name" 2>/dev/null)"; then
			error "tx build: failed to derive change address for '$name'"
			return 9
		fi
		# wallet derive may emit other lines (info etc. go to stderr,
		# but be defensive); take the last line as the address.
		change_addr="$(printf '%s\n' "$change_addr" | tail -n1)"
		if ! change_script="$(wallet:_address_to_script "$change_addr")"; then
			error "tx build: failed to compute change scriptPubKey for '$change_addr'"
			return 10
		fi
		n_out=2
	fi

	# --- serialise the BIP-141 unsigned transaction -----------------
	local raw_tx=""
	raw_tx+="02000000"                              # version (4 B LE)
	raw_tx+="$(_emit_varint "$n_in")"          # input count
	for ix in "${sel[@]}"; do
		txid="${utxos_txid[ix]}"
		vout="${utxos_vout[ix]}"
		raw_tx+="$(wallet:_reverse_hex "$txid")"    # 32-B prev_txid (LE)
		raw_tx+="$(wallet:_le32 "$vout")"           #  4-B prev_vout (LE)
		raw_tx+="00"                                # empty scriptSig
		raw_tx+="feffffff"                          # sequence 0xfffffffe (RBF off, locktime on)
	done
	raw_tx+="$(_emit_varint "$n_out")"         # output count
	raw_tx+="$(wallet:_le64 "$sats")"               # recipient value
	raw_tx+="$(_emit_varint $(( ${#out_script} / 2 )))"
	raw_tx+="$out_script"
	if (( n_out == 2 )); then
		raw_tx+="$(wallet:_le64 "$change")"
		raw_tx+="$(_emit_varint $(( ${#change_script} / 2 )))"
		raw_tx+="$change_script"
	fi
	raw_tx+="00000000"                              # locktime

	# --- wrap as a PSBT ---------------------------------------------
	# Magic + global UNSIGNED_TX record + section terminator, then per
	# input map a PSBT_IN_WITNESS_UTXO record (type 0x01) carrying the
	# prev-output's amount (8 B LE) + varint-prefixed scriptPubKey,
	# followed by an end-of-section 0x00 byte. Output maps are empty.
	# The PSBT_IN_WITNESS_UTXO record was added in 1.13.0 so that
	# `psbt sign` (FEAT-008 partial) has everything BIP-143 sighash
	# needs without re-fetching from the backend.
	local psbt="70736274ff"
	psbt+="01"                                      # global keylen=1
	psbt+="00"                                      # key = PSBT_GLOBAL_UNSIGNED_TX
	psbt+="$(_emit_varint $(( ${#raw_tx} / 2 )))"
	psbt+="$raw_tx"
	psbt+="00"                                      # close global
	local i utxo_script utxo_record
	for ((i=0; i<n_in; i++)); do
		ix="${sel[i]}"
		# scriptPubKey for the input's source address (same v0
		# P2WPKH/P2WSH we accept on the output side).
		if ! utxo_script="$(wallet:_address_to_script "${utxos_addr[ix]}")"; then
			error "tx build: failed to encode scriptPubKey for input address '${utxos_addr[ix]}'"
			return 11
		fi
		utxo_record="$(wallet:_le64 "${utxos_value[ix]}")"
		utxo_record+="$(_emit_varint $(( ${#utxo_script} / 2 )))"
		utxo_record+="$utxo_script"
		psbt+="01"                                  # keylen=1
		psbt+="01"                                  # key = PSBT_IN_WITNESS_UTXO
		psbt+="$(_emit_varint $(( ${#utxo_record} / 2 )))"
		psbt+="$utxo_record"
		psbt+="00"                                  # close input map
	done
	for ((i=0; i<n_out; i++)); do psbt+="00"; done  # empty output maps

	printf '%s\n' "$psbt"
}

# ---------------------------------------------------------------------------
# FEAT-014 (partial, 1.14.0): wallet sign + wallet send.
#
# `wallet sign` reads a PSBT (hex) on stdin and pipes it through
# `psbt sign <privkey>` once per address in the wallet's ledger.
# Each derivation reuses the pipeline wallet:_derive_address uses,
# but pulls the raw 32-byte private key rather than computing the
# pubkey. Keys that don't match any input are no-ops in the signer.
#
# `wallet send` composes build | sign | psbt finalize | psbt extract
# | broadcast, returning the txid the backend produced.
# ---------------------------------------------------------------------------

# Derive the raw 32-byte private key (hex) for <name>'s ledger index
# <idx>. Mirrors wallet:_derive_address but stops one step earlier
# and reads the 32 bytes of secret key rather than the 33-byte
# compressed pubkey.
wallet:_derive_privkey_hex() {
	local name="$1" idx="$2"
	if ! command -v secret >/dev/null 2>&1; then
		error "tx sign: 'secret' not in PATH (cannot read seed for '$name')"
		return 5
	fi
	local libexec="${SELF_LIBEXEC:?tx sign: SELF_LIBEXEC must be set}"
	# The bip32 derive plugin emits the full 78-byte serialised
	# extended private key. The last 32 bytes are the raw secret key
	# (the byte just before is the 0x00 marker that distinguishes
	# private from public child-key data).
	local priv_hex
	priv_hex="$(
		secret get "$name/seed" |
		"$libexec/${SELF:-bitcoin}/bip39" mnemonic-to-seed |
		"$libexec/${SELF:-bitcoin}/bip32" create 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip13" base58-decode 2>/dev/null |
		"$libexec/${SELF:-bitcoin}/bip32" derive "m/84h/0h/0h/0/$idx" 2>/dev/null |
		tail -c 32 |
		xxd -p -c 0 |
		tr -d '\n'
	)"
	if [[ ! "$priv_hex" =~ ^[0-9a-f]{64}$ ]]; then
		error "tx sign: private-key derivation produced unexpected output for $name/$idx"
		return 6
	fi
	printf '%s\n' "$priv_hex"
}

tx:sign() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "tx sign: usage: wallet sign <name> (PSBT on stdin)"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "tx sign: no such wallet '$name' at $path"
		return 3
	fi
	local ledger="$path/addresses"
	if [ ! -s "$ledger" ]; then
		error "tx sign: wallet '$name' has no derived addresses"
		return 4
	fi

	local psbt; psbt="$(cat | tr -d '[:space:]' | tr A-F a-f)"
	if [ -z "$psbt" ]; then
		error "tx sign: empty stdin (expected hex-encoded PSBT)"
		return 5
	fi
	if [[ ! "$psbt" =~ ^[0-9a-f]+$ ]]; then
		error "tx sign: stdin is not hex"
		return 6
	fi

	# Walk the ledger; for each index derive a privkey + re-pipe.
	# bip174 sign is a no-op for inputs the key can't sign, so this
	# is safe even when the ledger has many addresses.
	local libexec="${SELF_LIBEXEC:?tx sign: SELF_LIBEXEC must be set}"
	local idx addr_ledger _label privkey
	while IFS=$'\t' read -r idx addr_ledger _label; do
		[ -z "$idx" ] && continue
		if ! privkey="$(wallet:_derive_privkey_hex "$name" "$idx")"; then
			warn "tx sign: skipping index $idx (derivation failed)"
			continue
		fi
		psbt="$(printf '%s\n' "$psbt" | "$libexec/${SELF:-bitcoin}/bip174" sign "$privkey")" || {
			error "tx sign: bip174 sign failed at index $idx"
			return 7
		}
	done < "$ledger"

	printf '%s\n' "$psbt"
}

wallet:send() {
	# Same arg shape as `wallet build`. We don't re-parse positional
	# args here; whatever the user passes is forwarded to build. The
	# only flag we lift out is `--mainnet`, the broadcast-side guard
	# added in 1.21.0 for FEAT-014.
	local name="" mainnet=0
	local -a fwd_args=()
	local arg
	for arg in "$@"; do
		case "$arg" in
			--mainnet) mainnet=1 ;;
			*) fwd_args+=( "$arg" ) ;;
		esac
	done
	name="${fwd_args[0]:-}"
	if [ -z "$name" ]; then
		error "wallet send: usage: wallet send <name> <addr> <sats> [--fee-rate sat/vB] [--mainnet]"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet send: no such wallet '$name' at $path"
		return 3
	fi
	# Mainnet guard: a wallet whose config says `network=mainnet`
	# refuses to broadcast unless the user explicitly opted in.
	# Other networks (testnet, regtest, signet, unset) proceed
	# unconditionally; --mainnet is silently accepted there.
	local net; net="$(wallet:_network "$name")"
	if [ "$net" = "mainnet" ] && (( ! mainnet )); then
		error "wallet send: wallet '$name' is configured for mainnet (config: network=mainnet); pass --mainnet to confirm an irreversible broadcast"
		return 8
	fi
	# Compose build | sign | finalize | extract | broadcast in-shell.
	# A pipefail-style abort: capture the build PSBT first so a
	# build-time failure surfaces with its own error message.
	# fwd_args[] is the original arg list minus --mainnet (which is
	# a send-only flag; wallet build doesn't know about it).
	local psbt; psbt="$(tx:build "${fwd_args[@]}")" || {
		error "wallet send: wallet build failed"
		return 4
	}
	local signed; signed="$(printf '%s\n' "$psbt" | tx:sign "$name")" || {
		error "wallet send: wallet sign failed"
		return 5
	}
	local libexec="${SELF_LIBEXEC:?wallet send: SELF_LIBEXEC must be set}"
	local finalised; finalised="$(printf '%s\n' "$signed" | "$libexec/${SELF:-bitcoin}/bip174" finalize)" || {
		error "wallet send: bip174 finalize failed"
		return 6
	}
	local raw_tx; raw_tx="$(printf '%s\n' "$finalised" | "$libexec/${SELF:-bitcoin}/bip174" extract)" || {
		error "wallet send: bip174 extract failed"
		return 7
	}
	printf '%s\n' "$raw_tx" | tx:broadcast "$name"
}

# Read the wallet's `network=` line from its config. Returns the
# value or "testnet" if the line is missing (consistent with
# wallet new's default). Used by the wallet send mainnet guard.
wallet:_network() {
	local name="$1"
	local cfg; cfg="$(wallet:_path "$name")/config"
	if [ ! -f "$cfg" ]; then
		echo testnet
		return
	fi
	local v
	v="$(awk -F= '$1 == "network" { print $2; exit }' "$cfg")"
	echo "${v:-testnet}"
}

# ---------------------------------------------------------------------------
# FEAT-018 (partial, 1.17.0): wallet index / tx / history.
#
# `wallet index` walks the wallet's addresses ledger and downloads
# every tx touching one of them via `backend get-address-txs`,
# caching both the raw hex and the backend's decoded JSON under
# <wallet>/transactions/. The history ledger tracks one row per tx
# (txid, height, direction, net sats). Idempotent: each per-txid
# hex file gates the download, and the history is rewritten in
# place from the union of cached transactions on every run.
#
# `wallet tx` and `wallet history` read from the cache only, so
# they work even when the backend is unreachable.
# ---------------------------------------------------------------------------

# For the given decoded tx JSON, compute (direction, net sats) where
# direction is "in", "out", or "self" and net is the signed delta
# applied to the wallet's balance by this tx. Pure jq; no curl.
#   $1 = tx JSON (one tx entry from get-address-txs)
#   $2 = newline-separated list of wallet addresses
wallet:_tx_direction_and_amount() {
	local tx_json="$1" addrs="$2"
	# Sum of outputs paying our addresses, minus sum of inputs spent
	# from our addresses. -R -s reads the addr list as one string,
	# split on newlines, drops the trailing empty line.
	local result
	result="$(
		printf '%s\n' "$addrs" \
		| jq -R -s --argjson tx "$tx_json" -r '
			split("\n") | map(select(length > 0)) as $owned
			| ($tx.vout // []
				| map(select(.scriptpubkey_address as $a | $owned | index($a)))
				| map(.value) | add // 0) as $vout_to_us
			| ($tx.vin // []
				| map(select(.prevout.scriptpubkey_address as $a
				             | $owned | index($a)))
				| map(.prevout.value) | add // 0) as $vin_from_us
			| ($vout_to_us - $vin_from_us) as $net
			| (if $vout_to_us > 0 and $vin_from_us == 0 then "in"
			   elif $vin_from_us > 0 and $vout_to_us == 0 then "out"
			   elif $vin_from_us > 0 and $vout_to_us > 0 then "self"
			   else "in" end) as $dir
			| "\($dir)\t\($net)"
		' 2>/dev/null
	)"
	printf '%s' "$result"
}

wallet:index() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet index: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet index: no such wallet '$name' at $path"
		return 3
	fi
	local ledger="$path/addresses"
	if [ ! -s "$ledger" ]; then
		error "wallet index: wallet '$name' has no derived addresses (run 'wallet derive')"
		return 4
	fi
	if ! command -v jq >/dev/null 2>&1; then
		error "wallet index: jq is required for tx decoding"
		return 5
	fi

	local txdir="$path/transactions"
	mkdir -p "$txdir" || { error "wallet index: cannot mkdir $txdir"; return 6
	}

	# Collect the set of wallet addresses once for direction/amount.
	local owned_addrs
	owned_addrs="$(awk -F'\t' 'NF>=2 && $2 != "" {print $2}' "$ledger")"

	# Walk the ledger and fetch each address's tx list.
	local _idx addr _label tx_json_array txid height
	local txs_json
	while IFS=$'\t' read -r _idx addr _label; do
		[ -z "$addr" ] && continue
		if ! txs_json="$(backend:get-address-txs "$addr" 2>/dev/null)"; then
			warn "wallet index: backend get-address-txs failed for $addr (skipping)"
			continue
		fi
		# Iterate each tx via jq, emit "txid\theight" lines.
		while IFS=$'\t' read -r txid height; do
			[ -z "$txid" ] && continue
			# Persist the JSON for this tx (idempotent — skip if cached).
			if [ ! -s "$txdir/$txid.json" ]; then
				printf '%s' "$txs_json" \
					| jq --arg id "$txid" '.[] | select(.txid == $id)' \
					> "$txdir/$txid.json"
			fi
			# Fetch raw hex if not cached.
			if [ ! -s "$txdir/$txid.hex" ]; then
				local hex_url="$BITCOIN_MEMPOOL_URL/api/tx/$txid/hex"
				if ! curl -sfL "$hex_url" > "$txdir/$txid.hex" 2>/dev/null; then
					warn "wallet index: GET $hex_url failed (skipping hex cache for $txid)"
					rm -f "$txdir/$txid.hex"
				fi
			fi
		done < <(printf '%s' "$txs_json" \
			| jq -r '.[] | [.txid, (.status.block_height // "mempool")] | @tsv' 2>/dev/null)
	done < "$ledger"

	# Rebuild the history ledger from the cached transactions. Sorting
	# by height keeps the file deterministic and merge-friendly.
	local hist="$path/history"
	: > "$hist.tmp"
	local f
	for f in "$txdir"/*.json; do
		[ -f "$f" ] || continue
		txid="$(jq -r '.txid' "$f" 2>/dev/null)"
		height="$(jq -r '.status.block_height // "mempool"' "$f" 2>/dev/null)"
		local tx_json; tx_json="$(cat "$f")"
		local dir_amt; dir_amt="$(wallet:_tx_direction_and_amount "$tx_json" "$owned_addrs")"
		printf '%s\t%s\t%s\n' "$txid" "$height" "$dir_amt" >> "$hist.tmp"
	done
	# Stable sort by height (numeric where possible, "mempool" sorts last).
	LC_ALL=C sort -k2,2 "$hist.tmp" > "$hist"
	rm -f "$hist.tmp"

	# Commit if anything changed.
	(
		cd "$path"
		git add transactions history 2>/dev/null
		if ! git diff --cached --quiet 2>/dev/null; then
			git -c user.email=wallet@bitcoin -c user.name=bitcoin \
			    -c commit.gpgsign=false \
				commit -q -m "wallet index: $name" || true
		fi
	)
	info "wallet '$name' index updated"
}

wallet:tx() {
	local name="${1:-}" txid="${2:-}"
	if [ -z "$name" ] || [ -z "$txid" ]; then
		error "wallet tx: usage: wallet tx <name> <txid>"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet tx: no such wallet '$name' at $path"
		return 3
	fi
	local hex="$path/transactions/$txid.hex"
	local json="$path/transactions/$txid.json"
	if [ ! -s "$hex" ] && [ ! -s "$json" ]; then
		error "wallet tx: '$txid' not indexed (run 'wallet index $name' first)"
		return 4
	fi
	if [ -s "$json" ]; then
		echo "=== decoded ==="
		cat "$json"
	fi
	if [ -s "$hex" ]; then
		echo "=== hex ==="
		cat "$hex"
	fi
	# 1.19.0: append associated labels from labels/tx + labels/utxo
	# if any are recorded. Suppressed entirely when both files are
	# absent or hold no match.
	local tx_lbl utxo_lbls
	tx_lbl="$(wallet:_label_lookup "$path" "tx" "$txid")"
	# UTXO labels are keyed by <txid>:<vout>; print every match.
	if [ -f "$path/labels/utxo" ]; then
		utxo_lbls="$(awk -F '\t' -v p="$txid:" '$1 ~ "^"p {print "utxo:"$0}' "$path/labels/utxo")"
	fi
	if [ -n "$tx_lbl" ] || [ -n "$utxo_lbls" ]; then
		echo "=== labels ==="
		[ -n "$tx_lbl" ]    && printf 'tx\t%s\n' "$tx_lbl"
		[ -n "$utxo_lbls" ] && printf '%s\n' "$utxo_lbls"
	fi
}

# Read the label text for <key> from labels/<kind>. Empty when
# the file or key is absent. Pipe-free.
wallet:_label_lookup() {
	local path="$1" kind="$2" key="$3"
	local file="$path/labels/$kind"
	[ -f "$file" ] || return 0
	awk -F '\t' -v k="$key" '$1 == k { print $2; exit }' "$file"
}

wallet:history() {
	local name="" pattern=""
	# Flag parsing: --label <pattern> is the only flag in 1.19.0.
	while [ $# -gt 0 ]; do
		case "${1:-}" in
			--label)
				if [ -z "${2:-}" ]; then
					error "wallet history: --label requires a pattern argument"
					return 2
				fi
				pattern="$2"
				shift 2
				;;
			--) shift; break ;;
			-*)
				error "wallet history: unknown flag '$1'"
				return 2
				;;
			*)
				if [ -z "$name" ]; then name="$1"
				else
					error "wallet history: too many positional arguments (saw '$1')"
					return 2
				fi
				shift
				;;
		esac
	done
	if [ -z "$name" ]; then
		error "wallet history: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet history: no such wallet '$name' at $path"
		return 3
	fi
	local hist="$path/history"
	if [ ! -s "$hist" ]; then
		# Empty history is fine (no txs indexed yet).
		return 0
	fi
	if [ -z "$pattern" ]; then
		cat "$hist"
		return 0
	fi
	# Filter: keep history rows whose tx-label (looked up by txid in
	# labels/tx) contains <pattern> as a substring, case-insensitive.
	local labels="$path/labels/tx"
	if [ ! -s "$labels" ]; then
		# No labels yet → no matches by definition.
		return 0
	fi
	awk -F '\t' \
	    -v lbl_file="$labels" \
	    -v needle="${pattern,,}" \
	    'BEGIN {
	         while ((getline line < lbl_file) > 0) {
	             split(line, f, "\t")
	             labels[f[1]] = tolower(f[2])
	         }
	         close(lbl_file)
	     }
	     ($1 in labels) && index(labels[$1], needle) > 0 { print }' \
	    "$hist"
}

# ---------------------------------------------------------------------------
# FEAT-011 (partial, 1.9.0): wallet remote / push / pull. Thin
# wrappers around git's own remote machinery so a wallet repo can move
# between machines (the cold-storage flow). The original FEAT-011 spec
# routes through `account` to resolve SSH endpoints — that's deferred;
# the URL is taken directly here. The custom merge resolvers
# (addresses-union, psbts-last-writer-wins, descriptors-conflict-as-
# error) are also deferred.
# ---------------------------------------------------------------------------

wallet:remote() {
	local action="${1:-}"
	shift 2>/dev/null || true
	if [ "$action" != "add" ]; then
		error "wallet remote: only 'add' is supported in this release (sub-actions deferred)"
		return 2
	fi
	local name="${1:-}" rname="${2:-}" url="${3:-}"
	if [ -z "$name" ] || [ -z "$rname" ] || [ -z "$url" ]; then
		error "wallet remote add: usage: wallet remote add <wallet> <remote-name> <url>"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path/.git" ]; then
		error "wallet remote add: no such wallet '$name' at $path"
		return 3
	fi
	(
		cd "$path"
		# Replace existing remote with the new URL idempotently.
		if git remote get-url "$rname" >/dev/null 2>&1; then
			git remote set-url "$rname" "$url"
		else
			git remote add "$rname" "$url"
		fi
	) || { error "wallet remote add: git remote configuration failed"; return 4; }
	info "wallet '$name' remote '$rname' -> $url"
}

wallet:push() {
	local name="${1:-}" rname="${2:-origin}"
	if [ -z "$name" ]; then
		error "wallet push: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path/.git" ]; then
		error "wallet push: no such wallet '$name' at $path"
		return 3
	fi
	if ! ( cd "$path" && git remote get-url "$rname" >/dev/null 2>&1 ); then
		error "wallet push: '$name' has no '$rname' remote configured (use 'wallet remote add')"
		return 4
	fi
	(
		cd "$path"
		local branch
		branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || branch=main
		git push -q "$rname" "$branch"
	) || { error "wallet push: git push failed"; return 5; }
	info "wallet '$name' pushed to '$rname'"
}

wallet:pull() {
	local name="${1:-}" rname="${2:-origin}"
	if [ -z "$name" ]; then
		error "wallet pull: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path/.git" ]; then
		error "wallet pull: no such wallet '$name' at $path"
		return 3
	fi
	if ! ( cd "$path" && git remote get-url "$rname" >/dev/null 2>&1 ); then
		error "wallet pull: '$name' has no '$rname' remote configured (use 'wallet remote add')"
		return 4
	fi
	(
		cd "$path"
		local branch
		branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || branch=main
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			pull --rebase -q "$rname" "$branch"
	) || { error "wallet pull: git pull failed"; return 5; }
	info "wallet '$name' pulled from '$rname'"
}

wallet:balance() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet balance: name required"
		return 2
	fi
	local ledger; ledger="$(wallet:_path "$name")/addresses"
	if [ ! -f "$ledger" ]; then
		error "wallet balance: no ledger at $ledger"
		return 3
	fi
	local -i total=0
	local addr utxo_json sum
	while IFS=$'\t' read -r _idx addr _label; do
		[ -z "$addr" ] && continue
		if ! utxo_json="$(backend:get-address-utxos "$addr")"; then
			warn "wallet balance: backend get-utxos failed for $addr (continuing)"
			continue
		fi
		# Sum the .value fields. jq is in .rpk/depends; available on CI.
		sum="$(printf '%s' "$utxo_json" | jq -r '[.[].value] | add // 0' 2>/dev/null)"
		if [[ "$sum" =~ ^[0-9]+$ ]]; then
			(( total += sum ))
		fi
	done < "$ledger"
	echo "$total"
}

wallet:new() {
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet new: name required"
		return 2
	fi
	if ! wallet:_valid_name "$name"; then
		error "wallet new: invalid name '$name' (must match [A-Za-z0-9][A-Za-z0-9_-]*)"
		return 3
	fi
	local path; path="$(wallet:_path "$name")"
	if [ -e "$path" ]; then
		error "wallet new: '$name' already exists at $path"
		return 4
	fi
	if ! command -v secret >/dev/null 2>&1; then
		error "wallet new: 'secret' not found in PATH (install nostra124/secret)"
		return 5
	fi
	if [ ! -x "$SELF_LIBEXEC/$SELF/bip39" ]; then
		error "wallet new: 'bip39' libexec plugin not found at $SELF_LIBEXEC/$SELF/bip39"
		return 6
	fi

	local mnemonic
	if ! mnemonic="$("$SELF_LIBEXEC/$SELF/bip39" create 256 2>/dev/null)"; then
		error "wallet new: bip39 create failed"
		return 7
	fi
	if [ -z "$mnemonic" ]; then
		error "wallet new: bip39 create produced empty mnemonic"
		return 8
	fi

	if ! printf '%s\n' "$mnemonic" | secret put "$name/seed"; then
		error "wallet new: 'secret put $name/seed' failed"
		return 9
	fi

	mkdir -p "$path" || { error "wallet new: mkdir $path failed"; return 10; }
	(
		cd "$path" || exit 1
		git init -q -b main || git init -q
		cat > config <<-CFG
		# bitcoin wallet '$name' — FEAT-010
		name=$name
		network=testnet
		CFG
		: > descriptors
		git add config descriptors
		# commit.gpgsign=false: wallet-internal commits run on the
		# user's wallet repo, not on this project's repo. We don't
		# assume the user has signing keys set up for their wallet.
		git -c user.email=wallet@bitcoin -c user.name=bitcoin \
		    -c commit.gpgsign=false \
			commit -q -m "wallet new: $name"
	) || { error "wallet new: failed to initialise repo at $path"; return 11; }

	info "wallet '$name' created at $path"
}

wallet:ls() {
	local root; root="$(wallet:_root)"
	if [ ! -d "$root" ]; then
		return 0
	fi
	find "$root" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null | sort
}

wallet:rm() {
	local force=0
	while [ $# -gt 0 ]; do
		case "${1:-}" in
			-f|--force) force=1; shift ;;
			--) shift; break ;;
			-*) error "wallet rm: unknown flag '$1'"; return 2 ;;
			*) break ;;
		esac
	done
	local name="${1:-}"
	if [ -z "$name" ]; then
		error "wallet rm: name required"
		return 2
	fi
	local path; path="$(wallet:_path "$name")"
	if [ ! -d "$path" ]; then
		error "wallet rm: no such wallet '$name' at $path"
		return 3
	fi
	rm -rf "$path"
	if (( force )); then
		if command -v secret >/dev/null 2>&1; then
			secret rm "$name/seed" 2>/dev/null \
				|| warn "wallet rm: 'secret rm $name/seed' failed (continuing)"
		else
			warn "wallet rm: 'secret' not in PATH; skipped seed removal"
		fi
	fi
	info "wallet '$name' removed"
}

# BUG-016 (1.7.1): the previous `command:bip49-create` and
# `command:bip84-create` dispatcher entries here called a
# never-defined `command:bip32-create` and had been dead since the
# repo's extraction. Removed; the bash-function wrappers `bip49()`
# / `bip84()` later in this file are the canonical user surface.
# A latent issue with their BIP32_-prefixed env vars (the bip32
# plugin reads unprefixed `*_VERSION_CODE`) is tracked as an open
# audit follow-up; not in scope here.

# ---------------------------------------------------------------------------
# FEAT-035 Stream C2 (1.23.0): the bech32 / bech32m verbs and their
# private helpers moved to `libexec/bitcoin/bip173` and
# `libexec/bitcoin/bip350` per the BIP-faithful naming convention.
# `command:bech32`, `command:bech32-verify`, `command:bech32-encode`
# and `command:bech32-decode` remain as deprecated aliases that emit
# one warn line and forward to bip173 / bip350 based on the `-m`
# flag. Removal target 1.24.0.
# ---------------------------------------------------------------------------

# Helper: pick the canonical plugin target based on a leading -m.
command:bech32() {
	error "'bech32' was removed in 1.24.0; use 'bitcoin bip173 encode' or 'bitcoin bip350 encode'"
	return 1
}

command:bech32-verify() {
	error "'bech32-verify' was removed in 1.24.0; use 'bitcoin bip173 verify' or 'bitcoin bip350 verify'"
	return 1
}

command:bech32-encode() {
	error "'bech32-encode' was removed in 1.24.0; use 'bitcoin bip173 encode-values' or 'bitcoin bip350 encode-values'"
	return 1
}

command:bech32-decode() {
	error "'bech32-decode' was removed in 1.24.0; use 'bitcoin bip173 decode' or 'bitcoin bip350 decode'"
	return 1
}

# 'bitcoin help bech32' survives as documentation even though the
# bech32 verbs themselves were removed in 1.24.0 — the educational
# BIP citations (FEAT-017) point users at the canonical plugins.
help:bech32() {
	echo "'bech32' was removed in 1.24.0; use 'bitcoin bip173' / 'bitcoin bip350'." >&2
	cite 173 "Bech32 segwit address format"
	cite 350 "Bech32m for v1+ witness addresses"
}

help:daemon() {
	echo "install, configure, and manage the bitcoind daemon." >&2
	echo "" >&2
	echo "Usage: $SELF daemon <command>" >&2
	echo "" >&2
	echo "  install [--from <src>]  install bitcoind (brew|apt|apk|source)" >&2
	echo "  enable [--user|--system]  install + start systemd/launchd unit" >&2
	echo "  disable [--user|--system] tear down the service unit" >&2
	echo "  start [--user|--system]   start bitcoind" >&2
	echo "  stop [--user|--system]    stop bitcoind" >&2
	echo "  monitor [--user|--system] tail the bitcoind log" >&2
	echo "  space [--user|--system]   show data-dir disk usage" >&2
	echo "  help <command>            show detailed help" >&2
}

help:bip173() {
	echo "Bech32 segwit address format (BIP-0173)." >&2
	echo "See '$SELF bip173 help' for available subcommands." >&2
}

help:bip350() {
	echo "Bech32m v1+ witness addresses (BIP-0350)." >&2
	echo "See '$SELF bip350 help' for available subcommands." >&2
}

help:bip174() {
	echo "Partially Signed Bitcoin Transactions (BIP-0174)." >&2
	echo "See '$SELF bip174 help' for available subcommands." >&2
}

# bip-0173/bip-0350 code starts here {{{

# hash160(stdin) — SHA-256 then RIPEMD-160 of stdin bytes; emits the
# 20-byte hash. Delegates to the bip32 libexec plugin so we don't
# duplicate the implementation (per CLAUDE.md §4 no-shared-lib: the
# plugin owns hash160; sourceable mode wraps it).
hash160() {
	if [ -n "${SELF_LIBEXEC:-}" ] && [ -x "$SELF_LIBEXEC/${SELF:-bitcoin}/bip32" ]; then
		"$SELF_LIBEXEC/${SELF:-bitcoin}/bip32" hash160
	elif command -v bip32 >/dev/null 2>&1; then
		bip32 hash160
	else
		echo "hash160: bip32 plugin not on PATH and SELF_LIBEXEC not set" >&2
		return 1
	fi
}

p2wpkh() { segwitAddress -p "$1"; }

# shellcheck disable=SC1064,SC1072,SC1073  # function() <compound-command> is legal bash; shellcheck's parser doesn't recognise the if/elif/else form here.
segwitAddress()
  if
    local OPTIND OPTARG o
    getopts hp:tv: o
  then
    shift $((OPTIND - 1))
    case "$o" in
      h) cat <<-END_USAGE
	${FUNCNAME[0]} -h
	${FUNCNAME[0]} [-t] [-v witness-version] WITNESS_PROGRAM
	${FUNCNAME[0]} [-t] -p compressed-point
	END_USAGE
        ;;
      p)
        if [[ "$OPTARG" =~ ^0[23][[:xdigit:]]{64}$ ]]
        then ${FUNCNAME[0]} "$@" "$(
          basenc --base16 -d <<<"${OPTARG^^[a-f]}" |
          hash160 |
          basenc --base16 -w0
        )"
        else echo "-p option expects a compressed point as argument" >&2
          return 1
        fi
        ;;
      t) HRP=tb ${FUNCNAME[0]} "$@" ;;
      v) WITNESS_VERSION=$OPTARG ${FUNCNAME[0]} "$@" ;;
    esac
  elif
    local hrp="${HRP:-bc}"
    [[ ! "$hrp"     =~ ^(bc|tb)$ ]]
  then return 1
  elif
    local witness_program="$1"
    [[ ! "$witness_program" =~ ^([[:xdigit:]]{2})+$ ]]
  then return 2
  elif
    local -i version=WITNESS_VERSION
    ((version < 0))
  then return 3
  elif ((version == 0))
  then
    if [[ "$witness_program" =~ ^(.{40}|.{64})$ ]] # 20 or 32 bytes
    then
      # P2WPKH or P2WSH — FEAT-035 Stream C2: bech32 encode moved
      # to bip173 (v0) / bip350 (v1+).
      "${SELF_LIBEXEC:?segwitAddress: SELF_LIBEXEC must be set}/${SELF:-bitcoin}/bip173" encode-values "$hrp" $(
        echo $version;
        echo -n "$witness_program" |
        while read -n 2; do echo 0x$REPLY; done |
        convertbits 8 5
      )
    else
       1>&2 echo For version 0, the witness program must be either 20 or 32 bytes long.
       return 4
    fi
  elif ((version <= 16))
  then
    "${SELF_LIBEXEC:?segwitAddress: SELF_LIBEXEC must be set}/${SELF:-bitcoin}/bip350" encode-values "$hrp" $(
      echo $version
      echo -n "$witness_program" |
      while read -n 2; do echo 0x$REPLY; done |
      convertbits 8 5
     )
  else return 255
  fi

segwit_verify()
  if bech32 -v "$1"
  then return 1
  else
    local hrp
    local -i witness_version
    local -ai bytes
    bech32_decode "$1" |
    {
      read hrp
      [[ "$hrp" =~ ^(bc|tb)$ ]] || return 2
      read witness_version
      (( witness_version < 0 || witness_version > 16)) && return 3
      
      bytes=($(convertbits 5 8 0)) || return 4
      if
        ((
          ${#bytes[@]} == 0 ||
          ${#bytes[@]} <  2 ||
          ${#bytes[@]} > 40
        ))
      then return 7
      elif ((
         witness_version == 0 &&
         ${#bytes[@]} != 20 &&
         ${#bytes[@]} != 32
      ))
      then return 8
      fi
    }
  fi

convertbits() {
  local -i inbits=$1 outbits=$2 pad=${3:-1} val=0 bits=0 i
  local -i maxv=$(( (1 << outbits) - 1 ))
  while read 
  do
    ((
      val=(val<<inbits)|REPLY,
      bits+=inbits
    ))
    while ((bits >= outbits))
    do
      (( bits-=outbits ))
      echo $(( (val >> bits) & maxv ))
    done
  done
  if ((pad > 0))
  then
    if ((bits))
    then echo $(( (val << (outbits - bits)) & maxv ))
    fi
  elif (( ( (val << (outbits - bits) ) & maxv ) || bits >= inbits))
  then return 1
  fi
}

segwit_decode()
  if
    test-addr() {
      bech32_decode "$addr" ||
      bech32_decode -m "$addr" 
    }
    local addr="$1"
    ! test-addr >/dev/null
  then return 1
  else
    test-addr |
    {
      local hrp
      read hrp
      if [[ ! "$hrp" =~ ^(bc|tb)$ ]]
      then return 2
      fi
      local -i version
      read version
      if ((version > 0)) && bech32_decode "$addr" >/dev/null
      then return 3
      elif ((version == 0)) && bech32_decode -m "$addr" >/dev/null
      then return 4
      elif ((version > 16))
      then return 5
      fi
      mapfile -t
      local p
      local -a bytes
      bytes=($(
        for p in ${MAPFILE[@]}
        do echo $p
        done |
        convertbits 5 8 0
      )) || return 6
      if
        ((
          ${#bytes[@]} == 0 ||
          ${#bytes[@]} <  2 ||
          ${#bytes[@]} > 40
        ))
      then return 7
      elif ((
         version == 0 &&
         ${#bytes[@]} != 20 &&
         ${#bytes[@]} != 32
      ))
      then return 8
      else
        echo $hrp
        echo $version
        printf "%02x" "${bytes[@]}"
        echo
      fi
    }
  fi

# bip-0173 code stops here }}}

# bip-0032 code starts here {{{

# bip-0032 code stops here }}}

bip49() {
  BIP32_MAINNET_PUBLIC_VERSION_CODE=0x049d7cb2 \
  BIP32_MAINNET_PRIVATE_VERSION_CODE=0x049d7878 \
  BIP32_TESTNET_PUBLIC_VERSION_CODE=0x044a5262 \
  BIP32_TESTNET_PRIVATE_VERSION_CODE=0x044a4e28 \
  bip32 "$@"
}

bip84() {
  BIP32_MAINNET_PUBLIC_VERSION_CODE=0x04b24746 \
  BIP32_MAINNET_PRIVATE_VERSION_CODE=0x04b2430c \
  BIP32_TESTNET_PUBLIC_VERSION_CODE=0x045f1cf6 \
  BIP32_TESTNET_PRIVATE_VERSION_CODE=0x045f18bc \
  bip32 "$@"
}

alias xkey=bip32
alias ykey=bip49
alias zkey=bip84

bip85()
  case "$1" in
    wif)
      shift
      $FUNCNAME 2 "$@" |
      wif
      ;;
    xprv)
      $FUNCNAME 32 ${2:-0} |
      basenc --base16 -w64 |
      {
        read left
        read right
        printf '%08X%02X%08X%08X%s00%s' $BIP32_MAINNET_PRIVATE_VERSION_CODE 0 0 0 $left $right
      } |
      basenc --base16 -d |
      bip32
      ;;
    mnemo*)
      local -i words=${2:-12} index=${3:-0} lang ent=words*32/3
      {
        case "$LANG" in
          ja?(_*))  lang=1;;
          ko?(_*))  lang=2;;
          es?(_*))  lang=3;;
          zh_CN)    lang=4;;
          zh_TW)    lang=5;;
          fr?(_*))  lang=6;;
          it?(_*))  lang=7;;
          cz?(_*))  lang=8;;
          *)        lang=0;;
        esac
        # CS = ENT / 32
        # MS = (ENT + CS) / 11
        $FUNCNAME 39 $lang $words $index
      } |
        head -c $((ent/8)) |
        basenc --base16 -w$((2*(ent/8))) |
        {
          read
          create-mnemonic "$REPLY"
        }
      ;;
    hex)
      shift
      local -i num_bytes=${1:-16} index=${2:-0}
      if ((num_bytes < 16 || num_bytes > 64))
      then echo "number of bytes ($num_bytes) out of range" >&2
        return 46
      else 
        $FUNCNAME 128169 $num_bytes $index |
        head -c $num_bytes |
        basenc --base16 -w0
      fi
      ;;
    *)
      local path="m/83696968h/${1:-0}h/${2:-0}h"
      shift; shift;
      for i in "$@"
      do path="$path/${i}h"
      done
      {
        if test -t 0 
        then 
          read -p "extended master key: "
          $SELF bip13 base58-decode <<<"$REPLY"
        else cat
        fi
      } |
      bip32 "$path" |
      tail -c 32 |
      openssl dgst -sha512 -hmac "bip-entropy-from-k" -binary |
      escape-output-if-needed
      ;;
  esac

p2pkh-address() {
  {
    printf %b "${P2PKH_PREFIX:-\x00}"
    cat
  } | $SELF bip13 base58-encode
}
 
bitcoinAddress()
  if
    local OPTIND o
    getopts ht o
  then shift $((OPTIND - 1))
    case "$o" in
      h) cat <<-END_USAGE_bitcoinAddress
	${FUNCNAME[0]} -h
	${FUNCNAME[0]} PUBLIC_POINT
	${FUNCNAME[0]} WIF_PRIVATE_KEY
	${FUNCNAME[0]} PUBLIC_EXTENDED_KEY
	END_USAGE_bitcoinAddress
        ;;
      t) P2PKH_PREFIX="\x6F" ${FUNCNAME[0]} "$@" ;;
    esac
  elif [[ "$1" =~ ^0([23]([[:xdigit:]]{2}){32}|4([[:xdigit:]]{2}){64})$ ]]
  then basenc --base16 -d <<<"${1^^[a-f]}" |hash160 | p2pkh-address 
  elif
    $SELF bip13 base58-verify <<<"$1" && 
    [[ "$($SELF bip13 base58-decode <<<"$1" |
    basenc --base16 -w76
    )" =~ ^(80|ef)([[:xdigit:]]{64})(01)?([[:xdigit:]]{8})$ ]]
  then
    {
      echo "$secp256k1 16doi lgx ${BASH_REMATCH[2]^^}l;xlfxl<*+"
      if test -n "${BASH_REMATCH[3]}"
      then echo lCx
      else echo lUx
      fi
      echo P
    } |
    dc |
    basenc --base16 -w130 |
    {
      read
      if [[ "${BASH_REMATCH[1]}" = 80 ]]
      then ${FUNCNAME[0]} "$REPLY"
      else ${FUNCNAME[0]} -t "$REPLY"
      fi
    }
  elif [[ "$1" =~ ^[xtyzv]pub ]] && $SELF bip13 base58-verify <<<"$1"
  then
    $SELF bip13 base58-decode <<<"$1" |
    head -c -4 |
    tail -c 33 |
    basenc --base16 -w0 |
    {
      read
      case "${1::1}" in
        x) ${FUNCNAME[0]} "$REPLY" ;;
        t) ${FUNCNAME[0]} -t "$REPLY" ;;
        y) 
          {
            printf %b "\x05"
            {
              printf %b%b "\x00\x14"
              echo "${REPLY^^[a-f]}" | basenc --base16 -d |
              hash160
            } | 
            hash160
          } | $SELF bip13 base58-encode
          ;;
        z) segwitAddress -p "$REPLY" ;;
        v) segwitAddress -t -p "$REPLY" ;;
        *)
          echo "${1::4} addresses NYI" >&2
          return 2
          ;;
      esac
    }
  else return 1
  fi


