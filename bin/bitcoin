#!/usr/bin/env bash

############################################################################
# Configuration section
############################################################################

############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

# Per FEAT-194: VERSION read at runtime from VERSION at the repo root
# (dev tree) or $PREFIX/share/bitcoin/version (installed). The
# hardcoded fallback is used only if both files are missing.
__d="$(cd "$(dirname "$0")" && pwd)"; __s="$(basename "$0")"
VERSION=$(cat "$__d/../VERSION" 2>/dev/null || cat "$__d/../share/$__s/version" 2>/dev/null || echo '1.0.0')
unset __d __s
SELF=$(basename $0)

# Resolve $SELF_LIBEXEC (FEAT-001 libexec convention) — checks
# in order: env override, in-checkout sibling, user install,
# system install. Each per-script repo carries its own copy of
# this snippet (no shared lib per the no-shared-library policy).
if [ -z "$SELF_LIBEXEC" ]; then
	for _d in \
		"$(cd "$(dirname "$0")/../libexec" 2>/dev/null && pwd)" \
		"$HOME/.local/libexec" \
		"/usr/local/libexec" \
		"/usr/libexec"; do
		[ -d "$_d/$SELF" ] && SELF_LIBEXEC="$_d" && break
	done
	unset _d
fi

die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $@" >&2
}

info() {
	if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$@\033[0m" >&2; fi
}

warn() {
	echo -e "$SELF: warn - \033[31;1;m$@\033[0m" >&2
}

# Log an error without exiting. Caller decides whether to continue
# or to escalate to fatal/die. See skills/logging.md.
error() {
	echo -e "$SELF: error - \033[31;1;m$@\033[0m" >&2
}

# FEAT-017: print the citation block for a BIP. Used from help:*
# functions. Resolves the local mediawiki path against the install
# prefix or the dev tree.
cite() {
	local num="$1" title="$2"
	local file
	printf -v file 'bip-%04d.mediawiki' "$num"
	local self_dir local_path=""
	self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	for cand in \
		"$self_dir/../share/doc/bitcoin/bips/$file" \
		"$HOME/.local/share/doc/bitcoin/bips/$file" \
		"/usr/local/share/doc/bitcoin/bips/$file" \
		"/usr/share/doc/bitcoin/bips/$file"; do
		if [ -f "$cand" ]; then
			local_path="$cand"
			break
		fi
	done
	cat <<-EOF

	Implements:
	  BIP-$num  $title
	  https://github.com/bitcoin/bips/blob/master/$file
	  local:   ${local_path:-<not installed>}
	EOF
}

# checks if a certain function exists: eg. has command update
has() {
	local KIND=$1
	local NAME=$2

	type -t $KIND:$NAME | grep -q function
}

escape() {
	if test -t 1; then
		xxd -p -c 0
#		cat -v
	else
		cat
	fi
}

# We need to run getops as soon as possible so we catch -d and other
# options that will modify our behaviour.
# Commands are handled at the end of this script.
while getopts "c:dqpt" flag; do
	if [ x"$1" = x'-q' ]; then
		SELF_QUIET=1
	fi
	if [ x"$1" = x'-d' ]; then
		SELF_DEBUG=1
	fi
	if [ x"$1" = x'-p' ]; then
		SELF_PASSPHRASE=1
	fi
	if [ x"$1" = x'-t' ]; then
		SELF_TEST=1
	fi
	shift 1
done

# Read configuration and set defaults if anything's not set
: ${XDG_CONFIG_HOME:="~/.config"}
: ${XDG_CACHE_HOME:="~/.cache"}
: ${XDG_DATA_HOME:="~/.local/var"}
: ${XDG_SHARE_HOME:="$HOME/.local/share"}

[ -n "$SELF_VERBOSE" ] && set -vx

_is_libexec() {
	local name="$1"
	[ -n "$SELF_LIBEXEC" ] && [ -x "$SELF_LIBEXEC/$SELF/$name" ]
}

command:help() {
	if [[ $# != 0 ]]; then
		if has command $1 || _is_libexec "$1"; then
			if has help $1; then
				help:$1
				return 0
			else
				exec "$SELF_LIBEXEC/$SELF/$1" help
			fi
		else
			echo "'$1' is not an $SELF command"
			echo ""
			echo "please see '$SELF help'"
			exit -1
		fi
	else
		cat >&2 <<ENDHELP
usage: $SELF <options> <command> [<args>]

   options:
   -d                     Enable debug output
   -q                     Enable quiet mode
   -p                     Read BIP39 passphrase
   -t                     Test mode (dry run)

   $SELF implements a frontend for various bitcoin tools.

generic commands:
   help <command>          show detailed help for a command
   version                 print the version of $SELF

setup:
   daemon                  install and manage bitcoind
   backend                 manage blockchain backend (mempool|bitcoind|blockstream)

wallet & transactions:
   wallet                  create and manage wallets
   tx                      build, sign, broadcast transactions
   utxo                    list, freeze, select UTXOs

blockchain primitives:
   descriptor              emit wallet descriptors
   bip173                  Bech32 segwit address format (BIP-0173)
   bip350                  Bech32m v1+ witness addresses (BIP-0350)
   bip174                  Partially Signed Bitcoin Transactions (BIP-0174)

advanced:
   price                   BTC/EUR price oracle
   tax                     tax reporting labels
   modules                 list available libexec plugins

see '$SELF help <command>' for detailed usage of each command.
ENDHELP
	fi
}

command:version() {
	echo $VERSION
}

command:modules() {
	[ -d "$SELF_LIBEXEC/$SELF" ] && (cd "$SELF_LIBEXEC/$SELF" && ls)
}

