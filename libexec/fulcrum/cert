#!/usr/bin/env bash

############################################################################
# fulcrum cert (FEAT-057) — generate the self-signed TLS cert+key the
# Fulcrum SSL/WSS port requires.
#
#   fulcrum cert [--force]
#
# openssl is already a package dependency (.rpk/depends/openssl). The
# pair lands in the config dir ($FULCRUM_CONFIG_DIR, else the per-user
# default); an existing pair is refused without --force.
############################################################################

[ -n "$SELF_DEBUG" ] && set -vx

SELF=$(basename "$0")

info()  { if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$*\033[0m" >&2; fi; }
warn()  { echo -e "$SELF: warn - \033[31;1;m$*\033[0m" >&2; }
error() { echo -e "$SELF: error - \033[31;1;m$*\033[0m" >&2; }

cert:_os() {
	local os="${FULCRUM_OS:-}"
	[ -n "$os" ] && { printf '%s\n' "$os"; return; }
	case "$(uname -s)" in Linux) echo linux ;; Darwin) echo macos ;; *) echo unknown ;; esac
}

cert:_dir() {
	if [ -n "${FULCRUM_CONFIG_DIR:-}" ]; then printf '%s\n' "$FULCRUM_CONFIG_DIR"; return 0; fi
	# Harmonized (FEAT-308): ~/.fulcrum on every platform.
	printf '%s/.fulcrum\n' "$HOME"
}

help:cert() {
	cat >&2 <<-ENDHELP
	usage: fulcrum cert [--force]

	  Generate a self-signed cert.pem/key.pem pair into the config dir
	  for the Fulcrum SSL port. Refuses to overwrite an existing pair
	  without --force.
	ENDHELP
}

command:cert() {
	local force=0
	while [ $# -gt 0 ]; do
		case "$1" in
			--force)        force=1 ;;
			-h|--help|help) help:cert; return 0 ;;
			*) warn "cert: unknown argument '$1'"; return 1 ;;
		esac
		shift
	done

	command -v openssl >/dev/null 2>&1 || { error "cert: 'openssl' not found on PATH"; return 1; }

	local dir cert key
	dir="$(cert:_dir)"; cert="$dir/cert.pem"; key="$dir/key.pem"
	mkdir -p "$dir" || { error "cert: cannot create config dir '$dir'"; return 1; }

	if { [ -f "$cert" ] || [ -f "$key" ]; } && [ "$force" != 1 ]; then
		warn "cert: '$cert'/'$key' already exist; pass --force to overwrite"
		return 1
	fi

	if ! openssl req -x509 -newkey rsa:2048 -sha256 -days 3650 -nodes \
		-keyout "$key" -out "$cert" -subj "/CN=fulcrum" >/dev/null 2>&1; then
		error "cert: openssl failed to generate the certificate"
		return 1
	fi
	chmod 600 "$key" 2>/dev/null
	info "wrote $cert and $key"
}

verb="${1:-cert}"
case "$verb" in
	-h|--help|help) help:cert; exit 0 ;;
esac
# `fulcrum cert [--force]` — the verb is the command; pass all args through.
command:cert "$@"
exit $?
