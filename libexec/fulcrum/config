#!/usr/bin/env bash

############################################################################
# fulcrum config (FEAT-057) — render and tweak fulcrum.conf.
#
#   config init [--ssl|--no-ssl]   write a curated fulcrum.conf
#   config show                    print the effective file
#   config get <key>               read one key
#   config set <key> <val>         edit one key (curated allow-list)
#   config validate                sanity-check the deployment
#
# fulcrum.conf lives in the config dir ($FULCRUM_CONFIG_DIR, else the
# per-user/system default). The curated subset keeps an educational
# surface over Fulcrum's ~70 options. No shared library (§4/§5): the
# path helpers are this file's own copy.
############################################################################

[ -n "$SELF_DEBUG" ] && set -vx

SELF=$(basename "$0")

die()   { echo "$1" >&2; exit "${2:-1}"; }
debug() { [ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $*" >&2; }
info()  { if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$*\033[0m" >&2; fi; }
warn()  { echo -e "$SELF: warn - \033[31;1;m$*\033[0m" >&2; }
error() { echo -e "$SELF: error - \033[31;1;m$*\033[0m" >&2; }

has() { type -t "$1:$2" | grep -q function; }

# Curated set of keys `config set` will touch.
CONFIG_ALLOW="db_mem fast-sync max_history peering announce hostname banner tcp ssl"

config:_os() {
	local os="${FULCRUM_OS:-}"
	[ -n "$os" ] && { printf '%s\n' "$os"; return; }
	case "$(uname -s)" in Linux) echo linux ;; Darwin) echo macos ;; *) echo unknown ;; esac
}

config:_dir() {
	local mode="${1:-user}"
	if [ -n "${FULCRUM_CONFIG_DIR:-}" ]; then printf '%s\n' "$FULCRUM_CONFIG_DIR"; return 0; fi
	if [ "$mode" = system ]; then printf '%s/etc/fulcrum\n' "${FULCRUM_ROOT:-}"
	elif [ "$(config:_os)" = macos ]; then printf '%s/Library/Application Support/Fulcrum\n' "$HOME"
	else printf '%s/fulcrum\n' "${XDG_CONFIG_HOME:-$HOME/.config}"; fi
}

config:_file() { printf '%s/fulcrum.conf\n' "$(config:_dir "${1:-user}")"; }

# Index data dir (the `datadir =` line written into fulcrum.conf).
config:_datadir() {
	if [ -n "${FULCRUM_DATADIR:-}" ]; then printf '%s\n' "$FULCRUM_DATADIR"; return 0; fi
	printf '%s/.fulcrum\n' "$HOME"
}

# bitcoind RPC reachable? $FULCRUM_NODE_OK forces the answer for tests.
config:_node_reachable() {
	case "${FULCRUM_NODE_OK:-}" in yes|1|true) return 0 ;; no|0|false) return 1 ;; esac
	local hp="${FULCRUM_RPC_ADDR:-127.0.0.1:8332}" host port
	host="${hp%:*}"; port="${hp##*:}"
	(exec 3<>"/dev/tcp/$host/$port") 2>/dev/null && return 0
	return 1
}

# Is <port> in use? $FULCRUM_PORT_BUSY forces a single busy port for tests.
config:_port_in_use() {
	local port="$1"
	[ -n "${FULCRUM_PORT_BUSY:-}" ] && [ "$port" = "$FULCRUM_PORT_BUSY" ] && return 0
	(exec 3<>"/dev/tcp/127.0.0.1/$port") 2>/dev/null && { exec 3>&- 2>/dev/null; return 0; }
	return 1
}

config:_get_raw() {
	local key="$1" file="$2"
	sed -n -E "s/^[[:space:]]*${key}[[:space:]]*=[[:space:]]*(.*)$/\1/p" "$file" | head -1
}

# ---------------------------------------------------------------------------
# init
# ---------------------------------------------------------------------------

help:init() {
	cat >&2 <<-ENDHELP
	usage: fulcrum config init [--ssl | --no-ssl] [--system]

	  Write a curated fulcrum.conf wired to the local bitcoind. Cookie
	  auth by default; switches to rpcuser/rpcpassword (from the secret
	  store) when the node was brought up with rpcauth. SSL on by default.
	ENDHELP
}

command:init() {
	local mode=user ssl=1
	while [ $# -gt 0 ]; do
		case "$1" in
			--ssl)    ssl=1 ;;
			--no-ssl) ssl=0 ;;
			--system) mode=system ;;
			--user)   mode=user ;;
			-h|--help|help) help:init; return 0 ;;
			*) warn "init: unknown argument '$1'"; return 1 ;;
		esac
		shift
	done

	local dir file datadir
	dir="$(config:_dir "$mode")"; file="$(config:_file "$mode")"
	datadir="$(config:_datadir)"
	mkdir -p "$dir" || { error "init: cannot create config dir '$dir'"; return 1; }

	# Auth: rpcuser/rpcpassword from secret when present, else cookie.
	local rpcpass auth
	rpcpass="$(secret get "bitcoin/rpc/bitcoin" 2>/dev/null)"
	if [ -n "$rpcpass" ]; then
		auth="rpcuser = bitcoin"$'\n'"rpcpassword = $rpcpass"
		info "init: using rpcuser/rpcpassword from secret store"
	else
		auth="rpccookie = ${FULCRUM_NODE_DATADIR:-$HOME/.bitcoin}/.cookie"
	fi

	{
		echo "# fulcrum.conf — generated by 'fulcrum config init'"
		echo "datadir = $datadir"
		echo "bitcoind = 127.0.0.1:8332"
		echo "$auth"
		echo "tcp = 0.0.0.0:50001"
		if [ "$ssl" = 1 ]; then
			echo "ssl = 0.0.0.0:50002"
			echo "cert = $dir/cert.pem"
			echo "key = $dir/key.pem"
		fi
		echo "admin = 127.0.0.1:8000"
		echo "db_mem = 2048"
		echo "fast-sync = 1024"
		echo "peering = false"
	} > "$file" || { error "init: cannot write '$file'"; return 1; }
	info "wrote $file"
}

# ---------------------------------------------------------------------------
# show / get / set
# ---------------------------------------------------------------------------

help:show() { echo "usage: fulcrum config show   — print the effective fulcrum.conf" >&2; }
command:show() {
	for a in "$@"; do case "$a" in -h|--help|help) help:show; return 0 ;; esac; done
	local file; file="$(config:_file)"
	[ -f "$file" ] || { error "show: no config at '$file' (run 'fulcrum config init')"; return 1; }
	cat "$file"
}

help:get() { echo "usage: fulcrum config get <key>" >&2; }
command:get() {
	case "${1:-}" in ""|-h|--help|help) help:get; [ -z "${1:-}" ] && return 1 || return 0 ;; esac
	local key="$1" file val; file="$(config:_file)"
	[ -f "$file" ] || { error "get: no config at '$file' (run 'fulcrum config init')"; return 1; }
	val="$(config:_get_raw "$key" "$file")"
	if [ -z "$val" ]; then error "get: key '$key' not set"; return 1; fi
	printf '%s\n' "$val"
}

help:set() { echo "usage: fulcrum config set <key> <value>   (allowed: $CONFIG_ALLOW)" >&2; }
command:set() {
	case "${1:-}" in -h|--help|help) help:set; return 0 ;; esac
	local key="$1" val="$2" file; file="$(config:_file)"
	if [ -z "$key" ] || [ $# -lt 2 ]; then error "set: usage: config set <key> <value>"; return 1; fi
	# Curated allow-list — reject anything else, naming the key.
	local ok=0 k
	for k in $CONFIG_ALLOW; do [ "$k" = "$key" ] && ok=1; done
	if [ "$ok" = 0 ]; then
		error "set: key '$key' is not in the editable allow-list ($CONFIG_ALLOW)"
		return 1
	fi
	[ -f "$file" ] || { error "set: no config at '$file' (run 'fulcrum config init')"; return 1; }
	if grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$file"; then
		sed -i -E "s|^[[:space:]]*${key}[[:space:]]*=.*|${key} = ${val}|" "$file"
	else
		printf '%s = %s\n' "$key" "$val" >> "$file"
	fi
	info "set $key = $val"
}

# ---------------------------------------------------------------------------
# validate
# ---------------------------------------------------------------------------

help:validate() {
	cat >&2 <<-ENDHELP
	usage: fulcrum config validate

	  Check the deployment: bitcoind RPC reachable, cert/key present if
	  ssl is set, and the configured ports free. Emits a distinct error
	  per failed check and exits non-zero if any fail.
	ENDHELP
}

command:validate() {
	for a in "$@"; do case "$a" in -h|--help|help) help:validate; return 0 ;; esac; done
	local file dir; file="$(config:_file)"; dir="$(config:_dir)"
	[ -f "$file" ] || { error "validate: no config at '$file' (run 'fulcrum config init')"; return 1; }

	local fails=0

	if ! config:_node_reachable; then
		error "validate: bitcoind RPC unreachable at ${FULCRUM_RPC_ADDR:-127.0.0.1:8332}"
		fails=$((fails + 1))
	fi

	local ssl; ssl="$(config:_get_raw ssl "$file")"
	if [ -n "$ssl" ]; then
		local cert; cert="$(config:_get_raw cert "$file")"; : "${cert:=$dir/cert.pem}"
		if [ ! -f "$cert" ]; then
			error "validate: ssl is set but cert '$cert' is missing (run 'fulcrum cert')"
			fails=$((fails + 1))
		fi
	fi

	local line addr port
	for line in tcp ssl admin; do
		addr="$(config:_get_raw "$line" "$file")"
		[ -n "$addr" ] || continue
		port="${addr##*:}"
		if config:_port_in_use "$port"; then
			error "validate: configured $line port $port is already in use"
			fails=$((fails + 1))
		fi
	done

	if [ "$fails" -gt 0 ]; then
		error "validate: $fails check(s) failed"
		return 1
	fi
	info "validate: all checks passed"
}

# ---------------------------------------------------------------------------
# help / dispatch
# ---------------------------------------------------------------------------

command:help() {
	cat >&2 <<-ENDHELP
	usage: fulcrum config <init|show|get|set|validate> [args]

	  init [--ssl|--no-ssl]   write a curated fulcrum.conf
	  show                    print the effective file
	  get <key>               read one key
	  set <key> <value>       edit one key (allow-list: $CONFIG_ALLOW)
	  validate                check node / cert / ports
	ENDHELP
}

verb="${1:-help}"; [ $# -gt 0 ] && shift
if has command "$verb"; then
	command:"$verb" "$@"
	exit $?
else
	error "config: unknown subcommand '$verb'"
	command:help
	exit 1
fi
