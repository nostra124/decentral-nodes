install_system() {
	local migrate="$1"
	local elements_bin; elements_bin=$(daemon:_resolve_bin elementsd)

	if [ -z "$elements_bin" ]; then
		error "elementsd not found — run \`liquid daemon install\` first"
		return 1
	fi

	# Ensure liquid user exists
	if ! getent passwd liquid >/dev/null 2>&1; then
		info "creating liquid service account"
		sudo useradd --system --shell /usr/sbin/nologin --home-dir /var/lib/liquid liquid
	fi

	# Ensure data directory exists with correct ownership
	sudo mkdir -p /var/lib/liquid
	sudo chown liquid:liquid /var/lib/liquid
	sudo chmod 750 /var/lib/liquid

	# Join bitcoin group for cookie access (BUG-051)
	daemon:_join_bitcoin_group liquid

	# Write systemd unit
	sudo tee "/etc/systemd/system/${ELEMENTS_SVC}.service" > /dev/null <<EOF
[Unit]
Description=Liquid Network Node (Elements)
After=network.target bitcoind.service
Wants=bitcoind.service

[Service]
Type=simple
User=liquid
Group=liquid
ExecStart=${elements_bin} --elements-dir=/var/lib/liquid --network=${ELEMENTS_NETWORK}
Restart=on-failure
RestartSec=30
StandardOutput=file:/var/lib/liquid/log
StandardError=file:/var/lib/liquid/log

[Install]
WantedBy=multi-user.target
EOF
	sudo systemctl daemon-reload
	sudo systemctl enable "${ELEMENTS_SVC}.service"
	info "wrote /etc/systemd/system/${ELEMENTS_SVC}.service"
	info ""
	info "next:"
	info "    sudo systemctl start ${ELEMENTS_SVC}.service"
	info "    liquid daemon status"
}

