#!/usr/bin/env bash
#
# DEPRECATED: 'bitcoin mnemonic-to-seed' is an alias for
# 'bitcoin bip39 mnemonic-to-seed' as of 1.23.0 (FEAT-035).
# This shim emits one warn line and forwards every argument and
# stdin byte to the canonical subcommand. Removal target: 1.24.0.
#
# The implementation moved to libexec/bitcoin/bip39 verbatim. See
# bitcoin-bip39(1) and bitcoin-mnemonic-to-seed(1).

[ -n "$SELF_DEBUG" ] && set -vx

SELF=$(basename "$0")

# Match the existing logging convention (skills/logging.md §4) so
# the warn line styles match every other plugin.
echo -e "$SELF: warn - \033[31;1;m'$SELF' is deprecated since 1.23.0; use 'bitcoin bip39 mnemonic-to-seed' (will be removed in 1.24.0)\033[0m" >&2

exec "$(dirname "$0")/bip39" mnemonic-to-seed "$@"
