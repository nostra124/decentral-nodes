#!/usr/bin/env bash

############################################################################
# Configuration section
############################################################################

############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

VERSION='0.6'
SELF=$(basename $0)

die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $@" >&2
}

info() {
	if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$@\033[0m" >&2; fi
}

warn() {
	echo -e "$SELF: warn - \033[31;1;m$@\033[0m" >&2
}

# checks if a certain function exists: eg. has command update
has() {
	local KIND=$1
	local NAME=$2

	type -t $KIND:$NAME | grep -q function
}

escape() {
	if test -t 1; then
		xxd -p -c 0
#		cat -v
	else
		cat
	fi
}

# We need to run getops as soon as possible so we catch -d and other
# options that will modify our behaviour.
# Commands are handled at the end of this script.
while getopts "c:dqpt" flag; do
	if [ x"$1" = x'-q' ]; then
		SELF_QUIET=1
	fi
	if [ x"$1" = x'-d' ]; then
		SELF_DEBUG=1
	fi
	if [ x"$1" = x'-p' ]; then
		SELF_PASSPHRASE=1
	fi
	if [ x"$1" = x'-t' ]; then
		SELF_TEST=1
	fi
	shift 1
done

# Read configuration and set defaults if anything's not set
: ${XDG_CONFIG_HOME:="~/.config"}
: ${XDG_CACHE_HOME:="~/.cache"}
: ${XDG_DATA_HOME:="~/.local/var"}
: ${XDG_SHARE_HOME:="$HOME/.local/share"}

[ -n "$SELF_VERBOSE" ] && set -vx

command:help() {
	if [[ $# != 0 ]]; then
		if ! has command $1; then
			echo "'$1' is not an $SELF command"
			echo ""
			echo "please see '$SELF help'"
			exit -1
		elif ! has help $1; then
			echo "No help found for '$1'"
			echo ""
			echo "please see '$SELF help'"
			exit -2
		else
			help:$1
			return 0
		fi
	else
		cat >&2 <<ENDHELP
usage: $SELF <options> <command>

   options:
   -d                     Enable debug output
   -q                     Enable quiet mode
   -p                     Read BIP39 passphrase

   $SELF implements a frontent for various bitcoin tools.

generic commands:
   help                    print this help message
   help <command>          prints command specific help.
   version                 print the version of $SELF

bip39 (mnemonic) commands:
   words [wordlist]        print the specified wordlist valid for mnemomics
   create [bits|ent]       create the mnemonic based on bitlenght or entropy
   check <mnemonic>        check the validity of the given mnemonic
   seed <mnemonic>         creates the seed based on the given mnemonic (hex)

ENDHELP
	fi
}

command:version() {
	echo $VERSION
}

# This file requires extended globs to be parsed
shopt -s extglob

command:words() {
	local LANG=$1
	test -z "$LANG" && LANG="english"
	cat ${XDG_SHARE_HOME}/bitcoin/$SELF/$LANG.txt
}

command:create() {
	local -a wordlist=($(command:words))
	if (( ${#wordlist[@]} != 2048 )); then
		fatal "unexpected number of words (${#wordlist[@]}) in wordlist array" 1
	fi

	if [[ $1 =~ ^(128|160|192|224|256)$ ]]; then
		ENTROPY=$(openssl rand -hex $(($1/8)))
		debug "executing $FUNCNAME $ENTROPY"
		$FUNCNAME $ENTROPY
	elif [[ "$1" =~ ^([[:xdigit:]]{2}){16,32}$ ]]; then
		local hexnoise="${ENTROPY^^}"
		local -i ENT=${#hexnoise}*4 #bits
		if ((ENT % 32)); then
			fatal "entropy must be a multiple of 32, yet it is $ENT"
		fi
		{ 
			# A checksum is generated by taking the first <pre>ENT / 32</pre> bits of its SHA256 hash
			local -i CS=ENT/32
			local -i MS=(ENT+CS)/11 #bits
			echo "$MS 1- sn16doi"
			echo "$hexnoise 2 $CS^*"
			echo -n "${hexnoise^^[a-f]}" | basenc --base16 -d | openssl dgst -sha256 -binary |
			head -c1 |
			basenc --base16
			echo "0k 2 8 $CS -^/+"
			echo "[800 ~r ln1-dsn0<x]dsxx Aof"
		} | dc | while read -r
		do 
			echo ${wordlist[REPLY]}
		done |
		{
			mapfile -t
			echo "${MAPFILE[*]}"
		} | cat
	elif (($# == 0))
		then $FUNCNAME 160
	else
		fatal "parameters have insufficient entropy or wrong format"
	fi
}

command:check() {
	if [[ $# =~ ^(12|15|18|21|24)$ ]]; then
		local -a wordlist=($(command:words))
		local -Ai wordlist_reverse
		local -i i
		local word
		for word in "${wordlist[@]}"; do
			wordlist_reverse[$word]=++i
		done

		local dc_script='16o0'
		for word in $@; do
			if ((${wordlist_reverse[$word]})); then
				dc_script="$dc_script 2048*${wordlist_reverse[$word]} 1-+"
			else
				warn "$FUNCNAME: unreckognized word in mnemonic: $word"
				return 1
			fi
		done
		dc_script="$dc_script 2 $(($#*11/33))^ 0k/ p"
		local ENTROPY=$(dc -e "$dc_script" | { read -r; printf "%$(($#*11*32/33/4))s" $REPLY; } | sed 's/ /0/g')
		debug "executing command:bip39-create $ENTROPY"
		if $(command:create $ENTROPY | grep -q " ${@: -1}$"); then
			return 0
		else
			warn "$FUNCNAME: wrong mnemonic checksum"
			return 2
		fi
	else
		warn "$FUNCNAME: unexpected number of words"
		return 3
	fi
}

command:seed() {
	if $(command:check "$@"); then
		if [ -n "$SELF_PASSPHRASE" ]; then
			read -p "Passphrase: "
			local BIP39_PASSPHRASE="$REPLY"
		fi

      		openssl kdf -keylen 64 -binary \
			-kdfopt digest:SHA512 \
			-kdfopt pass:"$*" \
			-kdfopt salt:"mnemonic$BIP39_PASSPHRASE" \
			-kdfopt iter:2048 \
			PBKDF2 | xxd -p -c 256
	fi
}

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

#------------------------------------------------------------------------------
# If this is a builtin command, execute it, otherwise fall through
if has command $1; then
	debug "executing command:$1 ${@:2}"
	command:$1 "${@:2}" # array slice skipping first element
	exit $?
else
	warn "unknown command: $1 ${@:2} see bitcoin $SELF help"
	exit -1
fi
