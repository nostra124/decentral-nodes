#!/usr/bin/env bash

############################################################################
# Configuration section
############################################################################

############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

VERSION='0.6'
SELF=$(basename $0)

die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $@" >&2
}

info() {
	if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$@\033[0m" >&2; fi
}

warn() {
	echo -e "$SELF: warn - \033[31;1;m$@\033[0m" >&2
}

# Log an error without exiting. See skills/logging.md.
error() {
	echo -e "$SELF: error - \033[31;1;m$@\033[0m" >&2
}

# checks if a certain function exists: eg. has command update
has() {
	local KIND=$1
	local NAME=$2

	type -t $KIND:$NAME | grep -q function
}

escape() {
	if test -t 1; then
		xxd -p -c 0
#		cat -v
	else
		cat
	fi
}

# We need to run getops as soon as possible so we catch -d and other
# options that will modify our behaviour.
# Commands are handled at the end of this script.
while getopts "c:dqpt" flag; do
	if [ x"$1" = x'-q' ]; then
		SELF_QUIET=1
	fi
	if [ x"$1" = x'-d' ]; then
		SELF_DEBUG=1
	fi
	if [ x"$1" = x'-p' ]; then
		SELF_PASSPHRASE=1
	fi
	if [ x"$1" = x'-t' ]; then
		SELF_TEST=1
	fi
	shift 1
done

# Read configuration and set defaults if anything's not set
: ${XDG_CONFIG_HOME:="$HOME/.config"}
: ${XDG_CACHE_HOME:="$HOME/.cache"}
: ${XDG_DATA_HOME:="$HOME/.local/var"}
: ${XDG_SHARE_HOME:="$HOME/.local/share"}

[ -n "$SELF_VERBOSE" ] && set -vx

command:help() {
	if [[ $# != 0 ]]; then
		if ! has command $1; then
			echo "'$1' is not an $SELF command"
			echo ""
			echo "please see '$SELF help'"
			exit -1
		elif ! has help $1; then
			echo "No help found for '$1'"
			echo ""
			echo "please see '$SELF help'"
			exit -2
		else
			help:$1
			return 0
		fi
	else
		cat >&2 <<ENDHELP
usage: $SELF <options> <command>

   options:
   -d                     Enable debug output
   -q                     Enable quiet mode
   -p                     Read BIP39 passphrase

   $SELF manages the bitcoind daemon.

   see '$SELF help <command>' for detailed usage.

commands:
   install [--from <src>]   install bitcoind (brew|apt|apk|source)
   enable [--user]          install + start unit (default: system)
   disable [--user]         stop service and remove unit
   start [--user]           start bitcoind
   stop [--user]            stop bitcoind
   monitor [--user]         tail the bitcoind log
   password [--user]        show RPC credentials from config
   space [--user]           show data-dir disk usage
   help <command>           show detailed help for a command

   The default mode is --system; pass --user for the rootless
   per-user service.
ENDHELP
	fi
}

command:version() {
	echo $VERSION
}

# This file requires extended globs to be parsed
shopt -s extglob

# BUG-015 (branch c): the legacy start / stop / monitor / space
# verbs are folded onto the same systemd / launchd service that
# `enable` installs, sharing daemon:_os / daemon:_datadir and the
# --system (default) / --user mode split. They are thin shims over
# the init system: systemctl [--user] on Linux, launchctl on macOS.

# Resolve [--user|--system] from a bare argument list. Default is
# --system (FEAT-261): the deployment-ready posture survives logout/
# reboot; --user is the explicit rootless / personal / CI opt-in.
daemon:_mode() {
	local mode=system a
	for a in "$@"; do
		case "$a" in
			--system) mode=system ;;
			--user)   mode=user ;;
		esac
	done
	printf '%s\n' "$mode"
}

# macOS launchctl domain for a mode.
daemon:_domain() {
	if [ "$1" = system ]; then printf 'system\n'; else printf 'gui/%s\n' "$(id -u)"; fi
}

# Network (FEAT-268): mainnet (default) | testnet | signet | regtest.
# Parsed from --network <net> / --network=<net>. mainnet keeps the bare
# unit names (backward-compatible); other networks get a -<net> suffix
# and run in PARALLEL via bitcoind's -chain (own data subdir + own
# ports), so a regtest node coexists with the mainnet one. Echoes the
# normalized name; 'invalid:<x>' + non-zero on an unknown network.
daemon:_network() {
	local net=mainnet want=0 a
	for a in "$@"; do
		if [ "$want" = 1 ]; then net="$a"; want=0; continue; fi
		case "$a" in
			--network)   want=1 ;;
			--network=*) net="${a#--network=}" ;;
		esac
	done
	case "$net" in
		main|mainnet|bitcoin) printf 'mainnet\n' ;;
		test|testnet)         printf 'testnet\n' ;;
		signet)               printf 'signet\n' ;;
		regtest)              printf 'regtest\n' ;;
		*) printf 'invalid:%s\n' "$net"; return 1 ;;
	esac
}

# BUG-048 — default bitcoind RPC port per network. `enable` preflights this
# so it never installs a unit that crash-loops on "Unable to bind ... RPC
# server" because another node (e.g. an existing MacPorts/Homebrew bitcoind)
# already owns the port. Networks take the upstream bitcoind defaults.
daemon:_rpc_port() {
	case "$1" in
		mainnet) printf '8332\n' ;;
		testnet) printf '18332\n' ;;
		signet)  printf '38332\n' ;;
		regtest) printf '18443\n' ;;
		*)       printf '8332\n' ;;
	esac
}

# BUG-048 — is <port> already accepting TCP on localhost? When
# $BITCOIN_PORT_BUSY is set it is AUTHORITATIVE (busy iff <port> matches it)
# and the real probe is skipped — so the unit suite is hermetic on a host
# that is itself running a bitcoind (set it to a sentinel like 'none' to mean
# "every port free"). Otherwise probe localhost directly via /dev/tcp.
daemon:_port_in_use() {
	local port="$1"
	if [ -n "${BITCOIN_PORT_BUSY:-}" ]; then
		[ "$port" = "$BITCOIN_PORT_BUSY" ]
		return
	fi
	(exec 3<>"/dev/tcp/127.0.0.1/$port") 2>/dev/null && { exec 3>&- 2>/dev/null; return 0; }
	return 1
}

# launchd label / systemd unit base name / log / pidfile / -chain flag
# for a network. mainnet is bare; other networks append -<net>.
daemon:_label()   { [ "$1" = mainnet ] && printf 'org.bitcoin.bitcoind\n' || printf 'org.bitcoin.bitcoind-%s\n' "$1"; }
daemon:_svcname() { [ "$1" = mainnet ] && printf 'bitcoind\n'             || printf 'bitcoind-%s\n' "$1"; }
daemon:_logname() { [ "$1" = mainnet ] && printf 'bitcoind.log\n'         || printf 'bitcoind-%s.log\n' "$1"; }
daemon:_chain()   { [ "$1" = mainnet ] || printf -- '-chain=%s\n' "$1"; }

command:start() {
	for a in "$@"; do
		case "$a" in -h|--help|help) help:start; return 0 ;; esac
	done
	local mode os net SUDO=""
	mode="$(daemon:_mode "$@")"; os="$(daemon:_os)"
	net="$(daemon:_network "$@")" || { error "start: unknown network '${net#invalid:}'"; return 1; }
	[ "$mode" = system ] && SUDO=sudo
	case "$os" in
		linux)
			if [ "$mode" = system ]; then $SUDO systemctl start "$(daemon:_svcname "$net")"
			else systemctl --user start "$(daemon:_svcname "$net")"; fi ;;
		macos)
			$SUDO launchctl kickstart "$(daemon:_domain "$mode")/$(daemon:_label "$net")" || true ;;
		*) error "start: unsupported platform '$(uname -s)'"; return 1 ;;
	esac
}

command:stop() {
	for a in "$@"; do
		case "$a" in -h|--help|help) help:stop; return 0 ;; esac
	done
	local mode os net SUDO=""
	mode="$(daemon:_mode "$@")"; os="$(daemon:_os)"
	net="$(daemon:_network "$@")" || { error "stop: unknown network '${net#invalid:}'"; return 1; }
	[ "$mode" = system ] && SUDO=sudo
	case "$os" in
		linux)
			if [ "$mode" = system ]; then $SUDO systemctl stop "$(daemon:_svcname "$net")"
			else systemctl --user stop "$(daemon:_svcname "$net")"; fi ;;
		macos)
			$SUDO launchctl kill SIGTERM "$(daemon:_domain "$mode")/$(daemon:_label "$net")" ;;
		*) error "stop: unsupported platform '$(uname -s)'"; return 1 ;;
	esac
}

command:monitor() {
	for a in "$@"; do
		case "$a" in -h|--help|help) help:monitor; return 0 ;; esac
	done
	local mode os net
	mode="$(daemon:_mode "$@")"; os="$(daemon:_os)"
	net="$(daemon:_network "$@")" || { error "monitor: unknown network '${net#invalid:}'"; return 1; }
	case "$os" in
		linux)
			if [ "$mode" = system ]; then journalctl -u "$(daemon:_svcname "$net")" -f
			else journalctl --user -u "$(daemon:_svcname "$net")" -f; fi ;;
		macos)
			# BUG-030: the operator is in the service group and the datadir
			# is group-readable, so the log is read directly (no sudo).
			tail -f "$(daemon:_datadir "$mode")/$(daemon:_logname "$net")" ;;
		*) error "monitor: unsupported platform '$(uname -s)'"; return 1 ;;
	esac
}

command:space() {
	for a in "$@"; do
		case "$a" in -h|--help|help) help:space; return 0 ;; esac
	done
	local mode datadir SUDO=""
	mode="$(daemon:_mode "$@")"
	datadir="$(daemon:_datadir "$mode")"
	[ "$mode" = system ] && SUDO=sudo
	if [ ! -d "$datadir" ]; then
		error "space: data dir '$datadir' does not exist (run 'bitcoin daemon enable' first)"
		return 1
	fi
	$SUDO du -sh "$datadir" | cut -f1
}

#------------------------------------------------------------------------------
# FEAT-034: service-managed bitcoind (daemon enable / disable).
#
# Render a platform-appropriate service unit from the templates in
# share/bitcoin/units/, install it, and (de)activate it through the
# init system: systemd on Linux, launchd on macOS, in --user (no
# root) or --system (dedicated `bitcoin` account) mode. Every
# privileged step routes through $SUDO and every absolute system
# path through $BITCOIN_DAEMON_ROOT, so the bats matrix can mock the
# init system and redirect writes into a temp dir.

# OS family: "linux" | "macos". $BITCOIN_DAEMON_OS overrides uname so
# the test matrix can exercise both branches on a single runner.
daemon:_os() {
	local os="${BITCOIN_DAEMON_OS:-}"
	if [ -z "$os" ]; then
		case "$(uname -s)" in
			Linux)  os=linux ;;
			Darwin) os=macos ;;
			*)      os=unknown ;;
		esac
	fi
	printf '%s\n' "$os"
}

# bitcoind candidates in preference order: MacPorts (/opt/local — a
# world-readable, root-owned tree, ideal for a dedicated service
# account) ahead of Homebrew (/opt/homebrew, user-owned and easily
# locked down by a tight umask), then PATH. $BITCOIN_BITCOIND overrides.
daemon:_bitcoind_candidates() {
	if [ -n "${BITCOIN_BITCOIND:-}" ]; then printf '%s\n' "$BITCOIN_BITCOIND"; return 0; fi
	# $BITCOIN_SYSTEM_BINDIRS overrides the known-dir list (test harness);
	# defaults to the world-readable MacPorts tree ahead of Homebrew. PATH
	# is always probed last. Mirrors fulcrum's $FULCRUM_SYSTEM_BINDIRS seam.
	local dirs="${BITCOIN_SYSTEM_BINDIRS-/opt/local/bin /opt/homebrew/bin}"
	local c d cand seen=" "
	for d in $dirs; do
		cand="$d/bitcoind"
		[ -x "$cand" ] || continue
		case "$seen" in *" $cand "*) continue ;; esac
		seen="$seen$cand "; printf '%s\n' "$cand"
	done
	c="$(command -v bitcoind 2>/dev/null)"
	[ -n "$c" ] && [ -x "$c" ] || return 0
	case "$seen" in *" $c "*) return 0 ;; esac
	printf '%s\n' "$c"
}

# First candidate the daemon can run. In system mode each candidate is
# verified by running it as the service account (-datadir avoids probing
# the operator's home, which the account can't read); a non-world-
# readable Homebrew keg is skipped here instead of crash-looping under
# launchd. Prints the chosen path; errors + non-zero if none qualifies.
# $SUDO comes from the caller (dynamic scope).
daemon:_select_bitcoind() {
	local mode=$1 user=$2 datadir=$3 c found=""
	while IFS= read -r c; do
		found="$c"
		if [ "$mode" != system ]; then printf '%s\n' "$c"; return 0; fi
		if $SUDO -u "$user" "$c" -datadir="$datadir" --version >/dev/null 2>&1; then
			printf '%s\n' "$c"; return 0
		fi
	done < <(daemon:_bitcoind_candidates)
	if [ -z "$found" ]; then
		error "enable: no 'bitcoind' found; run 'bitcoin daemon install' first"
	else
		error "enable: service account '$user' cannot run any bitcoind found"
		error "  tried: $(daemon:_bitcoind_candidates | tr '\n' ' ')"
		error "  a binary execs but fails as '$user' (permissions on the binary,"
		error "  a parent directory, or a linked library — a restrictive umask on"
		error "  a Homebrew keg is the usual cause). Prefer a MacPorts install"
		error "  (world-readable /opt/local), or open the brew tree:"
		error "      sudo chmod -R o+rX \"\$(brew --prefix)\"/{Cellar,opt,lib}"
	fi
	return 1
}

# DESTDIR-style prefix for system-level absolute paths (default none).
daemon:_root() { printf '%s' "${BITCOIN_DAEMON_ROOT:-}"; }

# Directory holding the unit-file templates.
daemon:_units_dir() {
	if [ -n "${SELF_UNITS:-}" ]; then
		printf '%s\n' "$SELF_UNITS"
		return 0
	fi
	(cd "$(dirname "$0")/../../share/bitcoin/units" 2>/dev/null && pwd)
}

# Data directory for the given mode.
daemon:_datadir() {
	local mode=$1
	if [ "$mode" = system ]; then
		printf '%s/var/lib/bitcoin\n' "$(daemon:_root)"
	elif [ "$(daemon:_os)" = macos ]; then
		printf '%s/Library/Application Support/Bitcoin\n' "$HOME"
	else
		printf '%s/.bitcoin\n' "$HOME"
	fi
}

# Directory holding bitcoin.conf. FHS: system config lives under /etc
# (config in /etc, data in /var/lib); user mode keeps it in the datadir.
daemon:_confdir() {
	local mode=$1
	if [ "$mode" = system ]; then printf '%s/etc/bitcoin\n' "$(daemon:_root)"
	else daemon:_datadir "$mode"; fi
}

# Service account the daemon runs as. macOS uses the '_'-prefixed
# hidden-account convention; both OSes get a dedicated same-named group
# (the account's primary group), so files the daemon writes are reachable
# by the operator once they join it.
daemon:_user() {
	local mode=$1
	if [ "$mode" != system ]; then
		printf '%s\n' "${USER:-$(id -un)}"
	elif [ "$(daemon:_os)" = macos ]; then
		printf '_bitcoin\n'
	else
		printf 'bitcoin\n'
	fi
}

# Create the dedicated service account + group (idempotent). macOS gets a
# hidden account pinned in the system UID range (mirrors the lightning
# daemon's _clightning); Linux a --system user with a matching
# --user-group. Relies on the caller's $SUDO.
daemon:_ensure_account() {
	local os=$1 user=$2 datadir=$3
	id "$user" >/dev/null 2>&1 && return 0
	info "creating system user '$user'"
	if [ "$os" = macos ]; then
		local uid=295 gid
		while dscl . -list /Users UniqueID 2>/dev/null | awk '{print $2}' | grep -qx "$uid"; do
			uid=$((uid + 1))
		done
		gid=$uid
		$SUDO dscl . -create "/Groups/$user" PrimaryGroupID "$gid" || return 1
		$SUDO dscl . -create "/Users/$user" UniqueID "$uid"
		$SUDO dscl . -create "/Users/$user" PrimaryGroupID "$gid"
		$SUDO dscl . -create "/Users/$user" UserShell /usr/bin/false
		$SUDO dscl . -create "/Users/$user" NFSHomeDirectory "$datadir"
		$SUDO dscl . -create "/Users/$user" RealName "Bitcoin Core daemon"
		$SUDO dscl . -create "/Users/$user" IsHidden 1
	else
		$SUDO useradd --system --no-create-home --user-group \
			--shell /usr/sbin/nologin "$user" || return 1
	fi
}

# Add the invoking operator to the service group so they reach the datadir
# (config, cookie, log) without sudo. Takes effect on next login.
daemon:_join_group() {
	local os=$1 group=$2 op="${USER:-$(id -un)}"
	if [ "$os" = macos ]; then
		$SUDO dseditgroup -o edit -a "$op" -t user "$group" 2>/dev/null || true
	else
		$SUDO usermod -a -G "$group" "$op" 2>/dev/null || true
	fi
}

# The "can the service account actually run it" preflight now lives in
# daemon:_select_bitcoind (above): it runs each candidate as the service
# user (-datadir, --version) and skips one that execs-but-fails — the
# exec bit, every parent dir's traverse bit, and the dynamic-library
# load all in one shot. The classic failure is a Homebrew keg under
# /opt/homebrew left non-world-readable by a tight umask, which would
# otherwise make launchd crash-loop with EX_CONFIG / a dyld errno=13 and
# an empty log.

# Installed unit-file path for os × mode × network. Non-mainnet
# networks get a -<net> suffix so they install side by side with the
# mainnet unit.
daemon:_unit_path() {
	local os=$1 mode=$2 net=${3:-mainnet}
	local svc; svc="$(daemon:_svcname "$net")"
	local label; label="$(daemon:_label "$net")"
	case "$os:$mode" in
		linux:user)
			printf '%s/systemd/user/%s.service\n' \
				"${XDG_CONFIG_HOME:-$HOME/.config}" "$svc" ;;
		linux:system)
			printf '%s/etc/systemd/system/%s.service\n' "$(daemon:_root)" "$svc" ;;
		macos:user)
			printf '%s/Library/LaunchAgents/%s.plist\n' "$HOME" "$label" ;;
		macos:system)
			printf '%s/Library/LaunchDaemons/%s.plist\n' "$(daemon:_root)" "$label" ;;
		*) return 1 ;;
	esac
}

# Render a unit from its template, substituting @BITCOIND@ / @DATADIR@ /
# @USER@ and the per-network @LABEL@ / @CHAIN@ / @LOG@ / @PIDFILE@. For
# --user mode the privilege-drop directive is stripped (a `systemctl
# --user` unit may not carry User=, a LaunchAgent has no UserName).
daemon:_render() {
	local os=$1 mode=$2 datadir=$3 user=$4 bitcoind=$5 net=${6:-mainnet} tmpl rendered
	if [ "$os" = macos ]; then tmpl="$(daemon:_units_dir)/bitcoind.plist"
	else tmpl="$(daemon:_units_dir)/bitcoind.service"; fi
	[ -r "$tmpl" ] || { error "template not found: $tmpl"; return 1; }
	local label log pidfile chain conf
	label="$(daemon:_label "$net")"
	log="$datadir/$(daemon:_logname "$net")"
	pidfile="$datadir/$(daemon:_svcname "$net").pid"
	chain="$(daemon:_chain "$net")"
	conf="$(daemon:_confdir "$mode")/bitcoin.conf"
	rendered="$(sed \
		-e "s|@BITCOIND@|$bitcoind|g" \
		-e "s|@DATADIR@|$datadir|g" \
		-e "s|@CONF@|$conf|g" \
		-e "s|@USER@|$user|g" \
		-e "s|@LABEL@|$label|g" \
		-e "s|@LOG@|$log|g" \
		-e "s|@PIDFILE@|$pidfile|g" "$tmpl")"
	# Chain arg: present for non-mainnet; for mainnet drop it entirely (an
	# empty launchd ProgramArguments <string> would pass bitcoind a bogus
	# "" arg; an empty systemd token is harmless but we strip it too).
	if [ -n "$chain" ]; then
		rendered="$(printf '%s\n' "$rendered" | sed "s|@CHAIN@|$chain|g")"
	elif [ "$os" = macos ]; then
		rendered="$(printf '%s\n' "$rendered" | sed '/<string>@CHAIN@<\/string>/d')"
	else
		rendered="$(printf '%s\n' "$rendered" | sed 's| *@CHAIN@||g')"
	fi
	if [ "$mode" = user ]; then
		if [ "$os" = macos ]; then
			rendered="$(printf '%s\n' "$rendered" | sed '/<key>UserName<\/key>/{N;d;}')"
		else
			rendered="$(printf '%s\n' "$rendered" | sed '/^User=/d')"
		fi
	fi
	printf '%s\n' "$rendered"
}

help:enable() {
	cat >&2 <<-ENDHELP
	usage: $SELF enable [--user] [--network <net>] [--public --allow <cidr>]

	  Install a bitcoind service unit and bring the daemon up so it
	  survives reboots. --system (default) installs a system-wide
	  service running as a dedicated 'bitcoin' account (needs root);
	  --user installs a rootless per-user service. Idempotent.

	  --network mainnet (default) | testnet | signet | regtest. Non-
	            mainnet networks install a parallel unit (suffixed
	            -<net>) running 'bitcoind -chain=<net>' — own data
	            subdir + own ports — so they coexist with mainnet.
	  --public  Expose RPC on all interfaces. Requires --system and
	            --allow. Uses rpcauth (hash-based) instead of cookie
	            auth; password stored in secret store.
	  --allow   CIDR subnet allowed to connect (e.g. 192.168.0.0/16).
	            Required with --public.
	ENDHELP
}

help:disable() {
	cat >&2 <<-ENDHELP
	usage: $SELF disable [--user]

	  Bring the bitcoind service down and remove its unit file. The
	  data directory is preserved.
	ENDHELP
}

help:start() {
	cat >&2 <<-ENDHELP
	usage: $SELF start [--user]

	  Start the bitcoind service. Equivalent to systemctl --user start
	  or launchctl kickstart depending on platform.
	ENDHELP
}

help:stop() {
	cat >&2 <<-ENDHELP
	usage: $SELF stop [--user]

	  Stop the bitcoind service gracefully.
	ENDHELP
}

help:monitor() {
	cat >&2 <<-ENDHELP
	usage: $SELF monitor [--user]

	  Follow the bitcoind log output. On macOS reads from the
	  datadir bitcoind.log; on Linux uses journalctl.
	ENDHELP
}

help:space() {
	cat >&2 <<-ENDHELP
	usage: $SELF space [--user]

	  Show disk usage of the bitcoind data directory.
	ENDHELP
}

command:enable() {
	local mode=system public= allow= net=mainnet
	while [ $# -gt 0 ]; do
		case "$1" in
			--user)         mode=user ;;
			--system)       mode=system ;;
			--public)       public=1 ;;
			--allow)        allow="$2"; shift ;;
			--allow=*)      allow="${1#--allow=}" ;;
			--network)      net="$2"; shift ;;
			--network=*)    net="${1#--network=}" ;;
			-h|--help|help) help:enable; return 0 ;;
			*) warn "enable: unknown argument '$1'"; return 1 ;;
		esac
		shift
	done
	local _nn; _nn="$(daemon:_network "--network=$net")" \
		|| { error "enable: unknown network '$net' (mainnet|testnet|signet|regtest)"; return 1; }
	net="$_nn"
	if [ -n "$public" ]; then
		if [ "$mode" != system ]; then
			error "enable: --public requires --system"; return 1
		fi
		if [ -z "$allow" ]; then
			error "enable: --public requires --allow <cidr>"; return 1
		fi
	fi

	local os; os="$(daemon:_os)"
	case "$os" in linux|macos) ;; *)
		error "enable: unsupported platform '$(uname -s)'"; return 1 ;;
	esac

	if [ -z "$(daemon:_bitcoind_candidates)" ]; then
		error "enable: no 'bitcoind' found; run 'bitcoin daemon install' first"
		return 1
	fi

	# BUG-048 — refuse if the RPC port is already taken (e.g. an existing
	# MacPorts/Homebrew bitcoind, or a sibling already bound to this network's
	# port). Installing anyway leaves a unit that crash-loops under launchd/
	# systemd on "Unable to bind any endpoint for RPC server".
	local rpcport; rpcport="$(daemon:_rpc_port "$net")"
	if daemon:_port_in_use "$rpcport"; then
		error "enable: RPC port $rpcport ($net) is already in use — another bitcoind is running"
		error "  reuse it, stop it, or pick a different --network before enabling a node here"
		return 1
	fi

	local SUDO=""; [ "$mode" = system ] && SUDO=sudo
	local datadir user group unit
	datadir="$(daemon:_datadir "$mode")"
	user="$(daemon:_user "$mode")"
	group="$user"
	unit="$(daemon:_unit_path "$os" "$mode" "$net")" \
		|| { error "enable: no unit path for $os/$mode"; return 1; }

	# --system: dedicated service account + group; the operator joins the
	# group so they read config/cookie/log without sudo (three-user model,
	# mirrors the lightning daemon).
	if [ "$mode" = system ]; then
		daemon:_ensure_account "$os" "$user" "$datadir" \
			|| { error "enable: failed to provision service account '$user'"; return 1; }
		daemon:_join_group "$os" "$group"
	fi

	# State dir: owned by the service account, group-readable (0750) so the
	# operator (a group member) can reach it; world gets no access.
	$SUDO mkdir -p "$datadir" \
		|| { error "enable: cannot create data dir '$datadir'"; return 1; }
	if [ "$mode" = system ]; then
		$SUDO chmod 0750 "$datadir" 2>/dev/null
		$SUDO chown "$user:$group" "$datadir" 2>/dev/null
	fi

	# Config dir (FHS: /etc/bitcoin in system mode). World-traversable so the
	# service account reaches bitcoin.conf; the conf itself stays 0640.
	local confdir; confdir="$(daemon:_confdir "$mode")"
	$SUDO mkdir -p "$confdir" \
		|| { error "enable: cannot create config dir '$confdir'"; return 1; }
	[ "$mode" = system ] && $SUDO chmod 0755 "$confdir" 2>/dev/null

	# Select the bitcoind the service account can actually run (MacPorts
	# first, then Homebrew, then PATH; system mode verifies each as the
	# service account so a non-runnable Homebrew keg is skipped here
	# rather than crash-looped under launchd).
	local bitcoind
	bitcoind="$(daemon:_select_bitcoind "$mode" "$user" "$datadir")" || return 1
	# Generate or update bitcoin.conf. Note: daemon=1 is NOT set here
	# because launchd / systemd already manages the process — with
	# daemon=1 bitcoind forks, the original PID exits, KeepAlive
	# spawns another instance, and they collide on the datadir lock.
	local conf="$confdir/bitcoin.conf"
	if [ -n "$public" ]; then
		local rpcuser password salt_hex hmac tmpconf
		rpcuser="bitcoin"
		password="$(LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom 2>/dev/null | head -c 32)"
		salt_hex="$(openssl rand -hex 16 2>/dev/null)"
		hmac="$(printf '%s' "$salt_hex" | xxd -r -p | openssl dgst -sha256 -hmac "$password" 2>/dev/null | sed 's/.* //')"
		tmpconf="$(mktemp)"
		cat > "$tmpconf" <<-CONF
		# bitcoin.conf — generated by bitcoin daemon enable --public
		server=1
		rpcauth=$rpcuser:${salt_hex}\$${hmac}
		rpcbind=0.0.0.0
		rpcallowip=$allow
		CONF
		# BUG-030: the datadir is owned by the service account, so install
		# the config through $SUDO (a bare redirect runs as the invoking
		# user and fails with EACCES). 0640 + group ownership lets the
		# operator read it via group membership. Fail loudly on error.
		$SUDO install -m 0640 "$tmpconf" "$conf" \
			|| { rm -f "$tmpconf"; error "enable: cannot write config '$conf'"; return 1; }
		rm -f "$tmpconf"
		[ "$mode" = system ] && $SUDO chown "$user:$group" "$conf" 2>/dev/null
		secret init bitcoin >/dev/null 2>&1 || true
		printf '%s' "$password" | secret set "bitcoin/rpc:${rpcuser}" 2>/dev/null
		info "created $conf (public: $allow)"
		info "stored password in secret:bitcoin/rpc:${rpcuser}"
	elif [ ! -f "$conf" ]; then
		local tmpconf; tmpconf="$(mktemp)"
		{
			cat <<-CONF
			# bitcoin.conf — generated by bitcoin daemon enable
			# server=1 enables RPC with cookie auth (.cookie in datadir).
			# bitcoin-cli -datadir=@DATADIR@ uses it automatically.
			server=1
			CONF
			# FEAT-274: in system mode make the .cookie group-readable so
			# sibling daemons (lightning, fulcrum) whose service account is
			# in the bitcoin group can authenticate to this node without
			# their own RPC credentials (Bitcoin Core 28+; skipped if the
			# binary predates -rpccookieperms).
			if [ "$mode" = system ] && "$bitcoind" -help 2>/dev/null | grep -q -- '-rpccookieperms'; then
				printf '%s\n' 'rpccookieperms=group'
			fi
		} > "$tmpconf"
		# BUG-030: install through $SUDO; a bare redirect into the service-
		# owned datadir fails with EACCES yet still printed "created". 0640
		# + group ownership lets the operator read it via group membership.
		$SUDO install -m 0640 "$tmpconf" "$conf" \
			|| { rm -f "$tmpconf"; error "enable: cannot write config '$conf'"; return 1; }
		rm -f "$tmpconf"
		[ "$mode" = system ] && $SUDO chown "$user:$group" "$conf" 2>/dev/null
		info "created $conf (cookie auth)"
	fi

	# Render + install the unit (idempotent: overwrites in place).
	local tmp; tmp="$(mktemp)"
	daemon:_render "$os" "$mode" "$datadir" "$user" "$bitcoind" "$net" > "$tmp" \
		|| { rm -f "$tmp"; return 1; }
	$SUDO mkdir -p "$(dirname "$unit")" \
		|| { rm -f "$tmp"; error "enable: cannot create unit dir"; return 1; }
	$SUDO install -m 0644 "$tmp" "$unit" \
		|| { rm -f "$tmp"; error "enable: cannot install unit '$unit'"; return 1; }
	rm -f "$tmp"
	info "installed $unit"

	# Record the datadir so bitcoin backend auto can find it.
	local bitcoin_confdir="$HOME/.config/bitcoin"
	mkdir -p "$bitcoin_confdir"
	printf '%s\n' "$datadir" > "$bitcoin_confdir/bitcoind-datadir"

	# Activate through the init system (per-network label / unit name).
	local label svc
	label="$(daemon:_label "$net")"; svc="$(daemon:_svcname "$net")"
	if [ "$os" = macos ]; then
		local domain
		if [ "$mode" = system ]; then domain="system"; else domain="gui/$(id -u)"; fi
		$SUDO launchctl bootstrap "$domain" "$unit" 2>/dev/null
		$SUDO launchctl enable "$domain/$label" 2>/dev/null
	elif [ "$mode" = system ]; then
		$SUDO systemctl daemon-reload
		$SUDO systemctl enable --now "$svc"
	else
		systemctl --user daemon-reload
		systemctl --user enable --now "$svc"
	fi
	info "bitcoind ($net) service enabled ($mode/$os)"
}

command:disable() {
	# Default --system to match enable (the operate-verb default since
	# FEAT-261); --user is the explicit rootless opt-in.
	local mode=system net=mainnet
	while [ $# -gt 0 ]; do
		case "$1" in
			--user)         mode=user ;;
			--system)       mode=system ;;
			--network)      net="$2"; shift ;;
			--network=*)    net="${1#--network=}" ;;
			-h|--help|help) help:disable; return 0 ;;
			*) warn "disable: unknown argument '$1'"; return 1 ;;
		esac
		shift
	done
	local _nn; _nn="$(daemon:_network "--network=$net")" \
		|| { error "disable: unknown network '$net' (mainnet|testnet|signet|regtest)"; return 1; }
	net="$_nn"

	local os; os="$(daemon:_os)"
	case "$os" in linux|macos) ;; *)
		error "disable: unsupported platform '$(uname -s)'"; return 1 ;;
	esac

	local SUDO=""; [ "$mode" = system ] && SUDO=sudo
	local unit; unit="$(daemon:_unit_path "$os" "$mode" "$net")" \
		|| { error "disable: no unit path for $os/$mode"; return 1; }
	local label svc
	label="$(daemon:_label "$net")"; svc="$(daemon:_svcname "$net")"

	if [ "$os" = macos ]; then
		local domain
		if [ "$mode" = system ]; then domain="system"; else domain="gui/$(id -u)"; fi
		$SUDO launchctl bootout "$domain/$label" 2>/dev/null
	elif [ "$mode" = system ]; then
		$SUDO systemctl disable --now "$svc" 2>/dev/null
		$SUDO systemctl daemon-reload
	else
		systemctl --user disable --now "$svc" 2>/dev/null
		systemctl --user daemon-reload
	fi

	if [ -e "$unit" ]; then
		$SUDO rm -f "$unit" && info "removed $unit"
	fi
	info "bitcoind service disabled ($mode/$os); data dir preserved"
}

#------------------------------------------------------------------------------
# FEAT-033: install Bitcoin Core itself (daemon install).
#
# `bitcoind` is not in this repo; this verb wraps each platform's
# preferred install path so a clean host can reach a node without
# learning brew / macports / apt / apk / source idioms. The default
# source is chosen from `account platform`; --from overrides it. The
# package-manager binaries and `account` are all on PATH, so the
# suite mocks them.

# Default install source for the host platform.
daemon:_default_source() {
	case "$(account platform 2>/dev/null)" in
		macos)
			# MacPorts first: /opt/local is a world-readable, root-owned
			# tree a dedicated service account can run; Homebrew is the
			# fallback (FEAT — macports-first for system daemons).
			if command -v port >/dev/null 2>&1; then echo macports
			elif command -v brew >/dev/null 2>&1; then echo brew
			else echo source; fi ;;
		pureos|ubuntu|debian) echo apt ;;
		alpine)               echo apk ;;
		*)                    echo source ;;
	esac
}

# Require a command on PATH or emit an error and fail.
daemon:_need() {
	command -v "$1" >/dev/null 2>&1 && return 0
	error "install: required tool '$1' not found"
	return 1
}

# --from source: clone, build, and install Bitcoin Core. $BITCOIN_CORE_REPO
# overrides the upstream URL (used by the test harness).
daemon:_install_from_source() {
	local tag="$1" prefix="$2" tool repo workdir
	for tool in git make pkg-config; do
		daemon:_need "$tool" || return 1
	done
	repo="${BITCOIN_CORE_REPO:-https://github.com/bitcoin/bitcoin}"
	workdir="$(mktemp -d)"
	# shellcheck disable=SC2086
	git clone --depth 1 ${tag:+--branch} ${tag:+"$tag"} "$repo" "$workdir/bitcoin" \
		|| { error "install: git clone of '$repo' failed"; rm -rf "$workdir"; return 1; }
	(
		cd "$workdir/bitcoin" || exit 1
		[ -n "$tag" ] || tag="$(git describe --tags --abbrev=0 2>/dev/null)"
		info "building Bitcoin Core ${tag:-HEAD} (this takes a while)"
		./autogen.sh \
			&& ./configure --prefix "$prefix" --disable-wallet --disable-tests \
			&& make \
			&& sudo make install
	) || { error "install: source build failed"; rm -rf "$workdir"; return 1; }
	rm -rf "$workdir"
}

help:install() {
	cat >&2 <<-ENDHELP
	usage: $SELF install [--from <source>] [--tag <v>] [--prefix <path>]

	  Install the bitcoind binary. --from selects the source; the
	  default is chosen from the host platform:
	    macports  macOS (default; world-readable /opt/local — a
	              service account can run it; falls back to brew)
	    brew      macOS (fallback)
	    apt       Debian / Ubuntu / PureOS
	    apk       Alpine
	    source    clone + build from github.com/bitcoin/bitcoin
	    rpk       nostra124/bitcoind rpk package (not yet shipped)

	  --tag and --prefix apply only to --from source.
	ENDHELP
}

command:install() {
	local source="" tag="" prefix="/usr/local"
	while [ $# -gt 0 ]; do
		case "$1" in
			--from)     source="$2"; shift 2 ;;
			--from=*)   source="${1#--from=}"; shift ;;
			--tag)      tag="$2"; shift 2 ;;
			--tag=*)    tag="${1#--tag=}"; shift ;;
			--prefix)   prefix="$2"; shift 2 ;;
			--prefix=*) prefix="${1#--prefix=}"; shift ;;
			-h|--help|help) help:install; return 0 ;;
			*) warn "install: unknown argument '$1'"; return 1 ;;
		esac
	done
	[ -n "$source" ] || source="$(daemon:_default_source)"

	case "$source" in
		brew)
			daemon:_need brew || return 1
			brew install bitcoin || { error "install: 'brew install bitcoin' failed"; return 1; }
			;;
		macports)
			daemon:_need port || return 1
			sudo port install bitcoin || { error "install: 'port install bitcoin' failed"; return 1; }
			;;
		apt)
			daemon:_need apt-get || return 1
			if command -v add-apt-repository >/dev/null 2>&1; then
				sudo add-apt-repository -y ppa:luke-jr/bitcoincore
			fi
			sudo apt-get update
			sudo apt-get install -y bitcoind \
				|| { error "install: 'apt-get install bitcoind' failed"; return 1; }
			;;
		apk)
			daemon:_need apk || return 1
			sudo apk add bitcoin || { error "install: 'apk add bitcoin' failed"; return 1; }
			;;
		source)
			daemon:_install_from_source "$tag" "$prefix" || return 1
			;;
		rpk)
			error "install: --from rpk is not yet available; see docs/rpk-bitcoind.md"
			return 1
			;;
		*)
			error "install: unknown source '$source' (accepted: brew, macports, apt, apk, source, rpk)"
			return 1
			;;
	esac

	if command -v bitcoind >/dev/null 2>&1; then
		local v; v="$(bitcoind --version 2>/dev/null | head -1)"
		info "installed: $v"
		printf '%s\n' "$v"
	else
		warn "install: completed but no 'bitcoind' found on PATH"
		return 1
	fi
}

#------------------------------------------------------------------------------
# Query RPC credentials (rpcuser / rpcpassword) from bitcoin.conf.

help:password() {
	cat >&2 <<-ENDHELP
	usage: $SELF password [--user]

	  Print the RPC credentials for the given mode. Reads from
	  the secret store (bitcoin/rpc/<user>).
	ENDHELP
}

command:password() {
	for a in "$@"; do
		case "$a" in -h|--help|help) help:password; return 0 ;; esac
	done
	local mode
	mode="$(daemon:_mode "$@")"
	local conf="$(daemon:_confdir "$mode")/bitcoin.conf"
	if [ ! -f "$conf" ]; then
		error "password: no config at '$conf' (run 'bitcoin daemon enable' first)"
		return 1
	fi
	local rpcauth user
	rpcauth="$(sed -n 's/^rpcauth=//p' "$conf" | head -1)"
	if [ -z "$rpcauth" ]; then
		error "password: no rpcauth in '$conf' (not public mode)"
		return 1
	fi
	user="${rpcauth%%:*}"
	local pass
	pass="$(secret get "bitcoin/rpc/${user}" 2>/dev/null)" || {
		error "password: no secret stored for 'bitcoin/rpc/${user}'"
		return 1
	}
	echo "  user: $user"
	echo "  password: $pass"
	echo "  url: http://$user:$pass@localhost:8332"
}

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

#------------------------------------------------------------------------------
# If this is a builtin command, execute it, otherwise fall through
if has command $1; then
	debug "executing command:$1 ${@:2}"
	command:$1 "${@:2}" # array slice skipping first element
	exit $?
else
	command:help
	exit $?
fi
