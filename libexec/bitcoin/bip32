# bip32 (Hierarchical Deterministic Wallets) commands
command:ser32() {
	if local -i i=$1; ((i >= 0 && i < 1<<32)); then
		printf "%08X" $i | basenc --base16 -d
	else
		return 1
	fi
}

command:ser256() {
	if [[ "$1" =~ ^(0x)?([[:xdigit:]]{65,})$ ]]; then
		warn "unexpectedly large parameter"
		return 1
	elif [[ "$1" =~ ^(0x)?([[:xdigit:]]{64})$ ]]; then
		basenc --base16 -d <<<"${BASH_REMATCH[2]^^[a-f]}"
	elif [[ "$1" =~ ^(0x)?([[:xdigit:]]{1,63})$ ]]; then
		$FUNCNAME "0x0${BASH_REMATCH[2]}"
	else
		return 1
	fi
}

command:hash160() {
	openssl dgst -sha256 -binary |
	{
		# https://github.com/openssl/openssl/issues/16994
		# "-provider legacy" for openssl 3.0 || fallback for old versions
		2>/dev/null openssl dgst -provider legacy -rmd160 -binary ||
		openssl dgst -rmd160 -binary
	}
}

MAINNET_PUBLIC_VERSION_CODE=0x0488B21E
MAINNET_PRIVATE_VERSION_CODE=0x0488ADE4
TESTNET_PUBLIC_VERSION_CODE=0x043587CF
TESTNET_PRIVATE_VERSION_CODE=0x04358394

command:is-secret() (( $1 == TESTNET_PRIVATE_VERSION_CODE || $1 == MAINNET_PRIVATE_VERSION_CODE ))
command:is-public() (( $1 == TESTNET_PUBLIC_VERSION_CODE || $1 == MAINNET_PUBLIC_VERSION_CODE ))

command:create() {
	while getopts "st" flag; do
		if [ x"$1" = x'-t' ]; then
			local COMMAND_TEST=1
		fi
		shift 1
	done
	local header_format='%08X%02X%08X%08X'
	{
		if [ -n "${COMMAND_TEST}" ]; then
			printf "$header_format" $TESTNET_PRIVATE_VERSION_CODE 0 0 0
		else
			printf "$header_format" $MAINNET_PRIVATE_VERSION_CODE 0 0 0
		fi
		openssl mac -digest sha512 -macopt key:"Bitcoin seed" -binary hmac |
		basenc --base16 -w64 | tac | sed 2i00 
	} | basenc --base16 -d | bitcoin bip13 base58-encode
}

command:derive() {
	while getopts "st" flag; do
		if [ x"$1" = x'-t' ]; then
			local COMMAND_TEST=1
		fi
		if [ x"$1" = x'-s' ]; then
			local COMMAND_SEED=1
		fi
		shift 1
	done

	local header_format='%08X%02X%08X%08X'
	if [ -n "${COMMAND_SEED}" ]; then
		COMMAND_SEED=""
		{
			if [ -n "${COMMAND_TEST}" ]; then
        	  		printf "$header_format" $TESTNET_PRIVATE_VERSION_CODE 0 0 0
			else
				printf "$header_format" $MAINNET_PRIVATE_VERSION_CODE 0 0 0
			fi
			xxd -r -p | openssl mac -digest sha512 -macopt key:"Bitcoin seed" -binary hmac |
			basenc --base16 -w64 | tac | sed 2i00
		} | basenc --base16 -d | ${FUNCNAME[0]} $@
	fi

	if (( $# > 1 )); then
		fatal "too many parameters given : $@" 1
	elif [[ "$1" =~ ^[mM]?(/([[:digit:]]+h?|N))*$ ]]; then
		local path="$1" hexdump="$(
		if test -t 0; then
			read -p "eXtended key (secret or public): "
			bitcoin bip13 base58-decode <<<"$REPLY"
		else
			cat
		fi | head -c 78 | basenc --base16 -w0)"
	
		if (( ${#hexdump} < 2*78 )); then
			fatal "$FUNCNAME: input is too short" -1
		fi

		local -i      version="0x${hexdump:0:8}"
		local -i        depth="0x${hexdump:8:2}"
		local -i    parent_fp="0x${hexdump:10:8}"
		local -i child_number="0x${hexdump:18:8}"
		local      chain_code="${hexdump:26:64}"
		local             key="${hexdump:90:66}"

		# sanity checks
		if [[ "$path" =~ ^m ]] && ((
			version != TESTNET_PRIVATE_VERSION_CODE &&
			version != MAINNET_PRIVATE_VERSION_CODE
		)); then
			fatal "eXtended key represents no private key" 2
		elif [[ "$path" =~ ^M ]] && ((
			version != TESTNET_PUBLIC_VERSION_CODE &&
			version != MAINNET_PUBLIC_VERSION_CODE
		)); then
			fatal "eXtended key represents no public key" 3
		elif [[ "$path" =~ ^[mM] ]] && ((depth > 0)); then
			fatal "eXtended key has to be a master key with depth = 0" 4
		elif [[ "$path" =~ ^[mM] ]] && ((parent_fp > 0)); then
			fatal "eXtended key has to be a master key with no parent" 5
		elif [[ "$path" =~ ^[mM] ]] && ((child_number > 0)); then
			fatal "eXtended key has to be a master key child number = 0" 6
		elif [[ ! "$key" =~ ^0[023] ]]; then
			fatal "unexpected key: $key (hexdump is $hexdump)" 7
		elif ((
			version != TESTNET_PRIVATE_VERSION_CODE &&
			version != MAINNET_PRIVATE_VERSION_CODE &&
			version != TESTNET_PUBLIC_VERSION_CODE  &&
			version != MAINNET_PUBLIC_VERSION_CODE
		)); then
			fatal "key has to be either a private or a public key" 8
		elif ((depth < 0 || depth > 255)); then
			fatal "key depth has to be between 0 and 255" 9
		elif ((parent_fp < 0 || parent_fp > 0xffffffff)); then
			fatal "key parent has to be between 0 and 0xffffffff" 10
		elif ((child_number < 0 || child_number > 0xffffffff)); then
			fatal "key child number has to be between 0 and 0xffffffff" 11
		elif command:bip32-is-public  $version && [[ "$key" =~ ^00    ]]; then
			fatal "key is not a valid public key" 12
		elif command:bip32-is-secret $version && [[ "$key" =~ ^0[23] ]]; then
			fatal "key is not a valid private key" 13
		fi
		
		path="${path#[mM]}"
		if test -n "$path"; then
			coproc DC { dc -e "$secp256k1" -; }
			trap 'echo q >&"${DC[1]}"' EXIT RETURN
			while [[ "$path" =~ ^/(N|[[:digit:]]+h?) ]]; do
				path="${path#/${BASH_REMATCH[1]}}"
				local operator="${BASH_REMATCH[1]}"
				case "$operator" in
					N)
						case $version in
							$((TESTNET_PUBLIC_VERSION_CODE))) ;;
							$((MAINNET_PUBLIC_VERSION_CODE))) ;;
							$((MAINNET_PRIVATE_VERSION_CODE)))
								version=$MAINNET_PUBLIC_VERSION_CODE;;&
							$((TESTNET_PRIVATE_VERSION_CODE)))
								version=$TESTNET_PUBLIC_VERSION_CODE;;&
							*)
								echo "4d*doilgx${key^^}l;xlex" >&"${DC[1]}"
								read key <&"${DC[0]}"
						esac
						;;
					+([[:digit:]])h)
						(( child_number= ${operator%h} + (1 << 31) ));&
					+([[:digit:]]))
						((depth++))
						local parent_id
						if [[ ! "$operator" =~ h$ ]]; then
							child_number=operator
						fi
						if command:is-secret "$version"; then
							echo "4d*doilgx${key^^}l;xlex" >&"${DC[1]}"
							read parent_id <&"${DC[0]}"
							{
								{
									if (( child_number >= (1 << 31) )); then
										printf "\x00"
										command:ser256 "0x${key:2}" || warn "WARNING: ser256 return $?"
									else
										basenc --base16 -d <<<"${parent_id^^[a-f]}"
									fi
									command:ser32 $child_number
								} | openssl dgst -sha512 -mac hmac -macopt hexkey:"$chain_code" -binary | basenc --base16 -w64 | 
								{
									read left
									read right
									echo "4d*doi$right ${key^^} $left+ln%p"
								}
							} >&"${DC[1]}"
						elif command:is-public "$version"; then
							parent_id="$key"
							if (( child_number >= (1 << 31) )); then
								fatal "extented public key can't produce a hardened child" 4
							else
								{
									{
										basenc --base16 -d <<<"${key^^[a-f]}"
										command:ser32 $child_number
									} | openssl dgst -sha512 -mac hmac -macopt hexkey:"$chain_code" -binary | basenc --base16 -w64 |
									{
										read left
										read right
										echo "8d+doi$right lgx$left l;x ${key^^}l>x l<~rljx lPxlex 0"
									}
								} >&"${DC[1]}"
							fi
						else
							fatal "version is neither private nor public?!" 111
						fi
						read key <&"${DC[0]}"
						while ((${#key} < 66)); do
							key="0$key"
						done
						echo rp >&"${DC[1]}"
						read chain_code <&"${DC[0]}"
						while ((${#chain_code} < 64)); do
							chain_code="0$chain_code"
						done
						parent_fp="0x$(basenc --base16 -d <<<"${parent_id^^[a-f]}" | command:hash160 | head -c 4 | basenc --base16 -w0)"
						;;
				esac
			done
		fi				
		printf "$header_format%s%s" $version $depth $parent_fp $child_number "$chain_code" "$key" |
		basenc --base16 -d | if [[ -t 1 ]]; then
			$SELF bip13 base58-encode
		else
			cat
		fi		
	else
		fatal "no deriviation path given" 255
	fi
}

help:derive() {
	cat <<-END_USAGE
usage: $SELF bip32 [-st] [derivation-path]

Generates extended keys as defined by BIP-0032. When writing to a terminal,
$SELF will print the base58-checked version of the serialized key. Otherwise, 
it will print the serialized key.

With no argument, $SELF will generate an extended master key from a binary
seed read on standard input. With the -t option, it will generate such key
for the test network.

With a derivation path as an argument, $SELF will read a seralized extended 
key from stdin and generate the corresponding derived key.

If the derivation path begins with 'm', $SELF will expect a master private
key as input. If the derivation path begins with 'M', $SELF will expect a 
master public key as input. Otherwise the derivation path begins with '/', 
then we will derive any key read from standard input.

When expecting a serialized key from stdin, $SELF will only read the first
78 bytes. With the -s option, input is interpreted as a seed in hex format,
not as a serialized key. With the -t option, input is interpreted as a seed,
and a testnet master key is generated.
END_USAGE
}

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

#------------------------------------------------------------------------------
# If this is a builtin command, execute it, otherwise fall through
if has command $1; then
	debug "executing command:$1 ${@:2}"
	command:$1 "${@:2}" # array slice skipping first element
	exit $?
elif scripts has $SELF/$1; then
	scripts $SELF/$1 "${@:2}" # array slice skipping first element
	exit $?
else
	command:help
	exit $?
fi
