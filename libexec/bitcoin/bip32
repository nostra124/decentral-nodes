#!/usr/bin/env bash

############################################################################
# Configuration section
############################################################################

############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

VERSION='0.6'
SELF=$(basename $0)

die() {
	echo "$1" >&2
	exit "${2:-1}"
}

fatal() {
	echo "$SELF: fatal - $1" >&2
	exit "${2:-1}"
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $@" >&2
}

info() {
	if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$@\033[0m" >&2; fi
}

warn() {
	echo -e "$SELF: warn - \033[31;1;m$@\033[0m" >&2
}

# Log an error without exiting. See skills/logging.md.
error() {
	echo -e "$SELF: error - \033[31;1;m$@\033[0m" >&2
}

# checks if a certain function exists: eg. has command update
has() {
	local KIND=$1
	local NAME=$2

	type -t $KIND:$NAME | grep -q function
}

escape() {
	if test -t 1; then
		xxd -p -c 0
#		cat -v
	else
		cat
	fi
}

# We need to run getops as soon as possible so we catch -d and other
# options that will modify our behaviour.
# Commands are handled at the end of this script.
while getopts "c:dqpt" flag; do
	if [ x"$1" = x'-q' ]; then
		SELF_QUIET=1
	fi
	if [ x"$1" = x'-d' ]; then
		SELF_DEBUG=1
	fi
	if [ x"$1" = x'-p' ]; then
		SELF_PASSPHRASE=1
	fi
	if [ x"$1" = x'-t' ]; then
		SELF_TEST=1
	fi
	shift 1
done

# Read configuration and set defaults if anything's not set
: ${XDG_CONFIG_HOME:="~/.config"}
: ${XDG_CACHE_HOME:="~/.cache"}
: ${XDG_DATA_HOME:="~/.local/var"}
: ${XDG_SHARE_HOME:="$HOME/.local/share"}

[ -n "$SELF_VERBOSE" ] && set -vx

command:help() {
	if [[ $# != 0 ]]; then
		if ! has command $1; then
			echo "'$1' is not an $SELF command"
			echo ""
			echo "please see '$SELF help'"
			exit -1
		elif ! has help $1; then
			echo "No help found for '$1'"
			echo ""
			echo "please see '$SELF help'"
			exit -2
		else
			help:$1
			return 0
		fi
	else
		cat >&2 <<ENDHELP
usage: $SELF <options> <command>

options:
 -d                     Enable debug output
 -q                     Enable quiet mode
 -t                     generate key for test net

 $SELF implements commands for hierarchical deterministic 
 wallets.

 Generates extended keys as defined by BIP-0032. When writing to a terminal,
 $SELF will print the base58-checked version of the serialized key. Otherwise,
 it will print the serialized key.

 With no argument, $SELF will generate an extended master key from a binary
 seed read on standard input. With the -t option, it will generate such key
 for the test network.

 With a derivation path as an argument, $SELF will read a seralized extended
 key from stdin and generate the corresponding derived key.

 If the derivation path begins with 'm', $SELF will expect a master private
 key as input. If the derivation path begins with 'M', $SELF will expect a
 master public key as input. Otherwise the derivation path begins with '/',
 then we will derive any key read from standard input.

 When expecting a serialized key from stdin, $SELF will only read the first
 78 bytes. With the -s option, input is interpreted as a seed in hex format,
 not as a serialized key. With the -t option, input is interpreted as a seed,
 and a testnet master key is generated.

generic commands:
  help                    print this help message
  help <command>          prints command specific help.
  version                 print the version of $SELF

bip32 related commands:
  ser32 <i>               serialize a 32-bit unsigned integer <i> as a 4-byte
                          sequence, most significant byte first
  ser256 <p>              serializes the integer <p> as a 32-byte sequence,
                          most significant byte first.
  hash160                 calculates the has160 for the input read from stdin

  is-secret <key>   checks if the given key is a secret key
  is-public <key>   checks if the given key is a public key
  create [-st] [p]  generates extended keys from a seed read from stdin
  derive

ENDHELP
	fi
}

command:version() {
	echo $VERSION
}

