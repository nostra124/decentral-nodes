#!/usr/bin/env bash
#
# libexec/bitcoin/bip380 — BIP-380 output script descriptors.
#
# Public verbs match BIP-380's three operations: checksum (compute
# the 8-char polymod suffix), verify (assert a descriptor's
# embedded checksum), derive (instantiate the '*' placeholder and
# emit the resulting address). Address construction composes
# primitives from sibling plugins (bip13 base58, bip32 derive,
# bip173 encode-values) — per CLAUDE.md §4, this plugin doesn't
# share libraries with them.
#
# `bitcoin descriptor wallet <name>` (FEAT-026's wallet-touching
# verb) stays in bin/bitcoin because it reads wallet state via
# `secret get` and `wallet:_path`. It's wired to call this plugin
# for the checksum step. A future PR may re-home it under
# `bitcoin wallet descriptor` for cleaner separation.

[ -n "$SELF_DEBUG" ] && set -vx

SELF=$(basename "$0")
VERSION='0.1'

# Sibling-plugin directory. When invoked via the bitcoin dispatcher
# (`bitcoin bip380 ...`), $0 is the absolute libexec path, so
# dirname gives us $SELF_LIBEXEC/bitcoin. When invoked directly
# (`./libexec/bitcoin/bip380 ...`), dirname gives the same
# directory. Either way, sibling plugins (bip13, bip32, bip173)
# resolve under here. Avoids the `$SELF:-bitcoin` trick used while
# everything lived in bin/bitcoin — that broke once bip380 became
# its own plugin (SELF=bip380).
declare -r BIP380_SIBLINGS="$(cd "$(dirname "$0")" && pwd)"

die()   { echo "$SELF: fatal - $1" >&2; exit "${2:-1}"; }
debug() { [ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $*" >&2; }
info()  { [ -z "$SELF_QUIET" ] && echo -e "$SELF: info - \033[33;m$*\033[0m" >&2; }
warn()  { echo -e "$SELF: warn - \033[31;1;m$*\033[0m" >&2; }
error() { echo -e "$SELF: error - \033[31;1;m$*\033[0m" >&2; }

has() {
	local KIND=$1 NAME=$2
	type -t "$KIND:$NAME" 2>/dev/null | grep -q function
}

# Hash160(stdin-hex). Pipe-friendly: takes hex on stdin, prints hex
# on stdout. Duplicated from bin/bitcoin (CLAUDE.md §5) so this
# plugin doesn't depend on the dispatcher.
_hash160_hex() {
	local hex; read -r hex
	printf '%s' "$hex" \
		| xxd -r -p \
		| openssl dgst -sha256 -binary \
		| openssl dgst -rmd160 -binary \
		| xxd -p -c 0 \
		| tr -d '\n'
	printf '\n'
}

# 8-to-5 bit regrouping for bech32 encoding (BIP-173 §convertbits).
# Reads decimal integers (one per line) on stdin, emits decimal
# 5-bit groups on stdout. Used by the wpkh address path before
# handing the data list to bip173 encode-values.
_convertbits() {
	local -i inbits=$1 outbits=$2 pad=${3:-1} val=0 bits=0
	local -i maxv=$(( (1 << outbits) - 1 ))
	while read; do
		(( val=(val<<inbits)|REPLY, bits+=inbits ))
		while ((bits >= outbits)); do
			(( bits-=outbits ))
			echo $(( (val >> bits) & maxv ))
		done
	done
	if ((pad > 0)) && ((bits > 0)); then
		echo $(( (val << (outbits-bits)) & maxv ))
	fi
}

# BIP-173 / BIP-141 P2WPKH address from a compressed pubkey hex.
# Computes the 20-byte HASH160(pubkey), prepends witness version 0,
# regroups to 5-bit values, and hands off to the bip173 plugin for
# the bech32 encode. Mainnet HRP "bc".
descriptor:_p2wpkh_address() {
	local pubkey_hex="$1"
	local libexec="${SELF_LIBEXEC:?descriptor:_p2wpkh_address: SELF_LIBEXEC must be set}"
	local h160; h160="$(printf '%s' "$pubkey_hex" | _hash160_hex)"
	local -a five_bit
	mapfile -t five_bit < <(
		echo -n "$h160" | while read -n 2; do echo $((16#$REPLY)); done | _convertbits 8 5
	)
	"$BIP380_SIBLINGS/bip173" encode-values bc 0 "${five_bit[@]}"
}

command:help() {
	cat >&2 <<-ENDHELP
	usage: $SELF <subcommand> [args]

	  checksum <s>      append a BIP-380 §Checksum to the descriptor body;
	                    if <s> already ends in '#<8 chars>', replace it.
	  verify <s>        verify a descriptor's checksum; exit 0 on success.
	  derive <desc> <i> instantiate the '*' placeholder in <desc> with <i>
	                    and emit the resulting address. Supports wpkh()
	                    (bech32 segwit, via bip173), pkh() (legacy P2PKH),
	                    and sh(wpkh()) (P2SH-nested segwit). tr() and
	                    combo() return a clear 'not yet implemented'.
	  help              this message
	  version           plugin version

	BIP-380 §Checksum defines an 8-character polymod-based suffix
	after a '#' separator: descriptor body, '#', 8 bech32-charset
	chars. See bitcoin-bip380(1) for the full reference.

	Standards:
	  BIP-380 (Output script descriptors, general)
	  BIP-381 (Non-segwit output script descriptors)
	  BIP-386 (tr() output script descriptors)
	  local: share/doc/bitcoin/standards/bip-0380.mediawiki
	ENDHELP
}

command:version() { echo "$VERSION"; }


# ---------------------------------------------------------------------------

# INPUT_CHARSET — 95 chars. Position in string == symbol value.
declare -gr BIP380_INPUT_CHARSET=$'0123456789()[],\'/*abcdefgh@:$%{}IJKLMNOPQRSTUVWXYZ&+-.;<=>?!^_|~ijklmnopqrstuvwxyzABCDEFGH`#"\\ '

declare -gr BIP380_CHECKSUM_CHARSET="qpzry9x8gf2tvdw0s3jn54khce6mua7l"

descriptor:_polymod() {
	local -a generator=(0xf5dee51989 0xa9fdca3312 0x1bab10e32d 0x3706b1677a 0x644d626ffd)
	local -i chk=1 v top i
	for v; do
		(( top = chk >> 35,
		   chk = (chk & 0x7ffffffff) << 5 ^ v ))
		for i in 0 1 2 3 4; do
			(( ((top >> i) & 1) && (chk ^= generator[i]) )) || true
		done
	done
	echo $chk
}

descriptor:_expand() {
	local s="$1"
	local -ai groups=() symbols=()
	local -i i v idx j
	local c
	for ((i=0; i<${#s}; i++)); do
		c="${s:i:1}"
		idx=-1
		for ((j=0; j<${#BIP380_INPUT_CHARSET}; j++)); do
			if [[ "${BIP380_INPUT_CHARSET:j:1}" == "$c" ]]; then
				idx=$j
				break
			fi
		done
		(( idx < 0 )) && return 1
		v=$idx
		symbols+=( $(( v & 31 )) )
		groups+=( $(( v >> 5 )) )
		if (( ${#groups[@]} == 3 )); then
			symbols+=( $(( groups[0] * 9 + groups[1] * 3 + groups[2] )) )
			groups=()
		fi
	done
	if (( ${#groups[@]} == 1 )); then
		symbols+=( ${groups[0]} )
	elif (( ${#groups[@]} == 2 )); then
		symbols+=( $(( groups[0] * 3 + groups[1] )) )
	fi
	printf '%s\n' "${symbols[@]}"
}

descriptor:_create() {
	local body="$1"
	local -a expanded
	mapfile -t expanded < <(descriptor:_expand "$body") \
		|| { error "descriptor: invalid character in '$body'"; return 1; }
	if (( ${#expanded[@]} == 0 )) && [ -n "$body" ]; then
		error "descriptor: invalid character in '$body'"
		return 1
	fi
	local -i chk
	chk=$(descriptor:_polymod "${expanded[@]}" 0 0 0 0 0 0 0 0)
	(( chk ^= 1 ))
	local -i i val
	local out="$body#"
	for i in 0 1 2 3 4 5 6 7; do
		(( val = (chk >> (5 * (7 - i))) & 31 ))
		out+="${BIP380_CHECKSUM_CHARSET:val:1}"
	done
	printf '%s\n' "$out"
}

command:checksum() {
	local s="${1:-}"
	[ -n "$s" ] || { error "descriptor checksum: argument required"; return 2; }
	# If the input already ends in `#<8 chars>`, strip and re-compute.
	if (( ${#s} > 9 )) && [[ "${s: -9: 1}" == "#" ]]; then
		s="${s:0: ${#s}-9}"
	fi
	descriptor:_create "$s"
}

command:verify() {
	local s="${1:-}"
	[ -n "$s" ] || { error "descriptor verify: argument required"; return 2; }
	if (( ${#s} < 10 )) || [[ "${s: -9: 1}" != "#" ]]; then
		error "descriptor verify: no '#' separator + 8-char checksum suffix"
		return 3
	fi
	local body="${s:0: ${#s}-9}"
	local chksum="${s: -8}"
	local -i i j
	local c
	# Every checksum char must be in BIP380_CHECKSUM_CHARSET.
	for ((i=0; i<8; i++)); do
		c="${chksum:i:1}"
		case "$BIP380_CHECKSUM_CHARSET" in
			*"$c"*) ;;
			*) error "descriptor verify: checksum char '$c' not in bech32 set"; return 4 ;;
		esac
	done
	local -a expanded
	mapfile -t expanded < <(descriptor:_expand "$body") \
		|| { error "descriptor verify: invalid character in body"; return 5; }
	local -ai cksym=()
	for ((i=0; i<8; i++)); do
		c="${chksum:i:1}"
		for ((j=0; j<32; j++)); do
			if [[ "${BIP380_CHECKSUM_CHARSET:j:1}" == "$c" ]]; then
				cksym+=( $j )
				break
			fi
		done
	done
	local -i chk
	chk=$(descriptor:_polymod "${expanded[@]}" "${cksym[@]}")
	if (( chk == 1 )); then
		return 0
	else
		error "descriptor verify: checksum mismatch (got polymod=$chk, expected 1)"
		return 6
	fi
}

# ---------------------------------------------------------------------------

command:derive() {
	local desc="${1:-}" idx="${2:-}"
	if [ -z "$desc" ] || [ -z "$idx" ]; then
		error "descriptor derive: usage: descriptor derive <descriptor> <index>"
		return 2
	fi
	if [[ ! "$idx" =~ ^[0-9]+$ ]]; then
		error "descriptor derive: <index> must be a non-negative integer (got '$idx')"
		return 3
	fi

	# Strip and verify optional checksum suffix.
	local body="$desc"
	if (( ${#desc} > 9 )) && [[ "${desc: -9: 1}" == "#" ]]; then
		if ! command:verify "$desc" >/dev/null 2>&1; then
			error "descriptor derive: checksum suffix on '$desc' is invalid"
			return 4
		fi
		body="${desc:0: ${#desc}-9}"
	fi

	# Dispatch on the outer descriptor function. Each branch extracts
	# the inner key+path, runs the shared `_derive_pubkey` pipeline,
	# and hands the resulting compressed pubkey to a per-function
	# address encoder.
	local fn inner_body inner_fn
	if [[ "$body" =~ ^sh\((.*)\)$ ]]; then
		fn="sh"
		inner_body="${BASH_REMATCH[1]}"
		inner_fn="${inner_body%%(*}"
		# In 1.20.0 the only supported sh() inner is wpkh().
		if [[ "$inner_fn" != "wpkh" ]]; then
			error "descriptor derive: 'sh($inner_fn(...))' is not yet implemented (only sh(wpkh()) ships here)"
			return 5
		fi
	else
		fn="${body%%(*}"
		inner_body="$body"
	fi

	case "$fn" in
		wpkh|pkh|sh|tr) ;;
		combo) ;;
		*)
			error "descriptor derive: unknown descriptor function '$fn'"
			return 6
			;;
	esac

	# All currently-supported functions wrap a wpkh-shaped key body
	# ('<xpub>/<path>'). _parse_wpkh accepts both 'wpkh(...)' and
	# 'pkh(...)' because the inner shape is identical.
	local parsed
	if ! parsed="$(descriptor:_parse_key_body "$inner_body")"; then
		error "descriptor derive: malformed descriptor body '$inner_body' (need '<fn>(<xpub>/<path>)' with at least one '/')"
		return 7
	fi
	local xpub="${parsed%%	*}"
	local path="${parsed#*	}"

	if [[ "$path" != *"*"* ]]; then
		error "descriptor derive: descriptor has no '*' placeholder to instantiate"
		return 8
	fi
	path="${path//\*/$idx}"

	local pubkey
	if ! pubkey="$(descriptor:_derive_pubkey "$xpub" "$path")"; then
		# _derive_pubkey already emitted a specific error.
		return 9
	fi

	case "$fn" in
		wpkh)  descriptor:_p2wpkh_address      "$pubkey" ;;
		pkh)   descriptor:_pkh_address         "$pubkey" ;;
		sh)    descriptor:_p2sh_p2wpkh_address "$pubkey" ;;
		tr)    descriptor:_tr_address          "$pubkey" ;;
		combo)
			descriptor:_pkh_address         "$pubkey"
			descriptor:_p2wpkh_address      "$pubkey"
			descriptor:_p2sh_p2wpkh_address "$pubkey"
			descriptor:_tr_address          "$pubkey"
			;;
	esac
}

# tr() — BIP-341 P2TR address. The compressed pubkey's x-only half
# (drop the 02/03 parity byte) becomes BIP-341's internal key. Defers
# to libexec/bitcoin/bip341 for the TapTweak + bech32m address.
descriptor:_tr_address() {
	local pubkey="$1"
	[[ "$pubkey" =~ ^0[23][[:xdigit:]]{64}$ ]] \
		|| { error "descriptor derive tr: unexpected pubkey '$pubkey'"; return 1; }
	"$BIP380_SIBLINGS/bip341" address "${pubkey:2}"
}

# Extract '<xpub>/<path>' from a function body like 'wpkh(<xpub>/...)
# or 'pkh(<xpub>/...)'. Emits "<xpub><TAB><path>"; non-zero on a
# malformed body or a missing '/'.
descriptor:_parse_key_body() {
	local body="$1"
	if [[ ! "$body" =~ ^(wpkh|pkh|tr|combo)\((.*)\)$ ]]; then
		return 1
	fi
	local inner="${BASH_REMATCH[2]}"
	if [[ "$inner" != */* ]]; then
		return 2
	fi
	printf '%s\t%s\n' "${inner%%/*}" "${inner#*/}"
}

# Derive a compressed child pubkey from <xpub> at <path>. <path> is
# the post-substitution path (no '*'). Reuses the bip32 plugin via
# the same tmpfile dance the inline wpkh code used to use, so the
# 78-byte serialisation survives the null-byte hostile environment
# of bash command substitution.
descriptor:_derive_pubkey() {
	local xpub="$1" path="$2"
	local libexec="${SELF_LIBEXEC:?descriptor derive: SELF_LIBEXEC must be set}"
	if [ ! -x "$BIP380_SIBLINGS/bip32" ]; then
		error "descriptor derive: bip32 plugin not found at $BIP380_SIBLINGS/bip32"
		return 1
	fi
	if [ ! -x "$BIP380_SIBLINGS/bip13" ]; then
		error "descriptor derive: bip13 plugin not found at $BIP380_SIBLINGS/bip13"
		return 1
	fi
	local raw_decoded raw_serialised
	raw_decoded="$(mktemp)"
	raw_serialised="$(mktemp)"
	printf '%s' "$xpub" | "$BIP380_SIBLINGS/bip13" base58-decode 2>/dev/null > "$raw_decoded"
	if [ ! -s "$raw_decoded" ]; then
		rm -f "$raw_decoded" "$raw_serialised"
		error "descriptor derive: failed to base58-decode xpub '$xpub'"
		return 2
	fi
	local decoded_len; decoded_len="$(wc -c < "$raw_decoded")"
	if (( decoded_len != 82 )); then
		rm -f "$raw_decoded" "$raw_serialised"
		error "descriptor derive: decoded xpub is $decoded_len bytes, expected 82"
		return 3
	fi
	head -c 78 "$raw_decoded" > "$raw_serialised"
	local pubkey
	pubkey="$(
		"$BIP380_SIBLINGS/bip32" derive "/$path" 2>/dev/null < "$raw_serialised" \
			| tail -c 33 \
			| basenc --base16 -w0 \
			| tr A-F a-f
	)"
	rm -f "$raw_decoded" "$raw_serialised"
	if [[ ! "$pubkey" =~ ^0[23][[:xdigit:]]{64}$ ]]; then
		error "descriptor derive: derivation produced unexpected output '$pubkey'"
		return 4
	fi
	printf '%s\n' "$pubkey"
}

# BIP-13 P2PKH address from a compressed pubkey hex:
#   base58check(0x00 || HASH160(pubkey))
# Mainnet version byte 0x00; the resulting address starts with '1'.
descriptor:_pkh_address() {
	local pubkey_hex="$1"
	local pubkey_hash; pubkey_hash="$(printf '%s' "$pubkey_hex" | _hash160_hex)"
	descriptor:_base58check_hex "00$pubkey_hash"
}

# BIP-13 P2SH wrap of a P2WPKH redeem script:
#   redeem_script = 00 14 || HASH160(pubkey)
#   address       = base58check(0x05 || HASH160(redeem_script))
# Mainnet version byte 0x05; the resulting address starts with '3'.
descriptor:_p2sh_p2wpkh_address() {
	local pubkey_hex="$1"
	local pubkey_hash; pubkey_hash="$(printf '%s' "$pubkey_hex" | _hash160_hex)"
	local redeem_script="0014$pubkey_hash"
	local script_hash; script_hash="$(printf '%s' "$redeem_script" | _hash160_hex)"
	descriptor:_base58check_hex "05$script_hash"
}

# Base58Check-encode a binary file. Used to format the 78-byte
# extended-key serialisation into the canonical xpub/xprv/zpub
# textual form. BIP-32 §Serialization specifies the 4-byte SHA256d
# checksum appended to the data before base58 encoding; the bip13
# base58-encode plugin is plain base58 (no checksum), so this helper
# adds the checksum first.
descriptor:_base58check_file() {
	local infile="$1"
	local libexec="${SELF_LIBEXEC:?descriptor: SELF_LIBEXEC must be set}"
	local tmp; tmp="$(mktemp)"
	# data || sha256d(data)[:4]
	{
		cat "$infile"
		openssl dgst -sha256 -binary < "$infile" \
			| openssl dgst -sha256 -binary \
			| head -c 4
	} > "$tmp"
	"$BIP380_SIBLINGS/bip13" base58-encode < "$tmp"
	rm -f "$tmp"
}

# Hex-input sibling of _base58check_file. Used by the pkh / sh
# address derivations in 1.20.0; the data they hand off is small
# (21 bytes) and starts with a null version byte that command
# substitution would drop, so we pipe through bip13 base58-encode
# without ever capturing the raw bytes into a bash variable.
#
# Standard base58check emits one '1' character per leading 0x00
# byte in the payload (preserving byte count over an otherwise
# big-int encoding). `bip13 base58-encode` treats its input as a
# pure integer and drops leading zeros, so we prepend the missing
# '1's here. The P2PKH path (mainnet prefix 0x00) relies on this.
descriptor:_base58check_hex() {
	local data_hex="$1"
	local libexec="${SELF_LIBEXEC:?descriptor: SELF_LIBEXEC must be set}"
	# Count leading 0x00 bytes in the hex input.
	local -i leading_zeros=0
	while [[ "${data_hex:leading_zeros*2:2}" == "00" ]]; do
		(( leading_zeros++ ))
	done
	local tail
	tail="$(
		{
			printf '%s' "$data_hex" | xxd -r -p
			printf '%s' "$data_hex" | xxd -r -p \
				| openssl dgst -sha256 -binary \
				| openssl dgst -sha256 -binary \
				| head -c 4
		} | "$BIP380_SIBLINGS/bip13" base58-encode
	)"
	local prefix=""
	local -i i
	for ((i=0; i<leading_zeros; i++)); do prefix+="1"; done
	printf '%s%s\n' "$prefix" "$tail"
}


# ---- dispatch ----
#
# Source-safe: when this file is sourced (white-box tests), define
# every function and return without running the dispatcher.
[[ "${BASH_SOURCE[0]}" != "$0" ]] && return 0

if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

if has command "$1"; then
	debug "executing command:$1 ${*:2}"
	"command:$1" "${@:2}"
	exit $?
else
	error "unknown command: '$1' (see '$SELF help')"
	exit 1
fi
