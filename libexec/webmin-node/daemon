#!/usr/bin/env bash

############################################################################
# webmin daemon — system Webmin web administration service.
#
# Tier 3 (Self-hosting) tool. Installs and operates Webmin
# (https://www.webmin.com/), a browser-based system administration UI.
# Webmin ships its own mini HTTPS server (miniserv.pl) and, unlike the
# other nodes, runs AS ROOT (it administers the host) — so there is no
# dedicated service account.
#
# Layout (Linux, official package):
#   binary/libs  /usr/share/webmin
#   config       /etc/webmin (miniserv.conf, miniserv.users)
#   logs         /var/log/webmin/miniserv.log
#   service      systemd unit `webmin` (installed by the package)
#   web UI       https://127.0.0.1:10000
#
# Webmin is packaged for Linux (apt/dnf) only; macOS is not supported by
# this node (no launchd package upstream).
############################################################################

[ -n "$SELF_DEBUG" ] && set -vx

SELF=$(basename "$0")

die()   { echo "$1" >&2; exit "${2:-1}"; }
fatal() { echo "$SELF: fatal - $1" >&2; exit "${2:-1}"; }
debug() { [ -n "$SELF_DEBUG" ] && echo "$SELF: debug - $*" >&2; }
info()  { if [ ! -n "$SELF_QUIET" ]; then echo -e "$SELF: info - \033[33;m$*\033[0m" >&2; fi; }
warn()  { echo -e "$SELF: warn - \033[31;1;m$*\033[0m" >&2; }
error() { echo -e "$SELF: error - \033[31;1;m$*\033[0m" >&2; }

is_macos() { [ "$(uname -s)" = "Darwin" ]; }

# --- commands ----------------------------------------------------------------

usage() {
	cat >&2 <<EOF
usage: webmin-node daemon <subcommand> [args]

   Lifecycle of the Webmin web administration service.

   lifecycle:
     start                       start the webmin service
     stop                        stop the webmin service
     restart                     stop + start
     status                      health check
     monitor                     tail the miniserv log

   setup:
     install [--from auto|apt|dnf]
                                 add the official repo and install webmin
     enable                      enable the boot service
     disable                     stop and disable the service

   Webmin runs as root and serves HTTPS on 127.0.0.1:10000. After
   install, open https://<host>:10000 and log in as a root/sudo user.
   See webmin-node-daemon(1).
EOF
	exit 1
}

webmin_running() {
	if command -v systemctl >/dev/null 2>&1; then
		systemctl --quiet is-active webmin 2>/dev/null
	else
		pgrep -f "miniserv.pl" >/dev/null 2>&1
	fi
}

require_linux() {
	if is_macos; then
		error "Webmin is not packaged for macOS via this node (no launchd service)."
		error "See https://www.webmin.com/ for a manual install."
		exit 2
	fi
}

cmd_install() {
	require_linux
	local from=auto
	while [ $# -gt 0 ]; do
		case "$1" in
			--from) from="$2"; shift 2 ;;
			-h|--help) usage ;;
			*) error "install: unexpected arg '$1'"; usage ;;
		esac
	done

	# Resolve the package manager.
	if [ "$from" = auto ]; then
		if command -v apt-get >/dev/null 2>&1; then from=apt
		elif command -v dnf >/dev/null 2>&1; then from=dnf
		else error "no supported package manager (apt-get/dnf) found"; exit 1
		fi
	fi

	# Validate BEFORE any network/sudo side effect.
	case "$from" in
		apt|dnf) ;;
		*) error "install: unknown --from '$from' (use auto|apt|dnf)"; exit 2 ;;
	esac

	info "installing Webmin via $from (official repo)..."

	# The upstream setup-repos.sh configures the signed Webmin repo for
	# both apt and dnf, then we install the package.
	local repo_script="https://raw.githubusercontent.com/webmin/webmin/master/setup-repos.sh"
	local tmp; tmp=$(mktemp)
	if command -v curl >/dev/null 2>&1; then
		curl -fsSL "$repo_script" -o "$tmp" || { error "could not fetch setup-repos.sh"; rm -f "$tmp"; exit 1; }
	elif command -v wget >/dev/null 2>&1; then
		wget -qO "$tmp" "$repo_script" || { error "could not fetch setup-repos.sh"; rm -f "$tmp"; exit 1; }
	else
		error "curl or wget required"; rm -f "$tmp"; exit 1
	fi
	sudo sh "$tmp" -f || { error "repo setup failed"; rm -f "$tmp"; exit 1; }
	rm -f "$tmp"

	case "$from" in
		apt)
			sudo apt-get update
			sudo apt-get install -y --install-recommends webmin
			;;
		dnf)
			sudo dnf install -y webmin
			;;
		*) error "unknown --from '$from' (use auto|apt|dnf)"; exit 2 ;;
	esac

	info "webmin installed — web UI on https://127.0.0.1:10000"
	info "next: webmin-node daemon enable && webmin-node daemon start"
}

cmd_enable() {
	require_linux
	command -v systemctl >/dev/null 2>&1 || { error "systemctl not found"; exit 1; }
	sudo systemctl enable webmin || { error "could not enable webmin (is it installed?)"; exit 1; }
	info "webmin service enabled at boot"
	info "next: webmin-node daemon start"
}

cmd_disable() {
	require_linux
	cmd_stop 2>/dev/null || true
	if command -v systemctl >/dev/null 2>&1; then
		sudo systemctl disable webmin 2>/dev/null || true
		info "webmin service disabled"
	fi
	info "config preserved: /etc/webmin"
}

cmd_start() {
	require_linux
	if webmin_running; then info "webmin already running"; return 0; fi
	sudo systemctl start webmin
	info "webmin started — https://127.0.0.1:10000"
}

cmd_stop() {
	require_linux
	if ! webmin_running; then info "webmin not running"; return 0; fi
	sudo systemctl stop webmin
	info "webmin stopped"
}

cmd_restart() {
	require_linux
	sudo systemctl restart webmin 2>/dev/null || { cmd_stop || true; sleep 1; cmd_start; }
	info "webmin restarted"
}

cmd_status() {
	if webmin_running; then
		echo "running"
		[ -f /etc/webmin/version ] && echo "version $(cat /etc/webmin/version)"
	else
		echo "down"
	fi
}

cmd_monitor() {
	local logfile="/var/log/webmin/miniserv.log"
	if [ ! -f "$logfile" ] && command -v journalctl >/dev/null 2>&1; then
		exec sudo journalctl -u webmin "${@:--f}"
	fi
	[ -f "$logfile" ] || { error "no log file at $logfile"; exit 2; }
	exec sudo tail "${@:--f}" "$logfile"
}

# Dispatch
case "${1:-help}" in
	start)    shift; cmd_start "$@" ;;
	stop)     shift; cmd_stop "$@" ;;
	restart)  shift; cmd_restart "$@" ;;
	status)   shift; cmd_status "$@" ;;
	monitor)  shift; cmd_monitor "$@" ;;
	install)  shift; cmd_install "$@" ;;
	enable)   shift; cmd_enable "$@" ;;
	disable)  shift; cmd_disable "$@" ;;
	help|-h|--help) usage ;;
	*)        usage; exit 1 ;;
esac
