				local archive_url="https://archive.hiro.so/mainnet/stacks-blockchain/mainnet-stacks-blockchain-latest.tar.zst"
				local archive_file="/tmp/stacks-chainstate.tar.zst"
				
				if curl -fsSL "$archive_url" -o "$archive_file" 2>/dev/null; then
