EOF
	sudo chmod +x /etc/init.d/stacks-node
	sudo rc-update add stacks-node default
	info "wrote /etc/init.d/stacks-node"
	info ""
	info "next:"
	info "    sudo rc-service stacks-node start"
	info "    stacks daemon status"
}

cmd_disable() {
	info "stopping daemon"
	cmd_stop "$@" 2>/dev/null || true
	
	# System-mode only
	if is_macos; then
		local plist="$STACKS_LAUNCHD_DIR/${LAUNCHD_LABEL}.plist"
		if [ -f "$plist" ]; then
			sudo launchctl unload "$plist" 2>/dev/null || true
			sudo rm "$plist"
			info "removed $plist"
		fi
	elif [ "$(init_system)" = "openrc" ]; then
		local init_d="${STACKS_INIT_D:-/etc/init.d}"
		if [ -f "$init_d/stacks-node" ]; then
			sudo rc-update del stacks-node default 2>/dev/null || true
			sudo rm "$init_d/stacks-node"
			info "removed $init_d/stacks-node"
		fi
	else
		if [ -f "/etc/systemd/system/${STACKS_SVC}.service" ]; then
			sudo systemctl stop "${STACKS_SVC}.service" 2>/dev/null || true
			sudo systemctl disable "${STACKS_SVC}.service" 2>/dev/null || true
			sudo rm "/etc/systemd/system/${STACKS_SVC}.service"
			sudo systemctl daemon-reload
			info "removed /etc/systemd/system/${STACKS_SVC}.service"
		fi
	fi
	info "daemon disabled"
	info "data directory preserved: /var/lib/stacks"
}

cmd_install() {
	info "installing stacks-node $STACKS_VERSION"
	
	local arch os
	if is_macos; then
		if [ "$(uname -m)" = "arm64" ]; then
			arch="arm64"
		else
			arch="x64"
		fi
		os="macos"
	else
		if [ "$(uname -m)" = "aarch64" ]; then
			arch="arm64"
		else
			arch="x64"
		fi
		os="linux"
	fi
	
	local download_url="https://github.com/stacks-network/stacks-core/releases/download/${STACKS_VERSION}/${os}-${arch}.zip"
	local tmp_dir; tmp_dir=$(mktemp -d)
	
	info "downloading $download_url"
	curl -sL "$download_url" -o "$tmp_dir/stacks.zip" || {
		error "failed to download stacks-node"
		rm -rf "$tmp_dir"
		return 1
	}
	
	info "extracting binary"
	unzip -q "$tmp_dir/stacks.zip" -d "$tmp_dir" || {
		error "failed to extract stacks-node"
		rm -rf "$tmp_dir"
		return 1
	}
	
	# Find the binary in the extracted archive
	local stacks_bin="$tmp_dir/stacks-node"
	if [ ! -f "$stacks_bin" ]; then
		# Try to find it in subdirectories
		stacks_bin=$(find "$tmp_dir" -name "stacks-node" -type f | head -1)
	fi
	
	if [ ! -f "$stacks_bin" ]; then
		error "could not find stacks-node binary in archive"
		rm -rf "$tmp_dir"
		return 1
	fi
	
	# Install to /usr/local/bin
	info "installing to /usr/local/bin/stacks-node"
	sudo mkdir -p /usr/local/bin
	sudo install -m 755 "$stacks_bin" /usr/local/bin/stacks-node
	
	rm -rf "$tmp_dir"
	
	info "stacks-node $STACKS_VERSION installed successfully"
	info ""
	info "next:"
	info "    stacks daemon enable"
	info "    stacks daemon status"
}

# Dispatch
case "${1:-help}" in
	start)    shift; cmd_start "$@" ;;
	stop)     shift; cmd_stop "$@" ;;
	restart)  shift; cmd_restart "$@" ;;
	status)   shift; cmd_status "$@" ;;
	monitor)  shift; cmd_monitor "$@" ;;
	enable)   shift; cmd_enable "$@" ;;
	disable)  shift; cmd_disable "$@" ;;
	install)  shift; cmd_install "$@" ;;
	help)     usage ;;
	*)       usage; exit 1 ;;
esac